---
// FooterBottomBar.astro -- D-38: Dark bottom bar with social icons, legal links, copyright

interface Props {
  footerData: {
    social: Array<{ id: string; platform: string; url: string }>;
    legal: Array<{ id: string; label: { de: string; en: string }; href: string }>;
    copyright: { de: string; en: string };
  };
  lang: 'en' | 'de';
}

const { footerData, lang } = Astro.props;
---

<div class="footer-bottom-bar">
  {/* Social as text links */}
  <div class="footer-bottom-bar__social">
    {footerData.social.map((social, i) => (
      <>
        <a
          href={social.url}
          target="_blank"
          rel="noopener"
          class="footer-bottom-bar__social-link link-underline"
        >{social.platform}</a>
        {i < footerData.social.length - 1 && (
          <span class="footer-bottom-bar__separator" aria-hidden="true">&middot;</span>
        )}
      </>
    ))}
  </div>

  {/* Legal links */}
  <div class="footer-bottom-bar__legal">
    {footerData.legal.map((item, i) => (
      <>
        <a href={item.href} class="link-underline footer-bottom-bar__legal-link">{item.label[lang]}</a>
        {i < footerData.legal.length - 1 && <span class="footer-bottom-bar__separator" aria-hidden="true">&middot;</span>}
      </>
    ))}
  </div>

  {/* Copyright */}
  <div class="footer-bottom-bar__copyright">
    {footerData.copyright[lang]}
  </div>
</div>

<style>
  .footer-bottom-bar {
    background: #0f0f0f;
    color: #ffffff;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-4) var(--space-8);
  }

  .footer-bottom-bar__social {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .footer-bottom-bar__social-link {
    color: #ffffff;
    text-decoration: none;
    font-size: var(--type-sm);
    transition: opacity 200ms ease;
  }

  .footer-bottom-bar__social-link:hover {
    opacity: 0.7;
  }

  .footer-bottom-bar__legal {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
    justify-content: center;
  }

  .footer-bottom-bar__legal-link {
    font-size: var(--type-sm);
    color: #ffffff;
    text-decoration: none;
  }

  .footer-bottom-bar__separator {
    color: #ffffff;
    opacity: 0.5;
  }

  .footer-bottom-bar__copyright {
    font-size: var(--type-sm);
    color: #ffffff;
    opacity: 0.8;
  }

  /* Responsive: stack vertically on mobile */
  @media (max-width: 767px) {
    .footer-bottom-bar {
      flex-direction: column;
      gap: var(--space-4);
      text-align: center;
      padding: var(--space-6) var(--space-4);
    }
  }
</style>
