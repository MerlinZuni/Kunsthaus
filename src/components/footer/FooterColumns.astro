---
// FooterColumns.astro -- D-37, D-39: Four-column footer content layout
// Address, hours, links/media, newsletter

interface Props {
  modeLabels?: { planning?: string; onsite?: string };
  footerData: {
    address: {
      street: string;
      zip: string;
      city: { de: string; en: string };
      mapsUrl: string;
      email: string;
      phone: string;
    };
    schedule: Array<{
      day: { de: string; en: string };
      hours: { de: string; en: string };
      closed: boolean;
    }>;
    openStatus: { de: string; en: string };
    quickLinks: Array<{ id: string; label: { de: string; en: string }; href: string }>;
    media: Array<{ id: string; label: { de: string; en: string }; href: string }>;
    newsletter: {
      description: { de: string; en: string };
      linkLabel: { de: string; en: string };
      href: string;
    };
  };
  lang: 'en' | 'de';
}

const { footerData, lang, modeLabels = { planning: 'Plan a visit', onsite: "I'm here" } } = Astro.props;

const quickLinksHeading = lang === 'de' ? 'SCHNELLZUGRIFF' : 'QUICK LINKS';
const mediaHeading = 'MEDIA';
const newsletterHeading = 'NEWSLETTER';

// Phase 03-01: mode state = URL. Active segment derived from pathname.
// Strip the configured base (/Kunsthaus) so the check works on GitHub Pages.
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const pathWithoutBase = Astro.url.pathname.startsWith(base)
  ? Astro.url.pathname.slice(base.length)
  : Astro.url.pathname;
const isOnsite = pathWithoutBase.startsWith('/onsite');
const planningHref = `${base}/`;
const onsiteHref = `${base}/onsite`;
---

<div class="footer-columns">
  {/* Column 1: Address */}
  <div class="footer-col">
    <h3 class="footer-col__heading sub-heading">KUNSTHAUS ZURICH</h3>
    <address class="footer-col__address">
      <p>{footerData.address.street}</p>
      <p><span data-i18n-de={`${footerData.address.zip} ${footerData.address.city.de}`} data-i18n-en={`${footerData.address.zip} ${footerData.address.city.en}`}>{footerData.address.zip} {footerData.address.city[lang]}</span></p>
    </address>
    <div class="footer-col__links">
      <a href={footerData.address.mapsUrl} class="footer-col__link footer-col__link--icon" target="_blank" rel="noopener">
        <span class="icon">location_on</span>
        <span>Google Maps</span>
      </a>
      <a href={`mailto:${footerData.address.email}`} class="footer-col__link footer-col__link--icon">
        <span class="icon">mail</span>
        <span>{footerData.address.email}</span>
      </a>
      <a href={`tel:${footerData.address.phone}`} class="footer-col__link footer-col__link--icon">
        <span class="icon">call</span>
        <span>{footerData.address.phone}</span>
      </a>
    </div>
  </div>

  {/* Column 2: Hours */}
  <div class="footer-col">
    <p class="footer-col__open-status" data-i18n-de={footerData.openStatus.de} data-i18n-en={footerData.openStatus.en}>{footerData.openStatus[lang]}</p>
    <ul class="footer-col__schedule">
      {footerData.schedule.map((entry) => (
        <li class:list={['footer-col__schedule-item', { 'footer-col__schedule-item--closed': entry.closed }]}>
          <span class="footer-col__day" data-i18n-de={entry.day.de} data-i18n-en={entry.day.en}>{entry.day[lang]}</span>
          <span class="footer-col__hours" data-i18n-de={entry.hours.de} data-i18n-en={entry.hours.en}>{entry.hours[lang]}</span>
        </li>
      ))}
    </ul>
  </div>

  {/* Column 3: Quick Links + Media */}
  <div class="footer-col">
    <h3 class="footer-col__heading sub-heading" data-i18n-de="SCHNELLZUGRIFF" data-i18n-en="QUICK LINKS">{quickLinksHeading}</h3>
    <ul class="footer-col__link-list">
      {footerData.quickLinks.map((link) => (
        <li><a href={link.href} class="footer-col__link touch-pulse" data-i18n-de={link.label.de} data-i18n-en={link.label.en}>{link.label[lang]}</a></li>
      ))}
    </ul>
    <h3 class="footer-col__heading sub-heading footer-col__heading--spaced" data-i18n-de="MEDIEN" data-i18n-en="MEDIA">{mediaHeading}</h3>
    <ul class="footer-col__link-list">
      {footerData.media.map((link) => (
        <li><a href={link.href} class="footer-col__link touch-pulse" data-i18n-de={link.label.de} data-i18n-en={link.label.en}>{link.label[lang]}</a></li>
      ))}
    </ul>
  </div>

  {/* Column 4: Newsletter */}
  <div class="footer-col">
    <h3 class="footer-col__heading sub-heading" data-i18n-de="NEWSLETTER" data-i18n-en="NEWSLETTER">{newsletterHeading}</h3>
    <p class="footer-col__text" data-i18n-de={footerData.newsletter.description.de} data-i18n-en={footerData.newsletter.description.en}>{footerData.newsletter.description[lang]}</p>
    <a
      href={footerData.newsletter.href}
      class="footer-col__subscribe btn hover-wipe-inverse touch-pulse touch-target"
    >
      <span data-i18n-de={footerData.newsletter.linkLabel.de} data-i18n-en={footerData.newsletter.linkLabel.en}>{footerData.newsletter.linkLabel[lang]}</span>
      <span class="icon">arrow_forward</span>
    </a>

    <div class="footer-col__mode-toggle" role="radiogroup" aria-label="Site mode">
      <span class="footer-col__mode-pill"></span>
      <a
        class:list={['footer-col__mode-segment', { 'footer-col__mode-segment--active': !isOnsite }]}
        href={planningHref}
        data-mode-segment="planning"
        role="radio"
        aria-checked={!isOnsite}
      >
        <span data-i18n-de="Besuch planen" data-i18n-en="Plan a Visit">{lang === 'de' ? 'Besuch planen' : 'Plan a Visit'}</span>
      </a>
      <a
        class:list={['footer-col__mode-segment', { 'footer-col__mode-segment--active': isOnsite }]}
        href={onsiteHref}
        data-mode-segment="onsite"
        role="radio"
        aria-checked={isOnsite}
      >
        <span data-i18n-de="Im Kunsthaus" data-i18n-en="At Kunsthaus">{lang === 'de' ? 'Im Kunsthaus' : 'At Kunsthaus'}</span>
      </a>
    </div>
  </div>
</div>

<style>
  .footer-columns {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-12);
    padding: var(--space-12) var(--space-8);
  }

  .footer-col {
    font-size: var(--type-md);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    line-height: var(--leading-normal);
  }

  .footer-col__heading {
    margin-bottom: var(--space-4);
  }

  .footer-col__heading--spaced {
    margin-top: var(--space-8);
  }

  .footer-col__address {
    font-style: normal;
    font-size: var(--type-sm);
    font-weight: var(--weight-light);
    margin-bottom: var(--space-4);
  }

  .footer-col__address p {
    margin: 0;
  }

  .footer-col__links {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    font-size: var(--type-sm);
    font-weight: var(--weight-light);
  }

  .footer-col__links a {
    display: inline-block;
  }

  .footer-col__link {
    color: var(--color-offwhite);
    text-decoration: none;
    opacity: 0.7;
    transition: opacity 0.3s ease;
  }

  .footer-col__link:hover {
    opacity: 1;
  }

  .footer-col__link--icon {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .footer-col__link--icon .icon {
    font-size: 18px;
    line-height: 1;
    vertical-align: middle;
    flex-shrink: 0;
  }

  .footer-col__open-status {
    font-weight: var(--weight-bold);
    margin-bottom: var(--space-4);
  }

  .footer-col__schedule {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .footer-col__schedule-item {
    display: flex;
    justify-content: space-between;
    gap: var(--space-4);
  }

  .footer-col__schedule-item--closed {
    color: var(--color-decorative-shadow);
  }

  .footer-col__link-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .footer-col__text {
    margin-bottom: var(--space-6);
  }

  .footer-col__subscribe {
    display: inline-flex;
    align-items: center;
    padding: var(--space-3) var(--space-6);
    text-decoration: none;
    width: 100%;
    justify-content: center;
    box-sizing: border-box;
  }

  .footer-col__mode-toggle {
    display: flex;
    position: relative;
    border: 1px solid color-mix(in srgb, var(--color-offwhite) 20%, transparent);
    border-radius: var(--btn-radius);
    padding: 3px;
    gap: 0;
    margin-top: var(--space-12);
    width: 100%;
  }

  .footer-col__mode-pill {
    position: absolute;
    top: 3px;
    left: 3px;
    height: calc(100% - 6px);
    border-radius: var(--btn-radius-inner);
    border: 1px solid var(--color-offwhite);
    pointer-events: none;
    z-index: 0;
  }

  .footer-col__mode-segment {
    position: relative;
    z-index: 1;
    flex: 1;
    background: none;
    border: none;
    border-radius: var(--btn-radius-inner);
    cursor: pointer;
    font-size: var(--type-sm);
    font-weight: var(--weight-regular);
    color: color-mix(in srgb, var(--color-offwhite) 50%, transparent);
    padding: 8px var(--btn-padding-x);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    text-align: center;
    white-space: nowrap;
    transition: color 0.3s ease;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .footer-col__mode-segment--active {
    font-weight: var(--weight-medium);
    color: var(--color-offwhite);
  }

  /* Responsive: 2 columns tablet, 1 column mobile */
  @media (max-width: 1023px) {
    .footer-columns {
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-8);
    }
  }

  @media (max-width: 767px) {
    .footer-columns {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
  }
</style>

<script>
  import { gsap } from 'gsap';

  // Phase 03-01: position the footer mode pill under the server-rendered
  // active segment. Runs on first paint and after every View Transitions nav.
  function initFooterModePill() {
    document.querySelectorAll('.footer-col__mode-toggle').forEach((toggleEl) => {
      const toggle = toggleEl as HTMLElement;
      const pill = toggle.querySelector('.footer-col__mode-pill') as HTMLElement | null;
      const active = toggle.querySelector('.footer-col__mode-segment--active') as HTMLElement | null;
      if (!pill || !active) return;
      const toggleRect = toggle.getBoundingClientRect();
      const activeRect = active.getBoundingClientRect();
      gsap.set(pill, {
        x: activeRect.left - toggleRect.left - 3,
        width: activeRect.width,
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => requestAnimationFrame(initFooterModePill));
  } else {
    requestAnimationFrame(initFooterModePill);
  }
  document.addEventListener('astro:page-load', () => requestAnimationFrame(initFooterModePill));
</script>
