---
// Footer.astro -- D-35 through D-39: Complete footer component
// Composes: FooterMarquee, FooterColumns, FooterBottomBar
// Includes ReduceMotionToggle per D-40

import FooterMarquee from './FooterMarquee.astro';
import FooterColumns from './FooterColumns.astro';
import FooterBottomBar from './FooterBottomBar.astro';
import ReduceMotionToggle from '../ui/ReduceMotionToggle.astro';
import footerJson from '../../content/shared/footer.json';

interface Props {
  lang: 'en' | 'de';
  modeLabels?: { planning?: string; onsite?: string };
  ticketsLabel?: string;
  ticketsHref?: string;
}

const {
  lang,
  modeLabels = { planning: 'Plan a visit', onsite: "I'm here" },
  ticketsLabel = 'Buy Tickets',
  ticketsHref = 'https://www.kunsthaus.ch/tickets',
} = Astro.props;

// Load footer content directly (bypasses dev-mode collection cache issue)
const footerData = footerJson[0];
---

<footer class="site-footer">
  <FooterMarquee />

  <FooterColumns footerData={footerData} lang={lang} modeLabels={modeLabels} />

  <div class="site-footer__utilities">
    <ReduceMotionToggle />
  </div>

  <FooterBottomBar footerData={footerData} lang={lang} />
</footer>

<style>
  .site-footer {
    position: relative;
    border-top: 1px solid rgba(34, 34, 34, 0.2);
    background-color: #272523;
    background-image: url(/Kunsthaus/textures/dark-wall.png);
    background-repeat: repeat;
    /* Force onsite-style text colors regardless of mode */
    --color-text: var(--color-offwhite);
    --color-surface: var(--color-softblack);
    --color-decorative-shadow: var(--color-concrete-light);
    color: var(--color-offwhite);
    z-index: 30;
    overflow: hidden;
  }

  html[data-mode="onsite"] .site-footer {
    background-color: #1e1c1a;
    background-image: none;
  }

  .site-footer__utilities {
    padding: 0 var(--space-8) var(--space-4);
  }
</style>
