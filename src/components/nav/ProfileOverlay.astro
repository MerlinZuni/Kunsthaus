---
// ProfileOverlay.astro -- Logged-in profile panel with QR ticket hero,
// 6 secondary nav items, and log out button.

interface Props {
  lang: 'en' | 'de';
}

const { lang } = Astro.props;

const ticketTitle = lang === 'de' ? 'Tagespass \u2014 Alle Ausstellungen' : 'Day Pass \u2014 All Exhibitions';
const validLabel = lang === 'de' ? '22. April 2026, 10:00\u201320:00' : '22 April 2026, 10:00\u201320:00';
const accessLabel = lang === 'de'
  ? 'Alle laufenden Ausstellungen + Sammlung'
  : 'All current exhibitions + permanent collection';
const signedInLabel = lang === 'de' ? 'Angemeldet als Demo User' : 'Signed in as Demo User';
const logoutLabel = lang === 'de' ? 'Abmelden' : 'Log out';
const memberLabel = lang === 'de' ? 'Mitglied werden' : 'Become a member';
const memberPitch = lang === 'de'
  ? 'Unbegrenzter Zugang, exklusive Events und kostenloser Audioguide.'
  : 'Unlimited access, exclusive events, and free audio guide.';

const navItems = [
  { label: { de: 'Weiteres Ticket kaufen', en: 'Buy another ticket' } },
  { label: { de: 'Geplante Besuche & Events', en: 'Upcoming visits & events' } },
  { label: { de: 'Mitgliedschaft', en: 'Membership' } },
  { label: { de: 'Kontoeinstellungen', en: 'Account settings' } },
  { label: { de: 'Hilfe & Kontakt', en: 'Help & contact' } },
];
---

<div
  class="profile-overlay"
  id="profile-overlay"
  aria-hidden="true"
  role="dialog"
  aria-label="Profile"
>
  <div class="profile-overlay__inner">
    <header class="profile-overlay__header">
      <div class="profile-overlay__left">
        <button class="profile-overlay__icon-btn touch-target" aria-label={lang === 'de' ? 'Suche' : 'Search'} data-action="search">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="11" cy="11" r="8"/>
            <line x1="21" y1="21" x2="16.65" y2="16.65"/>
          </svg>
        </button>
        <button class="profile-overlay__icon-btn touch-target" aria-label="Opening hours" data-action="open-hours">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12 6 12 12 16 14"/>
          </svg>
        </button>
      </div>
      <a href="/Kunsthaus/" class="profile-overlay__logo">
        <img src="/Kunsthaus/images/logo.png" alt="Kunsthaus Zürich" class="profile-overlay__logo-img" />
      </a>
      <div class="profile-overlay__right">
        <button type="button" class="profile-overlay__icon-btn touch-target" data-profile-close-x aria-label="Close">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
               stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <line x1="18" y1="6" x2="6" y2="18"/>
            <line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
        <button class="profile-overlay__icon-btn touch-target" aria-label="Menu" data-action="hamburger">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <line x1="3" y1="6" x2="21" y2="6"/>
            <line x1="3" y1="12" x2="21" y2="12"/>
            <line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
        </button>
      </div>
    </header>

    <div class="profile-overlay__body" data-lenis-prevent>
      <p class="profile-overlay__greeting" data-i18n-de="Hallo Merlin" data-i18n-en="Hello Merlin">{lang === 'de' ? 'Hallo Merlin' : 'Hello Merlin'}</p>
      {/* QR Ticket Hero */}
      <div class="profile-overlay__ticket">
        <div class="profile-overlay__qr">
          <span class="icon" aria-hidden="true">qr_code_2</span>
        </div>
        <div class="profile-overlay__ticket-info">
          <h3 class="profile-overlay__ticket-title" data-i18n-de="Tagespass — Alle Ausstellungen" data-i18n-en="Day Pass — All Exhibitions">{ticketTitle}</h3>
          <p class="profile-overlay__ticket-code">KUNSTHAUS-DEMO-2026-04-22-DAYPASS-001</p>
          <p class="profile-overlay__ticket-valid" data-i18n-de="22. April 2026, 10:00–20:00" data-i18n-en="22 April 2026, 10:00–20:00">{validLabel}</p>
          <p class="profile-overlay__ticket-access" data-i18n-de="Alle laufenden Ausstellungen + Sammlung" data-i18n-en="All current exhibitions + permanent collection">{accessLabel}</p>
        </div>
      </div>

      {/* Secondary nav */}
      <nav class="profile-overlay__nav" aria-label="Profile navigation">
        <ul>
          {navItems.map(item => (
            <li class="profile-overlay__nav-item">
              <a href="#" class="profile-overlay__nav-link">
                <span data-i18n-de={item.label.de} data-i18n-en={item.label.en}>{item.label[lang]}</span>
                <span class="icon profile-overlay__nav-arrow" aria-hidden="true">arrow_forward</span>
              </a>
            </li>
          ))}
        </ul>
      </nav>

      {/* Action buttons */}
      <div class="profile-overlay__actions">
        <button type="button" class="btn profile-overlay__member-btn hover-wipe-inverse touch-target">
          <span data-i18n-de="Mitglied werden" data-i18n-en="Become a member">{memberLabel}</span>
          <span class="icon" aria-hidden="true">arrow_forward</span>
        </button>
        <button type="button" class="btn profile-overlay__logout touch-target" data-profile-logout>
          <span data-i18n-de="Abmelden" data-i18n-en="Log out">{logoutLabel}</span>
        </button>
      </div>
    </div>
  </div>
</div>

<style>
  .profile-overlay {
    position: fixed;
    inset: 0;
    z-index: 80;
    background: color-mix(in srgb, var(--color-surface) 85%, transparent);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    opacity: 0;
    visibility: hidden;
    transition: none;
  }

  .profile-overlay.is-open {
    visibility: visible;
  }

  .profile-overlay__inner {
    display: flex;
    flex-direction: column;
    height: 100vh;
    height: 100dvh;
    padding: var(--space-2);
  }

  .profile-overlay__header {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-1) var(--space-2);
    flex-shrink: 0;
  }

  .profile-overlay__left,
  .profile-overlay__right {
    display: flex;
    align-items: center;
    gap: var(--space-1);
  }

  .profile-overlay__icon-btn {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-text);
    padding: var(--space-1);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .profile-overlay__icon-btn svg { display: block; }

  .profile-overlay__logo {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    text-decoration: none;
    display: flex;
    align-items: center;
  }

  .profile-overlay__logo-img {
    width: 200px;
    height: auto;
    display: block;
    filter: invert(1);
  }

  html[data-mode="onsite"] .profile-overlay__logo-img {
    filter: invert(0);
  }

  .profile-overlay__body {
    flex: 1;
    overflow-y: auto;
    -webkit-overflow-scrolling: touch;
    padding: 0 var(--space-4) var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  /* QR Ticket */
  .profile-overlay__ticket {
    padding: var(--space-3) 0;
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: var(--space-4);
  }

  .profile-overlay__qr {
    width: 120px;
    height: 120px;
    flex-shrink: 0;
    border: 1px solid color-mix(in srgb, var(--color-text) 10%, transparent);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .profile-overlay__qr .icon {
    font-size: 110px;
    color: #272523;
    opacity: 0.6;
  }

  html[data-mode="onsite"] .profile-overlay__qr {
    background: #ffffff;
  }

  .profile-overlay__ticket-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .profile-overlay__ticket-title {
    font-size: var(--type-sm);
    font-weight: var(--weight-medium);
    color: var(--color-text);
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .profile-overlay__ticket-code {
    font-size: var(--type-xs);
    font-family: monospace;
    opacity: 0.4;
    margin: 0;
    color: var(--color-text);
    word-break: break-all;
  }

  .profile-overlay__ticket-valid {
    font-size: var(--type-sm);
    color: var(--color-text);
    opacity: 0.7;
    margin: 0;
  }

  .profile-overlay__ticket-access {
    font-size: var(--type-sm);
    color: var(--color-text);
    opacity: 0.55;
    margin: 0;
  }

  /* Nav items */
  .profile-overlay__nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .profile-overlay__nav-item {
    border-bottom: 1px solid color-mix(in srgb, var(--color-text) 10%, transparent);
  }
  .profile-overlay__nav-item:first-child {
    border-top: 1px solid color-mix(in srgb, var(--color-text) 10%, transparent);
  }

  .profile-overlay__nav-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-4) var(--space-2);
    text-decoration: none;
    color: var(--color-text);
    font-size: var(--type-sm);
    font-weight: var(--weight-regular);
    opacity: 0.8;
    transition: opacity 0.2s ease;
  }
  .profile-overlay__nav-link:hover { opacity: 1; }

  .profile-overlay__nav-arrow {
    font-size: 18px;
    opacity: 0.4;
  }

  /* Action buttons */
  .profile-overlay__actions {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-top: auto;
  }

  .profile-overlay__member-btn {
    width: 100%;
    justify-content: center;
    gap: var(--space-2);
  }

  .profile-overlay__greeting {
    font-size: var(--type-xs);
    color: var(--color-text);
    opacity: 0.45;
    margin: 0 0 calc(-1 * var(--space-4));
    text-align: center;
  }

  .profile-overlay__logout {
    width: 100%;
    justify-content: center;
    background: transparent;
    border: 1px solid color-mix(in srgb, var(--color-text) 30%, transparent);
    color: var(--color-text);
  }
  .profile-overlay__logout:hover {
    border-color: var(--color-text);
  }

  @media (min-width: 768px) {
    .profile-overlay__header {
      width: 500px;
      margin: 0 auto;
      padding-left: var(--space-2);
      padding-right: var(--space-2);
    }
    .profile-overlay__body {
      max-width: 500px;
      margin: 0 auto;
      width: 100%;
    }
  }
</style>

<script>
  import { gsap } from 'gsap';

  function initProfileOverlay() {
    const overlay = document.getElementById('profile-overlay');
    if (!overlay || overlay.dataset.initialized === 'true') return;
    overlay.dataset.initialized = 'true';

    const closeBtns = overlay.querySelectorAll('[data-profile-close-x]');
    const hamburgerBtn = overlay.querySelector('[data-action="hamburger"]');
    const searchBtn = overlay.querySelector('[data-action="search"]');
    const hoursBtn = overlay.querySelector('[data-action="open-hours"]');

    hamburgerBtn?.addEventListener('click', () => {
      close();
      setTimeout(() => {
        (window as any).__hamburgerOverlay?.open?.(true) ||
          document.querySelector('.navbar [data-action="hamburger"]')?.dispatchEvent(new MouseEvent('click', { bubbles: true }));
      }, 300);
    });

    searchBtn?.addEventListener('click', () => {
      close();
      setTimeout(() => {
        (window as any).__searchOverlay?.open?.(true) ||
          document.querySelector('.navbar [data-action="search"]')?.dispatchEvent(new MouseEvent('click', { bubbles: true }));
      }, 300);
    });

    hoursBtn?.addEventListener('click', () => {
      close();
      setTimeout(() => {
        (window as any).__hoursOverlay?.open?.(true) ||
          document.querySelector('.navbar [data-action="hours"]')?.dispatchEvent(new MouseEvent('click', { bubbles: true }));
      }, 300);
    });

    const logoutBtn = overlay.querySelector('[data-profile-logout]');

    function open() {
      if (!overlay) return;
      // Hide the profile button so the close-X replaces it visually
      const profileBtn = document.getElementById('nav-profile-btn');
      if (profileBtn) profileBtn.style.display = 'none';

      overlay.classList.add('is-open');
      overlay.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      (window as any).__lenis?.stop?.();
      gsap.to(overlay, { opacity: 1, duration: 0.3, ease: 'power2.out' });

      const navItems = overlay.querySelectorAll('.profile-overlay__ticket, .profile-overlay__greeting, .profile-overlay__nav-item, .profile-overlay__actions');
      if (navItems.length) {
        gsap.set(navItems, { opacity: 0, x: -20 });
        gsap.to(navItems, {
          opacity: 1,
          x: 0,
          duration: 0.4,
          ease: 'power3.out',
          stagger: 0.06,
          delay: 0.15,
        });
      }
    }

    function close() {
      if (!overlay) return;
      gsap.to(overlay, {
        opacity: 0,
        duration: 0.25,
        ease: 'power2.in',
        onComplete: () => {
          overlay.classList.remove('is-open');
          overlay.setAttribute('aria-hidden', 'true');
          document.body.style.overflow = '';
          (window as any).__lenis?.start?.();
          // Restore the profile button if user is still logged in
          const profileBtn = document.getElementById('nav-profile-btn');
          if (profileBtn && localStorage.getItem('kunsthaus-demo-user')) {
            profileBtn.style.display = 'flex';
          }
        },
      });
    }

    closeBtns.forEach(btn => btn.addEventListener('click', close));

    logoutBtn?.addEventListener('click', () => {
      localStorage.removeItem('kunsthaus-demo-user');
      (window as any).__demoUser = null;
      window.dispatchEvent(new CustomEvent('kunsthaus:logout'));
      close();
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && overlay?.classList.contains('is-open')) {
        close();
      }
    });

    (window as any).__profileOverlay = { open, close };
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initProfileOverlay);
  } else {
    initProfileOverlay();
  }
  document.addEventListener('astro:page-load', () => {
    const overlay = document.getElementById('profile-overlay');
    if (overlay) overlay.dataset.initialized = '';
    initProfileOverlay();
  });
</script>
