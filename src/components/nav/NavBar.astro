---
// NavBar.astro -- D-07 through D-13: Responsive floating navigation bar
// Velocity-aware scroll behavior on desktop, simplified always-visible bar on mobile

import LanguageSwitcher from './LanguageSwitcher.astro';

interface Props {
  navItems: Array<{ id: string; label: { de: string; en: string }; href: string }>;
  lang: 'en' | 'de';
  searchLabel: string;
  menuLabel: string;
}

const { navItems, lang, searchLabel, menuLabel } = Astro.props;
---

{/* Status bar scrim — fades content before it reaches iOS status bar */}
<div class="navbar-scrim" aria-hidden="true"></div>

<header class="navbar" id="navbar">
  <div class="navbar__inner">
    {/* Left: Search + Clock */}
    <div class="navbar__left">
      <button
        class="navbar__icon-btn touch-target touch-pulse"
        aria-label={searchLabel}
        data-action="search"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="8"/>
          <line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
      </button>
      <button class="navbar__icon-btn touch-target touch-pulse" aria-label="Opening hours" data-action="hours">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="10"/>
          <polyline points="12 6 12 12 16 14"/>
        </svg>
      </button>
    </div>

    {/* Right: Hamburger */}
    <div class="navbar__right">
      <button
        class="navbar__icon-btn touch-target touch-pulse"
        aria-label={menuLabel}
        data-action="hamburger"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>
    </div>
  </div>

  {/* Bar logo — visible when bar is showing */}
  <a href="/" class="navbar__logo-inner">
    <img src="/Kunsthaus/images/logo.png" alt="Kunsthaus Zürich" class="navbar__logo-inner-img" />
  </a>

  {/* Persistent logo — stays when bar fades */}
  <a href="/" class="navbar__logo">
    <img src="/Kunsthaus/images/logo.png" alt="Kunsthaus Zürich" class="navbar__logo-img" />
  </a>
</header>

{/* Migrated search icon -- visible when nav is hidden on scroll */}
<button
  class="navbar__search-migrated touch-target touch-pulse"
  id="search-migrated"
  aria-label={searchLabel}
  data-action="search"
>
  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="11" cy="11" r="8"/>
    <line x1="21" y1="21" x2="16.65" y2="16.65"/>
  </svg>
</button>

<style>
  /* Status bar scrim — always visible, fades content under navbar */
  .navbar-scrim {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: calc(env(safe-area-inset-top, 0px) + 100px);
    min-height: 110px;
    z-index: 59;
    background: linear-gradient(to bottom, var(--color-surface) 30%, color-mix(in srgb, var(--color-surface) 50%, transparent) 60%, transparent 100%);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    -webkit-mask-image: linear-gradient(to bottom, black 40%, transparent 100%);
    mask-image: linear-gradient(to bottom, black 40%, transparent 100%);
    pointer-events: none;
  }

  html[data-mode="onsite"] .navbar-scrim {
    background: linear-gradient(to bottom, #272523 30%, color-mix(in srgb, #272523 50%, transparent) 60%, transparent 100%);
  }

  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 60;
    padding: var(--space-2);
    pointer-events: none;
  }

  /* Bar logo — visible when bar is showing, hidden when faded */
  .navbar__logo-inner {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    display: flex;
    align-items: center;
    text-decoration: none;
    z-index: 2;
    pointer-events: auto;
    transition: opacity 0.6s ease;
  }

  .navbar--faded .navbar__logo-inner {
    opacity: 0;
    pointer-events: none;
  }

  .navbar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    background-color: #ede7de;
    background-image: url(/Kunsthaus/textures/concrete-wall.png);
    background-repeat: repeat;
    background-blend-mode: multiply;
    padding: var(--space-1) var(--space-2);
    pointer-events: auto;
    position: relative;
    overflow: hidden;
    border-radius: var(--btn-radius);
    transition: opacity 0.6s ease;
  }

  /* Faded state: bar disappears, persistent logo stays */
  .navbar--faded .navbar__inner {
    opacity: 0;
    pointer-events: none;
  }

  /* Bevel */
  .navbar__inner::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(to bottom, #fcfcfb, transparent 4px),
      linear-gradient(to left, #fcfcfb, transparent 4px),
      linear-gradient(to top, #e4d9cc, transparent 4px),
      linear-gradient(to right, #e4d9cc, transparent 4px);
    pointer-events: none;
    z-index: 1;
  }

  /* Left group: search + clock */
  .navbar__left {
    display: flex;
    align-items: center;
    gap: var(--space-1);
  }

  /* Right group: hamburger */
  .navbar__right {
    display: flex;
    align-items: center;
  }

  /* Icon buttons — shared style */
  .navbar__icon-btn {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-text);
    padding: var(--space-1);
    display: flex;
    align-items: center;
    justify-content: center;
  }


  .navbar__logo-inner-img {
    width: 200px;
    height: auto;
    display: block;
    filter: invert(1);
  }

  /* Persistent logo — hidden when bar visible, shows when faded */
  .navbar__logo {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    text-decoration: none;
    display: flex;
    align-items: center;
    z-index: 2;
    pointer-events: auto;
    opacity: 0;
  }

  .navbar--faded .navbar__logo {
    opacity: 1;
  }

  .navbar__logo-img {
    width: 200px;
    height: auto;
    display: block;
    filter: invert(1);
    transition: filter 0.25s ease;
  }

  /* When faded: persistent logo adapts */
  .navbar--faded .navbar__logo-img {
    filter: invert(1);
  }

  .navbar--faded .navbar__logo-img.on-dark {
    filter: none;
  }

  /* Onsite/dark mode: dark textured nav like footer */
  html[data-mode="onsite"] .navbar__inner {
    background-color: #272523;
    background-image: url(/Kunsthaus/textures/dark-wall.png);
    background-blend-mode: normal;
  }

  html[data-mode="onsite"] .navbar__inner::before {
    background:
      linear-gradient(to bottom, #3a3835, transparent 4px),
      linear-gradient(to left, #3a3835, transparent 4px),
      linear-gradient(to top, #1a1816, transparent 4px),
      linear-gradient(to right, #1a1816, transparent 4px);
  }

  html[data-mode="onsite"] .navbar__logo-img,
  html[data-mode="onsite"] .navbar__logo-inner-img {
    filter: none;
  }

  /* Tablet+: fixed-width centered bar */
  @media (min-width: 768px) {
    .navbar__inner {
      width: 500px;
      margin: 0 auto;
    }
  }

  /* Mobile/tablet: simplified bar */
  .navbar__search-migrated {
    display: none;
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initNavBar() {
    const navbar = document.getElementById('navbar');
    const logoIsland = document.getElementById('logo-island');
    const searchMigrated = document.getElementById('search-migrated');
    const isMobile = window.matchMedia('(max-width: 1200px)').matches;

    if (!navbar) return;

    // Search button handlers
    document.querySelectorAll('[data-action="search"]').forEach(btn => {
      btn.addEventListener('click', () => {
        (window as any).__searchOverlay?.open();
      });
    });

    // Hamburger button handler
    document.querySelectorAll('[data-action="hamburger"]').forEach(btn => {
      btn.addEventListener('click', () => {
        (window as any).__hamburgerOverlay?.open();
      });
    });

    // Hours button handler
    document.querySelectorAll('[data-action="hours"]').forEach(btn => {
      btn.addEventListener('click', () => {
        (window as any).__hoursOverlay?.open();
      });
    });

    // Skip scroll-driven behaviors if reduced motion is active
    const reduceMotion =
      window.matchMedia('(prefers-reduced-motion: reduce)').matches ||
      document.documentElement.classList.contains('reduce-motion');

    if (reduceMotion) return;

    // Fade navbar on scroll down, restore on scroll up
    let lastScrollY = window.scrollY;
    let ticking = false;

    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        const currentY = window.scrollY;
        if (currentY > lastScrollY && currentY > 80) {
          navbar.classList.add('navbar--faded');
        } else {
          navbar.classList.remove('navbar--faded');
        }
        lastScrollY = currentY;
        ticking = false;
      });
    };

    window.addEventListener('scroll', onScroll, { passive: true });

    // Show navbar when mouse enters the top area (even when faded)
    const onMouseMove = (e: MouseEvent) => {
      const navHeight = navbar.offsetHeight + 20;
      if (e.clientY <= navHeight) {
        navbar.classList.remove('navbar--faded');
      } else if (window.scrollY > 80) {
        navbar.classList.add('navbar--faded');
      }
    };

    window.addEventListener('mousemove', onMouseMove, { passive: true });

    // Detect background behind logo and toggle light/dark logo
    const logoImg = navbar.querySelector('.navbar__logo-img') as HTMLElement;
    const logoLink = navbar.querySelector('.navbar__logo') as HTMLElement;

    function getLuminance(r: number, g: number, b: number) {
      const [rs, gs, bs] = [r, g, b].map(c => {
        c = c / 255;
        return c <= 0.03928 ? c / 12.92 : Math.pow((c + 0.055) / 1.055, 2.4);
      });
      return 0.2126 * rs + 0.7152 * gs + 0.0722 * bs;
    }

    function checkLogoBg() {
      if (!logoImg || !logoLink || !navbar.classList.contains('navbar--faded')) return;

      const logoRect = logoLink.getBoundingClientRect();
      const cx = logoRect.left + logoRect.width / 2;
      const cy = logoRect.top + logoRect.height / 2;

      // Temporarily hide logo to sample what's behind it
      logoLink.style.visibility = 'hidden';
      const el = document.elementFromPoint(cx, cy) as HTMLElement;
      logoLink.style.visibility = '';

      if (!el) return;

      // Walk up to find an element with a background color
      let target: HTMLElement | null = el;
      let bgColor = '';
      while (target && target !== document.documentElement) {
        const bg = getComputedStyle(target).backgroundColor;
        if (bg && bg !== 'rgba(0, 0, 0, 0)' && bg !== 'transparent') {
          bgColor = bg;
          break;
        }
        target = target.parentElement;
      }

      if (!bgColor) return;

      // Parse rgb/rgba
      const match = bgColor.match(/(\d+),\s*(\d+),\s*(\d+)/);
      if (!match) return;

      const lum = getLuminance(+match[1], +match[2], +match[3]);
      // Dark background (luminance < 0.4) → white logo
      if (lum < 0.4) {
        logoImg.classList.add('on-dark');
      } else {
        logoImg.classList.remove('on-dark');
      }
    }

    window.addEventListener('scroll', checkLogoBg, { passive: true });
    checkLogoBg();
  }

  document.addEventListener('DOMContentLoaded', initNavBar);
</script>
