---
// LogoIsland.astro -- D-10: Persistent floating logo when nav dissolves on scroll
---

<div class="logo-island" id="logo-island" aria-hidden="true">
  <a href="/" class="logo-island__link" tabindex="-1">
    <img src="/Kunsthaus/images/logo.png" alt="Kunsthaus Zürich" class="logo-island__img" />
  </a>
</div>

<style>
  .logo-island {
    position: fixed;
    top: var(--space-4);
    left: 50%;
    transform: translateX(-50%);
    z-index: 65;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .logo-island.is-visible {
    opacity: 1;
    pointer-events: auto;
  }

  .logo-island.is-visible .logo-island__link {
    tabindex: 0;
  }

  .logo-island__link {
    text-decoration: none;
    padding: var(--space-2) var(--space-4);
    display: block;
  }

  .logo-island__img {
    width: 200px;
    height: auto;
    display: block;
    mix-blend-mode: exclusion;
  }

  /* Desktop only */
  @media (max-width: 1200px) {
    .logo-island {
      display: none;
    }
  }
</style>
