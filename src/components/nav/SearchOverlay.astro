---
// SearchOverlay.astro -- D-11: Visual search shell overlay (no functional search)

interface Props {
  searchLabel: string;
}

const { searchLabel } = Astro.props;

// Hardcoded suggestions per D-11
const suggestions = [
  { label: 'Current Exhibitions', href: '#' },
  { label: 'Opening Hours', href: '#' },
  { label: 'Tickets', href: '#' },
  { label: 'Kerry James Marshall', href: '#' },
  { label: 'Membership', href: '#' },
  { label: 'Getting Here', href: '#' },
];
---

<div class="search-overlay" id="search-overlay" aria-hidden="true">
  <div class="search-overlay__inner">
    {/* Header: close (where search was) + clock left, logo center, hamburger right */}
    <div class="search-overlay__header">
      <div class="search-overlay__left">
        <button class="search-overlay__close touch-target" aria-label="Close search">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <line x1="18" y1="6" x2="6" y2="18"/>
            <line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
        <button class="search-overlay__hours-btn touch-target" aria-label="Opening hours" data-action="open-hours">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12 6 12 12 16 14"/>
          </svg>
        </button>
      </div>
      <a href="/" class="search-overlay__logo">
        <img src="/Kunsthaus/images/logo.png" alt="Kunsthaus Zürich" class="search-overlay__logo-img" />
      </a>
      <button class="search-overlay__hamburger touch-target" aria-label="Open menu" data-action="open-hamburger">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>
    </div>

    {/* Body: search field + suggestions */}
    <div class="search-overlay__body">
      {/* Search field — pill with go button */}
      <div class="search-overlay__field">
        <label for="search-input" class="sr-only">{searchLabel}</label>
        <div class="search-overlay__input-wrap">
          <input
            type="text"
            id="search-input"
            class="search-overlay__input"
            autocomplete="off"
          />
          <span class="search-overlay__placeholder" id="search-placeholder" aria-hidden="true">
            Search for "<span class="search-overlay__rotating-text" id="search-rotating">exhibitions</span>"
          </span>
        </div>
        <button class="search-overlay__go" type="button" aria-label="Search">
          <span class="search-overlay__go-label">{searchLabel}</span>
          <span class="icon">search</span>
        </button>
      </div>

      {/* Suggestions */}
      <nav class="search-overlay__suggestions" aria-label="Suggested searches">
        <h2 class="search-overlay__heading sub-heading">Popular Searches</h2>
        <ul>
          {suggestions.map((s, i) => (
            <li class="search-overlay__item" data-search-item={i}>
              <a href={s.href} class="search-overlay__item-link btn-link touch-pulse">
                <span>{s.label}</span>
                <span class="icon">arrow_forward</span>
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>
  </div>
</div>

<style>
  .search-overlay {
    position: fixed;
    inset: 0;
    z-index: 80;
    background: color-mix(in srgb, var(--color-surface) 85%, transparent);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    opacity: 0;
    visibility: hidden;
  }

  .search-overlay.is-open {
    visibility: visible;
  }

  .search-overlay__inner {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    padding: var(--space-2);
  }

  /* Header: matches navbar exactly */
  .search-overlay__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-1) var(--space-2);
  }

  .search-overlay__left {
    display: flex;
    align-items: center;
    gap: var(--space-1);
  }

  .search-overlay__hamburger,
  .search-overlay__hours-btn {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-text);
    padding: var(--space-2);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .search-overlay__logo {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    text-decoration: none;
    display: flex;
    align-items: center;
  }

  .search-overlay__logo-img {
    width: 200px;
    height: auto;
    display: block;
    filter: invert(1);
  }

  html[data-mode="onsite"] .search-overlay__logo-img {
    filter: none;
  }

  /* Mobile: shrink logo to match navbar */
  @media (max-width: 767px) {
    .search-overlay__logo-img {
      width: 160px;
    }
  }

  .search-overlay__close {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-text);
    padding: var(--space-2);
  }

  /* Body */
  .search-overlay__body {
    padding: var(--space-8) var(--space-4) 0;
  }

  /* Search field — fully round pill */
  .search-overlay__field {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    border: 1px solid color-mix(in srgb, var(--color-text) 15%, transparent);
    border-radius: 999px;
    padding: 4px 4px 4px var(--space-6);
    background: rgba(255, 255, 255, 0.92);
  }

  /* Dark mode: near-white inverted */
  html[data-mode="onsite"] .search-overlay__field {
    background: rgba(255, 255, 255, 0.08);
    border-color: color-mix(in srgb, var(--color-text) 20%, transparent);
  }

  .search-overlay__go {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    border-radius: 999px;
    padding: 12px 20px;
    border: none;
    cursor: pointer;
    background: color-mix(in srgb, #7d7042 75%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    color: #faf6ee;
    transition: background 0.3s ease;
  }

  .search-overlay__go .icon {
    font-size: 22px;
  }

  .search-overlay__go:hover {
    background: color-mix(in srgb, #5f5530 85%, transparent);
  }

  .search-overlay__input-wrap {
    position: relative;
    flex: 1;
    min-width: 0;
  }

  .search-overlay__input {
    width: 100%;
    background: none;
    border: none;
    padding: 0;
    font-size: var(--type-lg);
    font-weight: var(--weight-light);
    color: var(--color-text);
    outline: none;
    font-family: inherit;
    position: relative;
    z-index: 1;
  }

  .search-overlay__placeholder {
    position: absolute;
    top: 50%;
    left: 0;
    transform: translateY(-50%);
    font-size: var(--type-lg);
    font-weight: var(--weight-light);
    color: #8a8578;
    pointer-events: none;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100%;
    z-index: 0;
  }

  .search-overlay__rotating-text {
    display: inline-block;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  @media (max-width: 767px) {
    /* iOS Safari auto-zooms inputs whose font-size is < 16px on focus.
       Lock to 16px to prevent the zoom-in jank that crops the header. */
    .search-overlay__input {
      font-size: 16px;
    }

    .search-overlay__placeholder {
      font-size: 16px;
      color: #757068;
    }
  }

  .search-overlay__rotating-text.is-exiting {
    opacity: 0;
    transform: translateY(-8px);
  }

  .search-overlay__rotating-text.is-entering {
    opacity: 0;
    transform: translateY(8px);
  }

  /* Suggestions */
  .search-overlay__heading {
    margin-top: var(--space-8);
    margin-bottom: var(--space-4);
    padding-left: var(--space-4);
  }

  .search-overlay__suggestions ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .search-overlay__item {
    border-bottom: 1px solid color-mix(in srgb, var(--color-text) 10%, transparent);
  }

  .search-overlay__item:first-child {
    border-top: 1px solid color-mix(in srgb, var(--color-text) 10%, transparent);
  }

  .search-overlay__item-link {
    padding: var(--space-3) 0;
    padding-left: var(--space-4);
  }

  /* Go button label — hidden on smallest breakpoint */
  .search-overlay__go-label {
    display: inline;
    font-size: var(--type-sm);
    font-family: inherit;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  @media (max-width: 767px) {
    .search-overlay__go-label {
      display: none;
    }

    .search-overlay__go {
      width: 44px;
      height: 44px;
      padding: 0;
    }
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  /* Tablet+: match navbar 500px centered layout */
  @media (min-width: 768px) {
    .search-overlay__header {
      width: 500px;
      margin: 0 auto;
      padding-left: var(--space-2);
      padding-right: var(--space-2);
    }

    .search-overlay__header svg {
      width: 18px;
      height: 18px;
    }

    .search-overlay__body {
      width: 500px;
      margin: 0 auto;
      padding-left: var(--space-2);
      padding-right: var(--space-2);
    }

    .search-overlay__heading {
      padding-left: 0;
    }

    .search-overlay__item-link {
      padding-left: 0;
      padding-right: 0;
    }
  }

</style>

<script>
  import { gsap } from 'gsap';

  // Cleanup for document-level listeners attached on previous init.
  // View Transitions navigations re-run this function; without cleanup
  // keydown handlers accumulate and reference orphan overlay elements.
  let searchOverlayCleanup: (() => void) | null = null;

  function initSearchOverlay() {
    searchOverlayCleanup?.();
    searchOverlayCleanup = null;

    const overlay = document.getElementById('search-overlay');
    const closeBtn = overlay?.querySelector('.search-overlay__close');
    const input = overlay?.querySelector('.search-overlay__input') as HTMLInputElement;
    const searchItems = overlay?.querySelectorAll('.search-overlay__item');
    const field = overlay?.querySelector('.search-overlay__field');
    const heading = overlay?.querySelector('.search-overlay__heading');

    const inner = overlay?.querySelector('.search-overlay__inner') as HTMLElement;

    function open(swap = false) {
      if (!overlay) return;
      overlay.classList.add('is-open');
      overlay.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      (window as any).__lenis?.stop?.();

      if (!swap) {
        gsap.to(overlay, { opacity: 1, duration: 0.3, ease: 'power2.out' });
      } else {
        gsap.set(overlay, { opacity: 1 });
      }

      const tl = gsap.timeline();
      if (field) {
        gsap.set(field, { opacity: 0, y: -10 });
        tl.to(field, { opacity: 1, y: 0, duration: 0.3, ease: 'power3.out' }, swap ? 0 : 0.15);
      }
      if (heading) {
        gsap.set(heading, { opacity: 0 });
        tl.to(heading, { opacity: 1, duration: 0.3, ease: 'power2.out' }, swap ? 0.1 : 0.25);
      }
      if (searchItems?.length) {
        gsap.set(searchItems, { opacity: 0, x: -20 });
        tl.to(searchItems, {
          opacity: 1, x: 0, duration: 0.4, ease: 'power3.out', stagger: 0.04,
        }, swap ? 0.1 : 0.3);
      }

      tl.call(() => input?.focus());
    }

    function close(swap = false) {
      if (!overlay) return;
      if (swap) {
        gsap.to(inner, {
          opacity: 0,
          duration: 0.2,
          ease: 'power2.in',
          onComplete: () => {
            overlay.classList.remove('is-open');
            overlay.setAttribute('aria-hidden', 'true');
            gsap.set(inner, { opacity: 1 });
          },
        });
      } else {
        gsap.to(overlay, {
          opacity: 0,
          duration: 0.25,
          ease: 'power2.in',
          onComplete: () => {
            overlay.classList.remove('is-open');
            overlay.setAttribute('aria-hidden', 'true');
            document.body.style.overflow = '';
            (window as any).__lenis?.start?.();
          },
        });
      }
    }

    // Hamburger button ref (listeners added below after wrapping)
    const hamburgerBtn = overlay?.querySelector('.search-overlay__hamburger');

    // Close on click on empty space (backdrop or below content)
    overlay?.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (target === overlay) {
        wrappedClose(false);
        return;
      }
      // Close if clicking empty area inside inner (below suggestions)
      const header = overlay?.querySelector('.search-overlay__header');
      const body = overlay?.querySelector('.search-overlay__body');
      if (target === inner || (target !== header && target !== body && !header?.contains(target) && !body?.contains(target))) {
        wrappedClose(false);
      }
    });

    // Close on Escape
    const onKeyDown = (e: KeyboardEvent) => {
      if (e.key === 'Escape' && overlay?.classList.contains('is-open')) {
        close();
      }
    };
    document.addEventListener('keydown', onKeyDown);
    searchOverlayCleanup = () => {
      document.removeEventListener('keydown', onKeyDown);
    };

    // Rotating placeholder text
    const placeholder = document.getElementById('search-placeholder');
    const rotatingEl = document.getElementById('search-rotating');
    const phrases = ['exhibitions', 'upcoming events', 'member benefits', 'a map of the Kunsthaus', 'something to eat or drink', 'educational resources', 'family/holiday activities', 'a specific artist'];
    let phraseIndex = 0;
    let rotateInterval: ReturnType<typeof setInterval> | null = null;

    function rotatePlaceholder() {
      if (!rotatingEl) return;
      // Exit current
      rotatingEl.classList.add('is-exiting');
      setTimeout(() => {
        phraseIndex = (phraseIndex + 1) % phrases.length;
        rotatingEl.textContent = phrases[phraseIndex];
        rotatingEl.classList.remove('is-exiting');
        rotatingEl.classList.add('is-entering');
        requestAnimationFrame(() => {
          setTimeout(() => {
            rotatingEl.classList.remove('is-entering');
          }, 20);
        });
      }, 300);
    }

    function startRotation() {
      if (rotateInterval) return;
      rotateInterval = setInterval(rotatePlaceholder, 2500);
    }

    function stopRotation() {
      if (rotateInterval) {
        clearInterval(rotateInterval);
        rotateInterval = null;
      }
    }

    // Hide placeholder when user types, show when empty
    if (input && placeholder) {
      input.addEventListener('input', () => {
        if (input.value.length > 0) {
          placeholder.style.display = 'none';
          stopRotation();
        } else {
          placeholder.style.display = '';
          startRotation();
        }
      });
    }

    // Start rotation when overlay opens, stop when it closes
    const origOpen = open;
    const wrappedOpen = (swap = false) => {
      origOpen(swap);
      if (input) input.value = '';
      if (placeholder) placeholder.style.display = '';
      if (rotatingEl) {
        phraseIndex = 0;
        rotatingEl.textContent = phrases[0];
        rotatingEl.classList.remove('is-exiting', 'is-entering');
      }
      startRotation();
    };

    const origClose = close;
    const wrappedClose = (swap = false) => {
      stopRotation();
      origClose(swap);
    };

    closeBtn?.addEventListener('click', () => wrappedClose(false));
    hamburgerBtn?.addEventListener('click', () => {
      (window as any).__hamburgerOverlay?.open(true);
      wrappedClose(true);
    });

    // Hours button — swap to hours overlay
    overlay?.querySelector('[data-action="open-hours"]')?.addEventListener('click', () => {
      (window as any).__hoursOverlay?.open(true);
      wrappedClose(true);
    });

    // Expose open/close for NavBar buttons
    (window as any).__searchOverlay = { open: wrappedOpen, close: wrappedClose };
  }

  // Run on first paint and after every Astro View Transitions navigation.
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSearchOverlay);
  } else {
    initSearchOverlay();
  }
  document.addEventListener('astro:page-load', initSearchOverlay);
</script>
