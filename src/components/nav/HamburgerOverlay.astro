---
// HamburgerOverlay.astro -- D-13: Full-screen mobile menu overlay

interface Props {
  navItems: Array<{ id: string; label: { de: string; en: string }; href: string }>;
  lang: 'en' | 'de';
  searchLabel: string;
}

const { navItems, lang, searchLabel } = Astro.props;
const languages = [
  { code: 'en', label: 'English' },
  { code: 'de', label: 'Deutsch' },
  { code: 'fr', label: 'Fran\u00e7ais' },
];

// Phase 03-01: mode state = URL. Server-render the active segment from pathname.
// Strip the configured base (/Kunsthaus) so the check works on GitHub Pages.
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const pathWithoutBase = Astro.url.pathname.startsWith(base)
  ? Astro.url.pathname.slice(base.length)
  : Astro.url.pathname;
const isOnsite = pathWithoutBase.startsWith('/onsite');
const planningHref = `${base}/`;
const onsiteHref = `${base}/onsite`;
---

<div class="hamburger-overlay" id="hamburger-overlay" aria-hidden="true" role="dialog" aria-label="Navigation menu">
  <div class="hamburger-overlay__inner">
    {/* Top bar: mirrors nav bar exactly — same padding, same icon positions */}
    <div class="hamburger-overlay__header">
      <div class="hamburger-overlay__left">
        <button class="hamburger-overlay__search-btn touch-target" aria-label={searchLabel}>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="11" cy="11" r="8"/>
            <line x1="21" y1="21" x2="16.65" y2="16.65"/>
          </svg>
        </button>
        <button class="hamburger-overlay__hours-btn touch-target" aria-label="Opening hours" data-action="open-hours">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/>
            <polyline points="12 6 12 12 16 14"/>
          </svg>
        </button>
      </div>
      <a href={`${base}/`} class="hamburger-overlay__logo">
        <img src="/Kunsthaus/images/logo.png" alt="Kunsthaus Zürich" class="hamburger-overlay__logo-img" />
      </a>
      <div class="hamburger-overlay__right">
        <button class="hamburger-overlay__profile-btn touch-target" aria-label="Profile" data-action="open-profile" style="display: none;">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="8" r="4"/>
            <path d="M20 21c0-3.87-3.58-7-8-7s-8 3.13-8 7"/>
          </svg>
        </button>
        <button class="hamburger-overlay__close touch-target" aria-label="Close menu">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
            <line x1="18" y1="6" x2="6" y2="18"/>
            <line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
      </div>
    </div>

    {/* Navigation links + secondary + language */}
    <div class="hamburger-overlay__body" data-lenis-prevent>
      {/* Mode toggle — top of the menu, above the nav items.
          Phase 03-01: <a href> navigation, active state from pathname. */}
      <div class="hamburger-overlay__mode" role="radiogroup" aria-label="Site mode" data-mode-toggle>
        <span class="hamburger-overlay__mode-pill"></span>
        <a
          class:list={['hamburger-overlay__mode-btn', { 'is-active': !isOnsite }]}
          href={planningHref}
          data-mode-segment="planning"
          role="radio"
          aria-checked={!isOnsite}
        >
          <span data-i18n-de="Besuch planen" data-i18n-en="Plan a Visit">{lang === 'de' ? 'Besuch planen' : 'Plan a Visit'}</span>
        </a>
        <a
          class:list={['hamburger-overlay__mode-btn', { 'is-active': isOnsite }]}
          href={onsiteHref}
          data-mode-segment="onsite"
          role="radio"
          aria-checked={isOnsite}
        >
          <span data-i18n-de="Im Kunsthaus" data-i18n-en="At Kunsthaus">{lang === 'de' ? 'Im Kunsthaus' : 'At Kunsthaus'}</span>
        </a>
      </div>

      <nav class="hamburger-overlay__nav" aria-label="Main navigation">
        <ul>
          {navItems.map((item, i) => (
            <li class="hamburger-overlay__item" data-nav-item={i}>
              <a href={item.href} class="hamburger-overlay__link">
                <span data-i18n-de={item.label.de} data-i18n-en={item.label.en}>{item.label[lang]}</span>
                <span class="icon hamburger-overlay__link-arrow">arrow_forward</span>
              </a>
            </li>
          ))}
        </ul>
      </nav>

      {/* Secondary navigation */}
      <nav class="hamburger-overlay__secondary" aria-label="Secondary navigation">
        <ul>
          <li class="hamburger-overlay__secondary-item">
            <a href={`${base}/membership`} class="hamburger-overlay__secondary-link">
              <span data-i18n-de="Mitglied werden" data-i18n-en="Become a member">{lang === 'de' ? 'Mitglied werden' : 'Become a member'}</span>
              <span class="icon hamburger-overlay__secondary-arrow">north_east</span>
            </a>
          </li>
          <li class="hamburger-overlay__secondary-item" data-login-item>
            <a href={`${base}/login`} class="hamburger-overlay__secondary-link" data-login-link>
              <span data-login-text data-i18n-de="Anmelden" data-i18n-en="Log in">{lang === 'de' ? 'Anmelden' : 'Log in'}</span>
              <span class="icon hamburger-overlay__secondary-arrow">north_east</span>
            </a>
          </li>
          <li class="hamburger-overlay__secondary-item">
            <a href={`${base}/shop`} class="hamburger-overlay__secondary-link">
              <span data-i18n-de="Shops & Gastronomie" data-i18n-en="Shops & Gastronomy">{lang === 'de' ? 'Shops & Gastronomie' : 'Shops & Gastronomy'}</span>
              <span class="icon hamburger-overlay__secondary-arrow">north_east</span>
            </a>
          </li>
          <li class="hamburger-overlay__secondary-item">
            <a href="https://visitorguide.kunsthaus.ch/" class="hamburger-overlay__secondary-link" target="_blank" rel="noopener">
              <span data-i18n-de="Besucherführer" data-i18n-en="Visitor Guide">{lang === 'de' ? 'Besucherführer' : 'Visitor Guide'}</span>
              <span class="icon hamburger-overlay__secondary-arrow">north_east</span>
            </a>
          </li>
          <li class="hamburger-overlay__secondary-item">
            <a href={`${base}/press`} class="hamburger-overlay__secondary-link">
              <span data-i18n-de="Presse" data-i18n-en="Press">{lang === 'de' ? 'Presse' : 'Press'}</span>
              <span class="icon hamburger-overlay__secondary-arrow">north_east</span>
            </a>
          </li>
        </ul>
      </nav>

      <div class="hamburger-overlay__spacer"></div>

      <div class="hamburger-overlay__lang" role="group" aria-label="Language selection" data-lang-toggle>
        <span class="hamburger-overlay__lang-pill"></span>
        {languages.map(l => (
          <button
            class:list={[
              'hamburger-overlay__lang-btn',
              { 'is-active': l.code === lang },
              { 'hamburger-overlay__lang-btn--disabled': l.code === 'fr' }
            ]}
            data-lang={l.code}
            {...(l.code === 'fr' ? { disabled: true, title: 'Coming soon' } : {})}
          >
            {l.label}
          </button>
        ))}
      </div>
    </div>
  </div>
</div>

<style>
  .hamburger-overlay {
    position: fixed;
    inset: 0;
    z-index: 80;
    background: color-mix(in srgb, var(--color-surface) 85%, transparent);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    opacity: 0;
    visibility: hidden;
    transition: none;
  }

  .hamburger-overlay.is-open {
    visibility: visible;
  }

  .hamburger-overlay__inner {
    display: flex;
    flex-direction: column;
    height: 100vh;
    height: 100dvh;
    padding: var(--space-2);
  }

  /* Header: matches navbar exactly, never scrolls */
  .hamburger-overlay__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-1) var(--space-2);
    flex-shrink: 0;
  }

  .hamburger-overlay__left {
    display: flex;
    align-items: center;
    gap: var(--space-1);
  }

  .hamburger-overlay__search-btn,
  .hamburger-overlay__hours-btn {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-text);
    padding: var(--space-2);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hamburger-overlay__logo {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    text-decoration: none;
    display: flex;
    align-items: center;
  }

  .hamburger-overlay__logo-img {
    width: 200px;
    height: auto;
    display: block;
    filter: invert(1);
  }

  html[data-mode="onsite"] .hamburger-overlay__logo-img {
    filter: none;
  }

  /* Mobile: shrink logo to match navbar */
  @media (max-width: 767px) {
    .hamburger-overlay__logo-img {
      width: 160px;
    }
  }

  .hamburger-overlay__right {
    display: flex;
    align-items: center;
    gap: var(--space-1);
  }

  .hamburger-overlay__profile-btn,
  .hamburger-overlay__close {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-text);
    padding: var(--space-2);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .hamburger-overlay__profile-btn svg,
  .hamburger-overlay__close svg { display: block; }

  /* Body: nav + secondary + language — scrolls when viewport is short */
  .hamburger-overlay__body {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-height: 0;
    overflow-y: auto;
    padding: var(--space-6) var(--space-4) var(--space-6);
    -webkit-overflow-scrolling: touch;
  }

  .hamburger-overlay__spacer {
    flex: 1;
  }

  /* Navigation links */
  .hamburger-overlay__nav {
    display: flex;
  }

  .hamburger-overlay__nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    width: 100%;
  }

  .hamburger-overlay__item {
    border-bottom: 1px solid color-mix(in srgb, var(--color-text) 10%, transparent);
  }

  .hamburger-overlay__link {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: calc(var(--space-6) - 4px) 0;
    padding-left: var(--space-4);
    padding-right: var(--space-2);
    font-size: var(--type-md);
    font-weight: var(--weight-light);
    color: var(--color-text);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    opacity: 0.75;
    transition: opacity 0.2s ease;
  }

  .hamburger-overlay__link:hover,
  .hamburger-overlay__link:active {
    opacity: 1;
  }

  .hamburger-overlay__link-arrow {
    font-size: 24px;
    opacity: 0.4;
  }

  /* Secondary navigation */
  .hamburger-overlay__secondary {
    padding-top: 0;
  }

  .hamburger-overlay__secondary ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
  }

  .hamburger-overlay__secondary-item {
    border-bottom: 1px solid color-mix(in srgb, var(--color-text) 10%, transparent);
  }

  .hamburger-overlay__secondary-item:first-child {
    border-top: none;
  }

  .hamburger-overlay__secondary-link {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-2) var(--space-3) var(--space-4);
    font-size: var(--type-sm);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    opacity: 0.75;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .hamburger-overlay__secondary-arrow {
    font-size: 18px;
    opacity: 0.55;
  }

  .hamburger-overlay__secondary-link:hover,
  .hamburger-overlay__secondary-link:active {
    opacity: 1;
  }

  /* Mode toggle */

  .hamburger-overlay__mode {
    display: flex;
    position: relative;
    border: 1px solid color-mix(in srgb, var(--color-text) 20%, transparent);
    border-radius: var(--btn-radius);
    padding: 3px;
    gap: 0;
    margin-bottom: var(--space-4);
    width: 100%;
  }

  .hamburger-overlay__mode-pill {
    position: absolute;
    top: 3px;
    left: 3px;
    height: calc(100% - 6px);
    border-radius: var(--btn-radius-inner);
    border: 1px solid var(--color-text);
    pointer-events: none;
    z-index: 0;
  }

  .hamburger-overlay__mode-btn {
    position: relative;
    z-index: 1;
    flex: 1;
    background: none;
    border: none;
    border-radius: var(--btn-radius-inner);
    cursor: pointer;
    font-size: var(--type-sm);
    font-weight: var(--weight-regular);
    color: color-mix(in srgb, var(--color-text) 65%, transparent);
    padding: 8px var(--btn-padding-x);
    text-transform: uppercase;
    text-decoration: none;
    letter-spacing: 0.04em;
    text-align: center;
    transition: color 0.3s ease;
  }

  .hamburger-overlay__mode-btn.is-active {
    font-weight: var(--weight-medium);
    color: var(--color-text);
  }

  /* Language */

  .hamburger-overlay__lang {
    display: flex;
    position: relative;
    border: 1px solid color-mix(in srgb, var(--color-text) 20%, transparent);
    border-radius: var(--btn-radius);
    padding: 3px;
    gap: 0;
    margin-top: 0;
    width: 100%;
  }

  .hamburger-overlay__lang-pill {
    position: absolute;
    top: 3px;
    left: 3px;
    height: calc(100% - 6px);
    border-radius: var(--btn-radius-inner);
    border: 1px solid var(--color-text);
    pointer-events: none;
    z-index: 0;
  }

  .hamburger-overlay__lang-btn {
    position: relative;
    z-index: 1;
    flex: 1;
    background: none;
    border: none;
    border-radius: var(--btn-radius-inner);
    cursor: pointer;
    font-size: var(--type-sm);
    font-weight: var(--weight-regular);
    color: color-mix(in srgb, var(--color-text) 65%, transparent);
    padding: 8px var(--btn-padding-x);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    text-align: center;
    transition: color 0.3s ease;
  }

  .hamburger-overlay__lang-btn.is-active {
    font-weight: var(--weight-medium);
    color: var(--color-text);
  }

  .hamburger-overlay__lang-btn--disabled {
    opacity: 0.35;
    cursor: not-allowed;
    pointer-events: none;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  @media (min-width: 768px) {
    .hamburger-overlay__header {
      width: 500px;
      margin: 0 auto;
      padding-left: var(--space-2);
      padding-right: var(--space-2);
    }

    .hamburger-overlay__header svg {
      width: 18px;
      height: 18px;
    }

    .hamburger-overlay__body {
      width: 500px;
      margin: 0 auto;
      padding-left: var(--space-2);
      padding-right: var(--space-2);
    }

    .hamburger-overlay__link {
      font-size: var(--type-md);
      padding: calc(var(--space-6) - 4px) 0;
      padding-left: 0;
      padding-right: 0;
      justify-content: space-between;
    }

    .hamburger-overlay__secondary {
      padding-top: 0;
    }

    .hamburger-overlay__secondary-link {
      padding-left: 0;
      padding-right: 0;
      justify-content: space-between;
    }

    .hamburger-overlay__secondary-item {
      border: none;
    }

    .hamburger-overlay__secondary-item:first-child {
      border: none;
    }

    .hamburger-overlay__lang {
      width: 100%;
    }
  }
</style>

<script>
  import { gsap } from 'gsap';

  function initHamburgerOverlay() {
    const overlay = document.getElementById('hamburger-overlay');
    const closeBtn = overlay?.querySelector('.hamburger-overlay__close');
    const langBtns = overlay?.querySelectorAll('.hamburger-overlay__lang-btn');
    const navItems = overlay?.querySelectorAll('.hamburger-overlay__item');
    const body = overlay?.querySelector('.hamburger-overlay__body');
    const langGroup = overlay?.querySelector('.hamburger-overlay__lang');

    const inner = overlay?.querySelector('.hamburger-overlay__inner') as HTMLElement;

    function open(swap = false) {
      if (!overlay) return;
      overlay.classList.add('is-open');
      overlay.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
      (window as any).__lenis?.stop?.();

      // Sync language toggle to current lang
      const currentLang = document.documentElement.lang || 'en';
      langBtns?.forEach(btn => {
        btn.classList.toggle('is-active', (btn as HTMLElement).dataset.lang === currentLang);
      });
      requestAnimationFrame(() => slideLangPill());

      if (!swap) {
        // Full open: fade in backdrop + content
        gsap.to(overlay, { opacity: 1, duration: 0.3, ease: 'power2.out' });
      } else {
        // Swap: backdrop already visible, just show
        gsap.set(overlay, { opacity: 1 });
      }

      // Animate content in
      const tl = gsap.timeline();
      if (navItems?.length) {
        gsap.set(navItems, { opacity: 0, x: -20 });
        tl.to(navItems, {
          opacity: 1,
          x: 0,
          duration: 0.4,
          ease: 'power3.out',
          stagger: 0.06,
        }, swap ? 0 : 0.15);
      }
      if (langGroup) {
        gsap.set(langGroup, { opacity: 0 });
        tl.to(langGroup, { opacity: 1, duration: 0.3, ease: 'power2.out' }, swap ? 0.15 : 0.35);
      }

      requestAnimationFrame(() => {
        slideLangPill();
        slideModePill();
      });
    }

    function close(swap = false) {
      if (!overlay) return;
      if (swap) {
        // Swap: just hide content quickly, keep backdrop
        gsap.to(inner, {
          opacity: 0,
          duration: 0.2,
          ease: 'power2.in',
          onComplete: () => {
            overlay.classList.remove('is-open');
            overlay.setAttribute('aria-hidden', 'true');
            gsap.set(inner, { opacity: 1 });
          },
        });
      } else {
        // Full close: fade out everything
        gsap.to(overlay, {
          opacity: 0,
          duration: 0.25,
          ease: 'power2.in',
          onComplete: () => {
            overlay.classList.remove('is-open');
            overlay.setAttribute('aria-hidden', 'true');
            document.body.style.overflow = '';
            (window as any).__lenis?.start?.();
          },
        });
      }
    }

    closeBtn?.addEventListener('click', () => close(false));

    // Search button — swap to search overlay
    const searchBtn = overlay?.querySelector('.hamburger-overlay__search-btn');
    searchBtn?.addEventListener('click', () => {
      // Immediately open the other overlay behind this one
      (window as any).__searchOverlay?.open(true);
      // Then fade out this content
      close(true);
    });

    // Hours button — swap to hours overlay
    overlay?.querySelector('[data-action="open-hours"]')?.addEventListener('click', () => {
      (window as any).__hoursOverlay?.open(true);
      close(true);
    });

    // Mode toggle pill slider
    const modeToggle = overlay?.querySelector('[data-mode-toggle]') as HTMLElement;
    const modePill = modeToggle?.querySelector('.hamburger-overlay__mode-pill') as HTMLElement;
    const modeBtns = overlay?.querySelectorAll('.hamburger-overlay__mode-btn');

    function slideModePill() {
      if (!modeToggle || !modePill) return;
      const active = modeToggle.querySelector('.is-active') as HTMLElement;
      if (!active) return;
      const toggleRect = modeToggle.getBoundingClientRect();
      const activeRect = active.getBoundingClientRect();
      gsap.to(modePill, {
        x: activeRect.left - toggleRect.left - 3,
        width: activeRect.width,
        duration: 0.35,
        ease: 'power3.out',
      });
    }

    // Phase 03-01: active state is server-rendered from Astro.url.pathname.
    // Just position the pill under the already-active segment on mount.
    if (modeToggle && modePill) {
      requestAnimationFrame(() => {
        const active = modeToggle.querySelector('.is-active') as HTMLElement;
        if (active) {
          const toggleRect = modeToggle.getBoundingClientRect();
          const activeRect = active.getBoundingClientRect();
          gsap.set(modePill, {
            x: activeRect.left - toggleRect.left - 3,
            width: activeRect.width,
          });
        }
      });
    }

    // Mode anchors: close overlay before navigation so View Transitions
    // don't animate the overlay itself. The <a href> then proceeds natively
    // and Astro's ClientRouter intercepts it.
    modeBtns?.forEach(btn => {
      btn.addEventListener('click', () => {
        close(false);
      });
    });

    // Language pill slider
    const langToggle = overlay?.querySelector('[data-lang-toggle]') as HTMLElement;
    const langPill = langToggle?.querySelector('.hamburger-overlay__lang-pill') as HTMLElement;

    function slideLangPill() {
      if (!langToggle || !langPill) return;
      const active = langToggle.querySelector('.is-active') as HTMLElement;
      if (!active) return;
      const toggleRect = langToggle.getBoundingClientRect();
      const activeRect = active.getBoundingClientRect();
      gsap.to(langPill, {
        x: activeRect.left - toggleRect.left - 3,
        width: activeRect.width,
        duration: 0.35,
        ease: 'power3.out',
      });
    }

    // Set initial lang pill position
    if (langToggle && langPill) {
      const initActive = langToggle.querySelector('.is-active') as HTMLElement;
      if (initActive) {
        requestAnimationFrame(() => {
          const toggleRect = langToggle.getBoundingClientRect();
          const activeRect = initActive.getBoundingClientRect();
          gsap.set(langPill, {
            x: activeRect.left - toggleRect.left - 3,
            width: activeRect.width,
          });
        });
      }
    }

    // Language buttons
    langBtns?.forEach(btn => {
      btn.addEventListener('click', () => {
        const lang = (btn as HTMLElement).dataset.lang;
        if (lang === 'fr') return; // FR disabled
        if (lang) {
          document.documentElement.setAttribute('lang', lang);
          localStorage.setItem('kunsthaus-lang', lang);
          langBtns.forEach(b => b.classList.remove('is-active'));
          btn.classList.add('is-active');
          slideLangPill();
        }
      });
    });

    // Close on Escape
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && overlay?.classList.contains('is-open')) {
        close();
      }
    });

    // --- Login-state awareness ---
    const loginItem = overlay?.querySelector('[data-login-item]') as HTMLElement;
    const loginLink = overlay?.querySelector('[data-login-link]') as HTMLAnchorElement;
    const loginText = overlay?.querySelector('[data-login-text]') as HTMLElement;
    const lang = document.documentElement.lang || 'en';
    const loginLabel = lang === 'de' ? 'Anmelden' : 'Log in';
    const accountLabel = lang === 'de' ? 'Mein Konto' : 'My Account';

    // Login handler for the "Log in" link (second login entry point)
    function handleLoginClick(e: Event) {
      e.preventDefault();
      localStorage.setItem('kunsthaus-demo-user', 'purchased');
      (window as any).__demoUser = 'purchased';
      window.dispatchEvent(new CustomEvent('kunsthaus:login'));
      close(false);
    }

    function setLoggedInState() {
      if (!loginText || !loginLink) return;
      loginText.textContent = accountLabel;
      loginLink.href = '#';
      loginLink.removeEventListener('click', handleLoginClick);
      loginLink.addEventListener('click', (e: Event) => {
        e.preventDefault();
        (window as any).__profileOverlay?.open();
        close(false);
      });
    }

    function setLoggedOutState() {
      if (!loginText || !loginLink) return;
      loginText.textContent = loginLabel;
      loginLink.href = '#';
      loginLink.addEventListener('click', handleLoginClick);
    }

    // Initial state
    if (localStorage.getItem('kunsthaus-demo-user')) {
      setLoggedInState();
    } else {
      setLoggedOutState();
    }

    window.addEventListener('kunsthaus:login', setLoggedInState);
    window.addEventListener('kunsthaus:logout', setLoggedOutState);

    // Expose open/close
    (window as any).__hamburgerOverlay = { open, close };
  }

  // Run once on first paint and again after every Astro View Transitions nav.
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHamburgerOverlay);
  } else {
    initHamburgerOverlay();
  }
  document.addEventListener('astro:page-load', initHamburgerOverlay);
</script>
