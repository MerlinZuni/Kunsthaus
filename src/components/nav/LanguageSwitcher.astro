---
// LanguageSwitcher.astro -- D-08: Language dropdown (EN/DE/FR)

interface Props {
  lang: 'en' | 'de';
}

const { lang } = Astro.props;
const languages = [
  { code: 'en', label: 'EN' },
  { code: 'de', label: 'DE' },
  { code: 'fr', label: 'FR' },
];
const current = languages.find(l => l.code === lang) || languages[0];
---

<div class="lang-switcher" role="group" aria-label="Language selection">
  <button
    class="lang-switcher__trigger touch-target"
    aria-expanded="false"
    aria-label={`Language: ${current.label}`}
  >
    <span class="lang-switcher__current">{current.label}</span>
    <span class="icon lang-switcher__arrow">arrow_drop_down</span>
  </button>
  <div class="lang-switcher__panel">
    {languages.map(l => (
      <button
        class:list={[
          'lang-switcher__option',
          { 'lang-switcher__option--hidden': l.code === lang },
          { 'lang-switcher__option--disabled': l.code === 'fr' }
        ]}
        data-lang={l.code}
        {...(l.code === 'fr' ? { disabled: true, title: 'Coming soon' } : {})}
      >
        {l.label}{l.code === 'fr' ? ' (soon)' : ''}
      </button>
    ))}
  </div>
</div>

<style>
  .lang-switcher {
    position: relative;
    z-index: 2;
  }

  .lang-switcher__trigger {
    background: none;
    border: 1px solid color-mix(in srgb, var(--color-text) 30%, transparent);
    border-radius: var(--btn-radius);
    cursor: pointer;
    color: var(--color-text);
    font-size: var(--type-md);
    font-weight: var(--weight-medium);
    font-family: inherit;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2px;
    padding: 6px 14px 6px 18px;
  }

  .lang-switcher.is-open .lang-switcher__trigger {
    border-radius: 16px 16px 0 0;
  }

  .lang-switcher__arrow {
    font-size: 24px;
    opacity: 0.7;
    transition: transform 0.3s ease;
  }

  .lang-switcher.is-open .lang-switcher__arrow {
    transform: rotate(180deg);
  }

  .lang-switcher__panel {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    display: flex;
    flex-direction: column;
    max-height: 0;
    overflow: hidden;
    background-color: var(--color-concrete-light);
    background-image: url(/Kunsthaus/textures/concrete-wall.png);
    background-repeat: repeat;
    background-blend-mode: multiply;
    border: 1px solid color-mix(in srgb, var(--color-text) 30%, transparent);
    border-top: none;
    border-radius: 0 0 16px 16px;
    transition: max-height 0.3s ease;
    opacity: 0;
  }

  .lang-switcher.is-open .lang-switcher__panel {
    max-height: 100px;
    opacity: 1;
  }

  .lang-switcher__option {
    background: none;
    border: none;
    border-top: 1px solid color-mix(in srgb, var(--color-text) 10%, transparent);
    cursor: pointer;
    color: var(--color-text);
    font-size: var(--type-md);
    font-weight: var(--weight-regular);
    font-family: inherit;
    padding: 6px 18px;
    text-align: left;
    opacity: 0.6;
    transition: opacity 0.2s ease;
  }

  .lang-switcher__option--hidden {
    display: none;
  }

  .lang-switcher__option:last-child {
    padding-bottom: 8px;
  }

  .lang-switcher__option:hover {
    opacity: 1;
  }

  .lang-switcher__option--disabled {
    opacity: 0.35;
    cursor: not-allowed;
    pointer-events: none;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.lang-switcher').forEach(switcher => {
      const trigger = switcher.querySelector('.lang-switcher__trigger') as HTMLButtonElement;
      const currentLabel = trigger?.querySelector('.lang-switcher__current') as HTMLElement;
      const options = switcher.querySelectorAll('.lang-switcher__option');

      trigger?.addEventListener('click', () => {
        const isOpen = switcher.classList.toggle('is-open');
        trigger.setAttribute('aria-expanded', String(isOpen));
      });

      options.forEach(option => {
        option.addEventListener('click', () => {
          const lang = (option as HTMLElement).dataset.lang;
          if (lang === 'fr') return; // FR disabled
          if (lang) {
            document.documentElement.setAttribute('lang', lang);
            localStorage.setItem('kunsthaus-lang', lang);
            if (currentLabel) currentLabel.textContent = lang.toUpperCase();
            // Show all options, then hide the newly active one
            options.forEach(o => o.classList.remove('lang-switcher__option--hidden'));
            option.classList.add('lang-switcher__option--hidden');
          }
          switcher.classList.remove('is-open');
          trigger.setAttribute('aria-expanded', 'false');
        });
      });

      // Close on click outside
      document.addEventListener('click', (e) => {
        if (!switcher.contains(e.target as Node)) {
          switcher.classList.remove('is-open');
          trigger?.setAttribute('aria-expanded', 'false');
        }
      });
    });

    // Restore language from localStorage
    const saved = localStorage.getItem('kunsthaus-lang');
    if (saved && ['en', 'de', 'fr'].includes(saved)) {
      document.documentElement.setAttribute('lang', saved);
    }
  });
</script>
