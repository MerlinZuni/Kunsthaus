---
// NavProfileButton.astro -- Conditional profile icon in navbar.
// Hidden by default; shown with GSAP fade-in on kunsthaus:login event
// or if localStorage already has the demo-user flag. Clicking opens ProfileOverlay.
---

<button
  type="button"
  class="navbar__icon-btn navbar__profile-btn touch-target touch-pulse"
  id="nav-profile-btn"
  aria-label="Profile"
  style="display: none;"
>
  <span class="icon" aria-hidden="true">account_circle</span>
</button>

<style>
  .navbar__profile-btn {
    position: relative;
    z-index: 2;
  }

  .navbar__profile-btn .icon {
    font-size: 24px;
  }
</style>

<script>
  import { gsap } from 'gsap';

  function initNavProfileButton() {
    const btn = document.getElementById('nav-profile-btn');
    if (!btn || btn.dataset.initialized === 'true') return;
    btn.dataset.initialized = 'true';

    function show() {
      btn.style.display = 'flex';
      gsap.fromTo(btn,
        { opacity: 0, scale: 0.8 },
        { opacity: 1, scale: 1, duration: 0.4, ease: 'back.out(1.7)' }
      );
    }

    function hide() {
      gsap.to(btn, {
        opacity: 0,
        scale: 0.8,
        duration: 0.25,
        ease: 'power2.in',
        onComplete: () => {
          btn.style.display = 'none';
        },
      });
    }

    // Check if already logged in
    if (localStorage.getItem('kunsthaus-demo-user')) {
      btn.style.display = 'flex';
      gsap.set(btn, { opacity: 1, scale: 1 });
    }

    window.addEventListener('kunsthaus:login', show);
    window.addEventListener('kunsthaus:logout', hide);

    btn.addEventListener('click', () => {
      (window as any).__profileOverlay?.open();
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initNavProfileButton);
  } else {
    initNavProfileButton();
  }
  document.addEventListener('astro:page-load', () => {
    const btn = document.getElementById('nav-profile-btn');
    if (btn) btn.dataset.initialized = '';
    initNavProfileButton();
  });
</script>
