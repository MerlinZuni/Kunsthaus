---
// KjmHero.astro — Phase 03-03 full-bleed background video hero for exhibition
// detail pages. Plain HTML5 video: autoplay muted loop playsinline
// preload="metadata" poster=... — all five attributes are non-negotiable for
// iOS autoplay. NO transition:persist (let the element remount on navigation).

interface Props {
  title: { de: string; en: string };
  dateLabel: { de: string; en: string };
  video: { src: string; poster: string };
  backLabel: { de: string; en: string };
  backHref: string;
  lang: 'en' | 'de';
}

const { title, dateLabel, video, backLabel, backHref, lang } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const videoSrc = `${base}${video.src}`;
const posterSrc = `${base}${video.poster}`;
---

<section class="kjm-hero" data-section="kjm-hero">
  <video
    class="kjm-hero__video"
    autoplay
    muted
    loop
    playsinline
    preload="metadata"
    poster={posterSrc}
  >
    <source src={videoSrc} type="video/mp4" />
  </video>
  <div class="kjm-hero__scrim" aria-hidden="true"></div>
  <a class="kjm-hero__back" href={backHref} data-i18n-de={backLabel.de} data-i18n-en={backLabel.en}>{backLabel[lang]}</a>
  <div class="kjm-hero__title-block">
    <p class="kjm-hero__datelabel" data-i18n-de={dateLabel.de} data-i18n-en={dateLabel.en}>{dateLabel[lang]}</p>
    <h1 class="kjm-hero__title" data-i18n-de={title.de} data-i18n-en={title.en}>{title[lang]}</h1>
    <button
      type="button"
      class="kjm-hero__playpause"
      data-kjm-playpause
      data-paused="false"
      aria-label="Pause background video"
    >
      <svg class="kjm-hero__icon kjm-hero__icon--pause" width="14" height="14" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <rect x="4" y="3" width="4" height="14" rx="1" />
        <rect x="12" y="3" width="4" height="14" rx="1" />
      </svg>
      <svg class="kjm-hero__icon kjm-hero__icon--play" width="14" height="14" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <polygon points="5,3 17,10 5,17" />
      </svg>
    </button>
  </div>
</section>

<script>
  // Reduce-motion: pause the hero video. Dual-init so View Transitions works.
  function kjmHeroReduceMotionGuard() {
    if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    document.querySelectorAll<HTMLVideoElement>('.kjm-hero__video').forEach((v) => v.pause());
  }
  kjmHeroReduceMotionGuard();
  document.addEventListener('astro:page-load', kjmHeroReduceMotionGuard);

  function initKjmHeroPlayPause() {
    document.querySelectorAll<HTMLElement>('.kjm-hero').forEach((hero) => {
      if (hero.dataset.pauseInit === 'true') return;
      hero.dataset.pauseInit = 'true';
      const video = hero.querySelector<HTMLVideoElement>('.kjm-hero__video');
      const btn = hero.querySelector<HTMLButtonElement>('[data-kjm-playpause]');
      if (!video || !btn) return;
      const sync = () => {
        const paused = video.paused;
        btn.dataset.paused = String(paused);
        btn.setAttribute('aria-label', paused ? 'Play background video' : 'Pause background video');
      };
      btn.addEventListener('click', () => {
        if (video.paused) video.play().catch(() => {});
        else video.pause();
        sync();
      });
      video.addEventListener('play', sync);
      video.addEventListener('pause', sync);
      sync();
    });
  }
  initKjmHeroPlayPause();
  document.addEventListener('astro:page-load', initKjmHeroPlayPause);
</script>

<style>
  .kjm-hero {
    position: relative;
    width: 100%;
    height: 85vh;
    min-height: 500px;
    overflow: hidden;
    background: #0a0a0a;
    color: #ffffff;
  }

  @media (max-width: 767px) {
    .kjm-hero {
      height: 100vh;
    }
  }

  .kjm-hero__video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .kjm-hero__scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0.55) 0%,
      rgba(0, 0, 0, 0.08) 38%,
      rgba(0, 0, 0, 0.55) 100%
    );
    pointer-events: none;
    z-index: 1;
  }

  .kjm-hero__back {
    position: absolute;
    top: calc(110px + var(--space-3));
    left: var(--space-8);
    color: #ffffff;
    text-decoration: none;
    font-size: var(--type-sm);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    z-index: 2;
    padding: var(--space-2) var(--space-3);
    border: 1px solid rgba(255, 255, 255, 0.45);
    backdrop-filter: blur(2px);
    transition: background 0.2s ease, border-color 0.2s ease;
  }

  .kjm-hero__back:hover,
  .kjm-hero__back:focus-visible {
    background: rgba(255, 255, 255, 0.12);
    border-color: rgba(255, 255, 255, 0.85);
    outline: none;
  }

  .kjm-hero__title-block {
    position: absolute;
    left: var(--space-8);
    right: var(--space-8);
    bottom: var(--space-12);
    z-index: 2;
    color: #ffffff;
    max-width: 24ch;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .kjm-hero__playpause {
    margin-top: var(--space-5);
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: none;
    background: rgba(0, 0, 0, 0.55);
    -webkit-backdrop-filter: blur(6px);
    backdrop-filter: blur(6px);
    color: #ffffff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s ease, transform 0.2s ease;
  }
  .kjm-hero__playpause:hover,
  .kjm-hero__playpause:focus-visible {
    background: rgba(0, 0, 0, 0.78);
    transform: scale(1.05);
    outline: none;
  }
  .kjm-hero__playpause[data-paused="false"] .kjm-hero__icon--play { display: none; }
  .kjm-hero__playpause[data-paused="true"] .kjm-hero__icon--pause { display: none; }

  .kjm-hero__datelabel {
    font-size: var(--type-sm);
    opacity: 0.85;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0 0 var(--space-3);
  }

  .kjm-hero__title {
    font-size: var(--type-4xl);
    font-weight: var(--weight-bold);
    line-height: 0.95;
    text-transform: uppercase;
    margin: 0;
  }

  @media (max-width: 767px) {
    .kjm-hero__back {
      top: calc(110px + var(--space-2));
      left: var(--space-6);
    }
    .kjm-hero__title-block {
      left: var(--space-6);
      right: var(--space-6);
      bottom: var(--space-24);
    }
    .kjm-hero__title {
      font-size: var(--type-2xl);
    }
  }
</style>
