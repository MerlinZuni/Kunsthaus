---
// CarouselTabs.astro -- D-04: Progress tabs with animated fill bars for carousel

interface Props {
  slides: Array<{
    id: string;
    title: { de: string; en: string };
    subtitle?: { de: string; en: string };
    cta: { label: { de: string; en: string }; href: string };
  }>;
  lang: 'en' | 'de';
  pauseLabel: string;
  playLabel: string;
}

const { slides, lang, pauseLabel, playLabel } = Astro.props;
const firstSlide = slides[0];
---

<script is:inline define:vars={{ slideData: slides.map(s => ({ subtitle_en: s.subtitle?.en || '', subtitle_de: s.subtitle?.de || '', ctaLabel: s.cta?.label?.[lang] || '', ctaHref: s.cta?.href || '#' })) }}>
  window.__carouselSlideData = slideData;
</script>

<nav class="carousel-tabs" aria-label="Exhibition slides">
  {/* Mobile label */}
  <span class="carousel-tabs__label" data-i18n-de="Ausstellungen" data-i18n-en="Exhibitions">{lang === 'de' ? 'Ausstellungen' : 'Exhibitions'}</span>

  {/* Row 1: Subtitle */}
  <p class="carousel-tabs__subtitle sub-heading" id="carousel-subtitle">{firstSlide?.subtitle?.[lang] || ''}</p>

  {/* Row 2: Tab buttons + controls */}
  <div class="carousel-tabs__row">
    {slides.map((slide, i) => (
      <button
        class:list={['carousel-tabs__tab', { 'carousel-tabs__tab--active': i === 0 }]}
        data-tab={i}
        aria-label={`Go to slide ${i + 1}: ${slide.title[lang]}`}
      >
        <span class="carousel-tabs__title" data-i18n-de={slide.title.de} data-i18n-en={slide.title.en}>{slide.title[lang]}</span>
        <div class="carousel-tabs__progress">
          <div class="carousel-tabs__tab-fill" data-tab-fill={i} />
        </div>
      </button>
    ))}

    {/* Pause/play + counter */}
    <div class="carousel-tabs__controls">
      <button
        class="carousel-tabs__pause touch-target"
        id="carousel-pause-btn"
        aria-label={pauseLabel}
        data-pause-label={pauseLabel}
        data-play-label={playLabel}
      >
        <svg class="carousel-tabs__pause-icon" width="20" height="20" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <rect x="4" y="3" width="4" height="14" rx="1"/>
          <rect x="12" y="3" width="4" height="14" rx="1"/>
        </svg>
        <svg class="carousel-tabs__play-icon" width="20" height="20" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
          <polygon points="5,3 17,10 5,17"/>
        </svg>
      </button>
      <span class="carousel-tabs__counter" id="carousel-counter">1/{slides.length}</span>
    </div>
  </div>
</nav>

{/* Mobile condensed tabs: counter + title + segmented progress, above sticky bar */}
{/* Moved to <body> via script so position:fixed escapes hero overflow/transforms */}
<div class="carousel-tabs-mobile" id="carousel-tabs-mobile">
  <div class="carousel-tabs-mobile__header">
    <span class="carousel-tabs-mobile__counter" id="carousel-counter-mobile">01/{String(slides.length).padStart(2, '0')}</span>
    <span class="carousel-tabs-mobile__title" id="carousel-title-mobile">{firstSlide?.title?.[lang] || ''}</span>
  </div>
  <div class="carousel-tabs-mobile__progress">
    {slides.map((_, i) => (
      <button
        class:list={['carousel-tabs-mobile__segment', { 'carousel-tabs-mobile__segment--active': i === 0 }]}
        data-mobile-tab={i}
        aria-label={`Go to slide ${i + 1}`}
      >
        <div class="carousel-tabs-mobile__fill" data-mobile-fill={i} />
      </button>
    ))}
  </div>
</div>

<style>
  .carousel-tabs {
    position: absolute;
    bottom: 0;
    left: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    z-index: 3;
    background: color-mix(in srgb, var(--color-surface) 70%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    padding: var(--space-6) var(--space-8);
  }

  /* Mobile-only label */
  .carousel-tabs__label {
    display: none;
    font-size: 16px;
    font-weight: var(--weight-regular);
    text-transform: uppercase;
    color: var(--color-text);
  }

  /* Row 1: Subtitle */
  .carousel-tabs__subtitle {
    margin: 0;
  }

  /* Row 2: Tabs + controls inline */
  .carousel-tabs__row {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .carousel-tabs__tab {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-text);
    padding: var(--space-2) 0;
    min-width: 120px;
    text-align: left;
  }

  .carousel-tabs__title {
    display: block;
    font-size: var(--type-sm);
    font-weight: var(--weight-regular);
    margin-bottom: var(--space-1);
    opacity: 0.5;
    white-space: nowrap;
    transition: opacity 0.4s ease, font-weight 0.4s ease;
  }

  .carousel-tabs__tab--active .carousel-tabs__title {
    opacity: 1;
    font-weight: var(--weight-bold);
  }

  .carousel-tabs__progress {
    height: 2px;
    background: var(--color-decorative);
    width: 100%;
  }

  .carousel-tabs__tab-fill {
    height: 100%;
    background: var(--color-text);
    transform-origin: left;
    transform: scaleX(0);
    will-change: transform;
  }

  .carousel-tabs__tab--active .carousel-tabs__tab-fill {
    transform: scaleX(1);
  }

  /* Pause + counter inline controls */
  .carousel-tabs__controls {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin-left: var(--space-2);
    padding-left: var(--space-4);
    border-left: 1px solid var(--color-decorative);
  }

  .carousel-tabs__pause {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-text);
    padding: var(--space-1);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .carousel-tabs__play-icon {
    display: none;
  }

  .carousel-tabs__pause.is-paused .carousel-tabs__pause-icon {
    display: none;
  }
  .carousel-tabs__pause.is-paused .carousel-tabs__play-icon {
    display: block;
  }

  .carousel-tabs__counter {
    font-size: var(--type-sm);
    font-variant-numeric: tabular-nums;
    color: var(--color-text);
    opacity: 0.7;
    white-space: nowrap;
    display: none;
  }

  @media (max-width: 1200px) {
    .carousel-tabs__counter {
      display: block;
    }
  }

  /* Mobile */
  @media (max-width: 767px) {
    .carousel-tabs {
      right: 0;
      bottom: 0;
      padding: 16px 16px 72px;
      gap: 12px;
    }

    .carousel-tabs__subtitle {
      display: none;
    }

    .carousel-tabs__label {
      display: none;
    }

    .carousel-tabs__row {
      flex-direction: column;
      gap: 0;
      align-items: stretch;
    }

    .carousel-tabs__tab {
      min-width: auto;
      padding: 14px 0;
    }

    .carousel-tabs__title {
      display: block;
      font-size: 16px;
      text-transform: uppercase;
      margin-bottom: 0;
    }

    /* Progress bars become thin separator lines */
    .carousel-tabs__progress {
      width: 100%;
      height: 1px;
      background: rgba(0, 0, 0, 0.1);
      margin-top: 14px;
    }

    .carousel-tabs__tab-fill {
      height: 2px;
      margin-top: -1px;
    }

    /* Hide pause/counter on mobile */
    .carousel-tabs__controls {
      display: none;
    }

    /* Hide desktop tabs on mobile */
    .carousel-tabs {
      display: none;
    }
  }

  /* Mobile condensed tabs */
  .carousel-tabs-mobile {
    display: none;
  }

  @media (max-width: 767px) {
    .carousel-tabs-mobile {
      display: flex;
      flex-direction: column;
      gap: 8px;
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      z-index: 6;
      padding: 20px 16px 140px;
      pointer-events: auto;
      background: color-mix(in srgb, var(--color-surface) 70%, transparent);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
    }

    .carousel-tabs-mobile__header {
      display: flex;
      align-items: baseline;
      gap: 10px;
    }

    .carousel-tabs-mobile__counter {
      font-size: var(--type-sm);
      font-weight: var(--weight-medium);
      font-variant-numeric: tabular-nums;
      color: var(--color-text);
      opacity: 0.5;
    }

    .carousel-tabs-mobile__title {
      font-size: var(--type-sm);
      font-weight: var(--weight-bold);
      color: var(--color-text);
      text-transform: uppercase;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .carousel-tabs-mobile__progress {
      display: flex;
      gap: 4px;
    }

    .carousel-tabs-mobile__segment {
      flex: 1;
      height: 2px;
      background: color-mix(in srgb, var(--color-text) 15%, transparent);
      border: none;
      padding: 0;
      cursor: pointer;
      position: relative;
      overflow: hidden;
    }

    .carousel-tabs-mobile__fill {
      position: absolute;
      inset: 0;
      background: var(--color-text);
      transform-origin: left;
      transform: scaleX(0);
    }

    .carousel-tabs-mobile__segment--active .carousel-tabs-mobile__fill {
      transform: scaleX(1);
    }
  }
</style>
