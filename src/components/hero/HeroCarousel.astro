---
// HeroCarousel.astro -- Stub: will be fully implemented in Plan 02-02
// D-01 through D-06: Hero carousel with right-aligned typography and scattered images

interface Props {
  slides: Array<{
    id: string;
    title: { de: string; en: string };
    subtitle?: { de: string; en: string };
    cta: { label: { de: string; en: string }; href: string };
    images: Array<{
      src: string;
      alt: { de: string; en: string };
      gridCol: string;
      gridRow: string;
    }>;
  }>;
  lang: 'en' | 'de';
  uiStrings: any;
}

const { slides, lang } = Astro.props;
const activeSlide = slides[0];
---

<section class="hero-pinned" aria-roledescription="carousel" aria-label="Featured exhibitions">
  <div class="hero-carousel">
    {/* Exhibition images -- scattered behind text */}
    <div class="hero-carousel__images">
      {activeSlide?.images.map((img, i) => {
        const grays = ['#b0b0b0', '#8a8a8a', '#c8c8c8', '#9e9e9e', '#d4d4d4'];
        return (
          <div class="hero-carousel__image-slot" style={`grid-column: ${img.gridCol}; grid-row: ${img.gridRow}; background: ${grays[i % grays.length]};`}>
            <img src={img.src} alt={img.alt[lang]} loading="eager" />
          </div>
        );
      })}
    </div>

    {/* Large right-aligned typography */}
    <div class="hero-carousel__text">
      <h1 class="hero-carousel__title">
        <span>KUNST</span>
        <span>HAUS</span>
        <span>ZURICH</span>
      </h1>
    </div>

    {/* Gradient scrim for tab/CTA legibility over images */}
    <div class="hero-carousel__scrim" aria-hidden="true"></div>

    {/* Carousel progress tabs */}
    <nav class="hero-carousel__tabs" aria-label="Exhibition slides">
      {slides.map((slide, i) => (
        <button
          class:list={['hero-carousel__tab', { 'hero-carousel__tab--active': i === 0 }]}
          role="group"
          aria-roledescription="slide"
          aria-label={`${i + 1} of ${slides.length}: ${slide.title[lang]}`}
        >
          <span class="hero-carousel__tab-title">{slide.title[lang]}</span>
          <div class="hero-carousel__tab-progress">
            <div class="hero-carousel__tab-fill" />
          </div>
        </button>
      ))}
    </nav>

    {/* CTA -- positioned in the image area, left side */}
    {activeSlide?.cta && (
      <a href={activeSlide.cta.href} class="hero-carousel__cta hover-wipe-inverse touch-pulse touch-target">
        <span>{activeSlide.cta.label[lang]}</span>
      </a>
    )}
  </div>
</section>

<style>
  .hero-carousel {
    position: relative;
    width: 100%;
    height: 85vh;
    min-height: 500px;
    overflow: hidden;
    background: var(--color-surface);
  }

  .hero-carousel__images {
    position: absolute;
    inset: 0;
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    grid-template-rows: 80px 80px 160px 160px 160px 80px 80px 160px;
    z-index: 1;
  }

  .hero-carousel__image-slot {
    overflow: hidden;
    align-self: start;
  }

  .hero-carousel__image-slot img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .hero-carousel__image-slot img[src=""],
  .hero-carousel__image-slot img:not([src]) {
    display: none;
  }

  /* Placeholder aspect ratios — width driven by grid columns, height by ratio */
  .hero-carousel__image-slot:nth-child(1) {
    aspect-ratio: 3 / 2;
  }
  .hero-carousel__image-slot:nth-child(2) {
    aspect-ratio: 3 / 2;
    margin-top: 80px;
  }
  .hero-carousel__image-slot:nth-child(3) {
    aspect-ratio: 2 / 3;
  }

  .hero-carousel__scrim {
    display: none;
  }

  .hero-carousel__text {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    mix-blend-mode: multiply;
    padding-right: var(--space-12);
    z-index: 5;
  }

  .hero-carousel__title {
    display: flex;
    flex-direction: column;
    text-align: right;
    font-size: clamp(var(--type-4xl), 10vw, 7rem);
    font-weight: var(--weight-bold);
    line-height: var(--leading-tight);
    text-transform: uppercase;
    color: var(--color-text);
  }

  .hero-carousel__tabs {
    position: absolute;
    bottom: var(--space-4);
    left: var(--space-8);
    display: inline-flex;
    width: fit-content;
    gap: var(--space-4);
    z-index: 3;
    background: color-mix(in srgb, var(--color-surface) 70%, transparent);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    padding: var(--space-3) var(--space-4);
    border-radius: 2px;
  }

  .hero-carousel__tab {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-text);
    padding: var(--space-2) 0;
    min-width: 120px;
  }

  .hero-carousel__tab-title {
    display: block;
    font-size: var(--type-sm);
    font-weight: var(--weight-regular);
    text-align: left;
    margin-bottom: var(--space-1);
    opacity: 0.5;
  }

  .hero-carousel__tab--active .hero-carousel__tab-title {
    opacity: 1;
    font-weight: var(--weight-bold);
  }

  .hero-carousel__tab-progress {
    height: 2px;
    background: var(--color-decorative);
    width: 100%;
  }

  .hero-carousel__tab-fill {
    height: 100%;
    background: var(--color-text);
    width: 0%;
  }

  .hero-carousel__tab--active .hero-carousel__tab-fill {
    width: 100%;
  }

  .hero-carousel__cta {
    position: absolute;
    bottom: 40%;
    left: var(--space-8);
    z-index: 3;
    display: inline-flex;
    align-items: center;
    padding: var(--space-3) var(--space-6);
    text-decoration: none;
    font-size: var(--type-md);
  }

  @media (max-width: 767px) {
    .hero-carousel__images {
      grid-template-columns: repeat(6, 1fr);
      grid-template-rows: 60px 60px 120px 120px 120px 60px 60px 120px;
      left: -10vw;
      right: -10vw;
      width: 120vw;
    }

    .hero-carousel__image-slot {
      aspect-ratio: auto;
    }

    /* Mobile: reposition images — !important overrides inline grid styles */
    .hero-carousel__image-slot:nth-child(1) {
      grid-column: 1 / 5 !important;
      grid-row: 2 / 5 !important;
    }
    .hero-carousel__image-slot:nth-child(2) {
      grid-column: 2 / 6 !important;
      grid-row: 4 / 7 !important;
    }
    .hero-carousel__image-slot:nth-child(3) {
      grid-column: 4 / 7 !important;
      grid-row: 3 / 7 !important;
    }

    .hero-carousel__text {
      padding-right: var(--space-4);
    }

    .hero-carousel__tabs {
      display: none;
    }

    .hero-carousel__cta {
      bottom: calc(var(--space-16) + 50px);
      left: var(--space-4);
    }
  }
</style>
