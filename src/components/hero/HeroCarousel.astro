---
// HeroCarousel.astro -- Stub: will be fully implemented in Plan 02-02
// D-01 through D-06: Hero carousel with right-aligned typography and scattered images

interface Props {
  slides: Array<{
    id: string;
    title: { de: string; en: string };
    subtitle?: { de: string; en: string };
    cta: { label: { de: string; en: string }; href: string };
    images: Array<{
      src: string;
      alt: { de: string; en: string };
      gridCol: string;
      gridRow: string;
    }>;
  }>;
  lang: 'en' | 'de';
  uiStrings: any;
}

const { slides, lang } = Astro.props;
const activeSlide = slides[0];
---

<section class="hero-pinned" aria-roledescription="carousel" aria-label="Featured exhibitions">
  <div class="hero-carousel">
    {/* Exhibition images -- scattered behind text */}
    <div class="hero-carousel__images">
      {activeSlide?.images.map((img) => (
        <div class="hero-carousel__image-slot" style={`grid-column: ${img.gridCol}; grid-row: ${img.gridRow};`}>
          <img src={img.src} alt={img.alt[lang]} loading="eager" />
        </div>
      ))}
    </div>

    {/* Large right-aligned typography */}
    <div class="hero-carousel__text">
      <h1 class="hero-carousel__title">
        <span>KUNST</span>
        <span>HAUS</span>
        <span>ZURICH</span>
      </h1>
    </div>

    {/* Carousel progress tabs */}
    <nav class="hero-carousel__tabs" aria-label="Exhibition slides">
      {slides.map((slide, i) => (
        <button
          class:list={['hero-carousel__tab', { 'hero-carousel__tab--active': i === 0 }]}
          role="group"
          aria-roledescription="slide"
          aria-label={`${i + 1} of ${slides.length}: ${slide.title[lang]}`}
        >
          <span class="hero-carousel__tab-title">{slide.title[lang]}</span>
          <div class="hero-carousel__tab-progress">
            <div class="hero-carousel__tab-fill" />
          </div>
        </button>
      ))}
    </nav>

    {/* CTA */}
    {activeSlide?.cta && (
      <a href={activeSlide.cta.href} class="hero-carousel__cta hover-wipe-inverse touch-pulse touch-target">
        <span>{activeSlide.cta.label[lang]}</span>
      </a>
    )}
  </div>
</section>

<style>
  .hero-carousel {
    position: relative;
    width: 100%;
    height: 100vh;
    overflow: hidden;
    background: var(--color-surface);
  }

  .hero-carousel__images {
    position: absolute;
    inset: 0;
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    grid-template-rows: repeat(8, 1fr);
    z-index: 1;
  }

  .hero-carousel__image-slot {
    overflow: hidden;
  }

  .hero-carousel__image-slot img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-carousel__text {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding-right: var(--space-12);
    z-index: 2;
  }

  .hero-carousel__title {
    display: flex;
    flex-direction: column;
    text-align: right;
    font-size: clamp(var(--type-3xl), 8vw, var(--type-4xl));
    font-weight: var(--weight-bold);
    line-height: var(--leading-tight);
    text-transform: uppercase;
    color: var(--color-text);
  }

  .hero-carousel__tabs {
    position: absolute;
    bottom: var(--space-12);
    left: var(--space-8);
    display: flex;
    gap: var(--space-4);
    z-index: 3;
  }

  .hero-carousel__tab {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-text);
    padding: var(--space-2) 0;
    min-width: 120px;
  }

  .hero-carousel__tab-title {
    display: block;
    font-size: var(--type-sm);
    font-weight: var(--weight-regular);
    text-align: left;
    margin-bottom: var(--space-1);
    opacity: 0.5;
  }

  .hero-carousel__tab--active .hero-carousel__tab-title {
    opacity: 1;
    font-weight: var(--weight-bold);
  }

  .hero-carousel__tab-progress {
    height: 2px;
    background: var(--color-decorative);
    width: 100%;
  }

  .hero-carousel__tab-fill {
    height: 100%;
    background: var(--color-text);
    width: 0%;
  }

  .hero-carousel__tab--active .hero-carousel__tab-fill {
    width: 100%;
  }

  .hero-carousel__cta {
    position: absolute;
    bottom: var(--space-12);
    right: var(--space-8);
    z-index: 3;
    display: inline-flex;
    align-items: center;
    padding: var(--space-3) var(--space-6);
    text-decoration: none;
    font-size: var(--type-md);
  }

  @media (max-width: 767px) {
    .hero-carousel__text {
      padding-right: var(--space-4);
    }

    .hero-carousel__tabs {
      display: none;
    }

    .hero-carousel__cta {
      bottom: var(--space-8);
      right: var(--space-4);
    }
  }
</style>
