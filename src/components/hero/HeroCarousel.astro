---
// HeroCarousel.astro -- D-01 through D-06, D-41: Hero section with carousel
// Monumental right-aligned KUNST/HAUS/ZURICH typography, scattered images,
// auto-play with progress tabs, pause/play toggle, ARIA carousel pattern

import HeroSlide from './HeroSlide.astro';
import CarouselTabs from './CarouselTabs.astro';
import GridOverlay from '../GridOverlay.tsx';

interface Props {
  slides: Array<{
    id: string;
    title: { de: string; en: string };
    subtitle?: { de: string; en: string };
    cta: { label: { de: string; en: string }; href: string };
    images: Array<{
      src: string;
      alt: { de: string; en: string };
      gridCol: string;
      gridRow: string;
    }>;
  }>;
  lang: 'en' | 'de';
  uiStrings: any;
}

const { slides, lang, uiStrings } = Astro.props;

// Get pause/play labels from ui-strings
const getString = (key: string) => {
  const entry = uiStrings.find((s: any) => s.key === key);
  return entry?.value?.[lang] || key;
};
const pauseLabel = getString('carousel-pause');
const playLabel = getString('carousel-play');
---

<section class="hero-pinned" aria-roledescription="carousel" aria-label="Featured exhibitions">
  <div class="hero-carousel">
    {/* Grid overlay — background layer */}
    <GridOverlay client:only="react" />

    {/* Slides container */}
    <div class="hero-carousel__slides">
      {slides.map((slide, i) => (
        <HeroSlide
          images={slide.images}
          subtitle={slide.subtitle}
          cta={slide.cta}
          lang={lang}
          index={i}
          total={slides.length}
          title={slide.title}
          isActive={i === 0}
        />
      ))}
    </div>

    {/* Large right-aligned typography -- topmost z-index within hero */}
    <div class="hero-carousel__text">
      <h1 class="hero-carousel__title">
        <span>KUNST</span>
        <span>HAUS</span>
        <span>ZURICH</span>
      </h1>
    </div>

    {/* Gradient scrim for tab/CTA legibility */}
    <div class="hero-carousel__scrim" aria-hidden="true"></div>

    {/* Carousel progress tabs with pause/counter */}
    <CarouselTabs slides={slides} lang={lang} pauseLabel={pauseLabel} playLabel={playLabel} />

    {/* Live region for screen readers */}
    <div class="sr-only" aria-live="polite" aria-atomic="true" id="carousel-live-region">
    </div>
  </div>
</section>

<style>
  .hero-carousel {
    position: relative;
    width: 100%;
    height: 85vh;
    min-height: 500px;
    overflow: hidden;
    background: var(--color-surface);
  }

  .hero-carousel__slides {
    position: absolute;
    inset: 0;
  }

  /* Typography (D-01): right-aligned, three lines, topmost layer */
  .hero-carousel__text {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: flex-end;
    mix-blend-mode: multiply;
    padding-right: var(--space-12);
    z-index: 5;
    pointer-events: none;
  }

  .hero-carousel__title {
    display: flex;
    flex-direction: column;
    text-align: right;
    font-size: clamp(var(--type-4xl), 11vw, 9rem);
    font-weight: var(--weight-bold);
    line-height: var(--leading-tight);
    text-transform: uppercase;
    color: var(--color-text);
  }

  /* Onsite mode: screen blend for dark bg */
  html[data-mode="onsite"] .hero-carousel__text {
    mix-blend-mode: screen !important;
  }

  .hero-carousel__scrim {
    display: none;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  @media (max-width: 767px) {
    .hero-carousel {
      height: 100vh;
    }

    .hero-carousel__text {
      align-items: flex-start;
      justify-content: flex-end;
      padding-right: var(--space-4);
      padding-top: 100px;
    }
  }
</style>

<script>
  import { gsap } from 'gsap';

  function initHeroCarousel() {
    const carousel = document.querySelector('[aria-roledescription="carousel"]');
    if (!carousel) return;

    const slides = carousel.querySelectorAll('[data-slide-index]');
    const tabs = carousel.querySelectorAll('[data-tab]');
    const fills = carousel.querySelectorAll('[data-tab-fill]');
    const pauseBtn = document.getElementById('carousel-pause-btn');
    const liveRegion = document.getElementById('carousel-live-region');
    const counter = document.getElementById('carousel-counter');
    const subtitleEl = document.getElementById('carousel-subtitle');
    const slideData = (window as any).__carouselSlideData || [];
    const slideCount = slides.length;

    const mobileTabsEl = document.getElementById('carousel-tabs-mobile');

    const mobileCounter = document.getElementById('carousel-counter-mobile');
    const mobileTitle = document.getElementById('carousel-title-mobile');
    const mobileTabs = document.querySelectorAll('[data-mobile-tab]');
    const mobileFills = document.querySelectorAll('[data-mobile-fill]');
    const mobileTitles = Array.from(tabs).map(tab =>
      tab.querySelector('.carousel-tabs__title')?.textContent || ''
    );

    if (slideCount <= 1) return;

    const SLIDE_DURATION = 5; // seconds per slide
    const WELCOME_TEXT = 'Welcome to the Kunsthaus';
    let currentIndex = -1; // -1 = empty/welcome state
    let isPaused = false;

    // Start with everything hidden — empty welcome state
    slides.forEach((slide) => {
      const el = slide as HTMLElement;
      el.style.opacity = '0';
      el.style.pointerEvents = 'none';
      el.classList.remove('hero-slide--active');
      const images = el.querySelectorAll('.hero-slide__image-slot');
      gsap.set(images, { opacity: 0, scale: 1.35 });
    });
    tabs.forEach((tab) => {
      tab.classList.remove('carousel-tabs__tab--active');
      const title = tab.querySelector('.carousel-tabs__title') as HTMLElement;
      if (title) gsap.set(title, { opacity: 0.5 });
    });
    fills.forEach((fill) => gsap.set(fill, { scaleX: 0 }));
    mobileFills.forEach((fill) => gsap.set(fill, { scaleX: 0 }));
    if (subtitleEl) subtitleEl.textContent = WELCOME_TEXT;
    if (counter) counter.textContent = '';
    if (mobileCounter) mobileCounter.textContent = '';
    if (mobileTitle) mobileTitle.textContent = WELCOME_TEXT;

    // Build GSAP timeline for auto-play
    const tl = gsap.timeline({ repeat: -1 });

    // Get all tab title elements
    const tabTitles = Array.from(tabs).map(tab =>
      tab.querySelector('.carousel-tabs__title') as HTMLElement
    );

    // Phase 0: Empty welcome state
    tl.call(() => clearToWelcome());
    tl.to({}, { duration: SLIDE_DURATION }); // hold for same duration

    // Phases 1–N: Actual slides
    for (let i = 0; i < slideCount; i++) {
      const fill = fills[i] as HTMLElement;
      const mFill = mobileFills[i] as HTMLElement;
      const title = tabTitles[i];
      const nextTitle = tabTitles[i + 1] || tabTitles[0];

      // Show slide i
      tl.call(() => activateSlide(i));

      // Animate fill bar (desktop + mobile in sync)
      const fillStart = tl.duration();
      tl.fromTo(
        fill,
        { scaleX: 0 },
        { scaleX: 1, duration: SLIDE_DURATION, ease: 'none' },
      );
      if (mFill) {
        tl.fromTo(
          mFill,
          { scaleX: 0 },
          { scaleX: 1, duration: SLIDE_DURATION, ease: 'none' },
          fillStart,
        );
      }

      // Near end of fill, start fading out current title
      tl.to(title, { opacity: 0.5, duration: 0.4, ease: 'power2.inOut' }, `-=0.5`);
      if (i < slideCount - 1) {
        tl.to(nextTitle, { opacity: 0.8, duration: 0.4, ease: 'power2.inOut' }, `-=0.4`);
      }

      // Reset fill after transition
      if (i < slideCount - 1) {
        tl.call(() => {
          gsap.to(fill, { scaleX: 0, duration: 0.3, ease: 'power2.out' });
          if (mFill) gsap.to(mFill, { scaleX: 0, duration: 0.3, ease: 'power2.out' });
        });
      }
    }

    // After last slide: reset fills and return to welcome
    tl.call(() => {
      const lastFill = fills[slideCount - 1] as HTMLElement;
      const lastMFill = mobileFills[slideCount - 1] as HTMLElement;
      gsap.to(lastFill, { scaleX: 0, duration: 0.3, ease: 'power2.out' });
      if (lastMFill) gsap.to(lastMFill, { scaleX: 0, duration: 0.3, ease: 'power2.out' });
    });

    function clearToWelcome() {
      currentIndex = -1;

      // Hide all slides
      slides.forEach((slide) => {
        const el = slide as HTMLElement;
        gsap.to(el, { opacity: 0, duration: 0.6, ease: 'power2.out' });
        el.style.pointerEvents = 'none';
        el.classList.remove('hero-slide--active');
      });

      // Deactivate all tabs
      tabs.forEach((tab) => {
        tab.classList.remove('carousel-tabs__tab--active');
        const title = tab.querySelector('.carousel-tabs__title') as HTMLElement;
        if (title) gsap.to(title, { opacity: 0.5, duration: 0.5, ease: 'power2.out' });
        const fill = fills[Array.from(tabs).indexOf(tab)] as HTMLElement;
        gsap.to(fill, { scaleX: 0, duration: 0.3, ease: 'power2.out' });
      });

      // Reset mobile tabs
      mobileTabs.forEach((tab, i) => {
        tab.classList.remove('carousel-tabs-mobile__segment--active');
        const fill = mobileFills[i] as HTMLElement;
        gsap.set(fill, { scaleX: 0 });
      });

      // Update text
      if (subtitleEl) subtitleEl.textContent = WELCOME_TEXT;
      if (counter) counter.textContent = '';
      if (mobileCounter) mobileCounter.textContent = '';
      if (mobileTitle) {
        gsap.to(mobileTitle, {
          opacity: 0, duration: 0.15,
          onComplete: () => {
            mobileTitle.textContent = WELCOME_TEXT;
            gsap.to(mobileTitle, { opacity: 1, duration: 0.25 });
          },
        });
      }
      if (liveRegion) liveRegion.textContent = 'Welcome to the Kunsthaus';
    }

    function activateSlide(index: number) {
      currentIndex = index;

      // Stacking mode: previous slides stay visible, new ones drop on top
      slides.forEach((slide, i) => {
        const el = slide as HTMLElement;
        const images = el.querySelectorAll('.hero-slide__image-slot');

        if (i <= index) {
          // Show this slide and keep it visible
          el.classList.add('hero-slide--active');
          el.style.opacity = '1';
          el.style.pointerEvents = i === index ? 'auto' : 'none';
          // Bump z-index so later slides stack on top
          el.style.zIndex = String(i);

          // Only show CTA on the active slide, hide on previous
          const cta = el.querySelector('.hero-slide__cta') as HTMLElement;
          if (cta) {
            cta.style.display = i === index ? '' : 'none';
          }

          if (i === index) {
            // Animate new slide's images dropping in
            gsap.set(images, { opacity: 0, scale: 1.35 });
            gsap.to(images, {
              opacity: 1,
              scale: 1,
              duration: 1.4,
              ease: 'power3.out',
              stagger: 0.4,
            });
          }
          // Previous slides' images stay as they are
        } else {
          // Future slides: hidden and reset
          el.classList.remove('hero-slide--active');
          el.style.opacity = '0';
          el.style.pointerEvents = 'none';
          gsap.set(images, { opacity: 0, scale: 1.35 });
        }
      });

      // On first slide (after welcome), reset all slides so stack starts fresh
      if (index === 0) {
        slides.forEach((slide, i) => {
          const el = slide as HTMLElement;
          if (i > 0) {
            el.style.opacity = '0';
            el.style.pointerEvents = 'none';
            el.classList.remove('hero-slide--active');
            const images = el.querySelectorAll('.hero-slide__image-slot');
            gsap.set(images, { opacity: 0, scale: 1.35 });
          }
        });
      }

      // Toggle tabs with smooth title transitions
      tabs.forEach((tab, i) => {
        const title = tab.querySelector('.carousel-tabs__title') as HTMLElement;
        if (i === index) {
          tab.classList.add('carousel-tabs__tab--active');
          if (title) {
            gsap.to(title, { opacity: 1, duration: 0.5, ease: 'power2.out' });
          }
        } else {
          tab.classList.remove('carousel-tabs__tab--active');
          if (title) {
            gsap.to(title, { opacity: 0.5, duration: 0.5, ease: 'power2.out' });
          }
          // Reset inactive fills
          const fill = fills[i] as HTMLElement;
          gsap.to(fill, { scaleX: 0, duration: 0.3, ease: 'power2.out' });
        }
      });

      // Update counter
      if (counter) {
        counter.textContent = `${index + 1}/${slideCount}`;
      }

      // Update mobile condensed tabs
      if (mobileCounter) {
        mobileCounter.textContent = `${String(index + 1).padStart(2, '0')}/${String(slideCount).padStart(2, '0')}`;
      }
      if (mobileTitle) {
        gsap.to(mobileTitle, {
          opacity: 0,
          duration: 0.15,
          onComplete: () => {
            mobileTitle.textContent = mobileTitles[index] || '';
            gsap.to(mobileTitle, { opacity: 1, duration: 0.25 });
          },
        });
      }
      // Sync mobile progress segments — only active bar fills, rest are empty
      mobileTabs.forEach((tab, i) => {
        tab.classList.toggle('carousel-tabs-mobile__segment--active', i === index);
        const fill = mobileFills[i] as HTMLElement;
        if (i !== index) {
          gsap.set(fill, { scaleX: 0 });
        }
      });

      // Update subtitle
      const data = slideData[index];
      if (data && subtitleEl) {
        subtitleEl.textContent = data.subtitle;
      }

      // Update live region
      if (liveRegion) {
        const title = tabs[index]?.querySelector('.carousel-tabs__title')?.textContent || '';
        liveRegion.textContent = `Slide ${index + 1} of ${slideCount}: ${title}`;
      }
    }

    // Tab click: jump to slide (offset by welcome phase duration)
    tabs.forEach((tab, i) => {
      tab.addEventListener('click', () => {
        const seekTime = SLIDE_DURATION + (i * SLIDE_DURATION);
        tl.seek(seekTime);
        activateSlide(i);
        if (isPaused) tl.pause();
      });
    });

    // Mobile tab click: jump to slide
    mobileTabs.forEach((tab, i) => {
      tab.addEventListener('click', () => {
        const seekTime = SLIDE_DURATION + (i * SLIDE_DURATION);
        tl.seek(seekTime);
        activateSlide(i);
        if (isPaused) tl.pause();
      });
    });

    // Pause/play toggle (D-05, WCAG 2.2.2)
    if (pauseBtn) {
      const pauseLabel = pauseBtn.dataset.pauseLabel || 'Pause slideshow';
      const playLabel = pauseBtn.dataset.playLabel || 'Play slideshow';

      pauseBtn.addEventListener('click', () => {
        isPaused = !isPaused;
        if (isPaused) {
          tl.pause();
          pauseBtn.classList.add('is-paused');
          pauseBtn.setAttribute('aria-label', playLabel);
        } else {
          tl.resume();
          pauseBtn.classList.remove('is-paused');
          pauseBtn.setAttribute('aria-label', pauseLabel);
        }
      });
    }

    // Auto-pause on prefers-reduced-motion
    const motionQuery = window.matchMedia('(prefers-reduced-motion: reduce)');
    if (motionQuery.matches) {
      tl.pause();
      isPaused = true;
      pauseBtn?.classList.add('is-paused');
      pauseBtn?.setAttribute('aria-label', pauseBtn?.dataset.playLabel || 'Play slideshow');
    }
    motionQuery.addEventListener('change', (e) => {
      if (e.matches && !isPaused) {
        tl.pause();
        isPaused = true;
        pauseBtn?.classList.add('is-paused');
        pauseBtn?.setAttribute('aria-label', pauseBtn?.dataset.playLabel || 'Play slideshow');
      }
    });

    // Auto-pause on keyboard focus within carousel
    carousel.addEventListener('focusin', () => {
      if (!isPaused) {
        tl.pause();
        isPaused = true;
        pauseBtn?.classList.add('is-paused');
        pauseBtn?.setAttribute('aria-label', pauseBtn?.dataset.playLabel || 'Play slideshow');
      }
    });
  }

  document.addEventListener('DOMContentLoaded', initHeroCarousel);
</script>
