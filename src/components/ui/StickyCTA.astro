---
// StickyCTA.astro -- D-18, D-19, D-21: Floating buttons (desktop) / sticky bottom bar (mobile)
// Segmented mode toggle + Tickets button
// ModeToggle React island for data-mode switching with localStorage persistence

import ModeToggle from './ModeToggle.tsx';

interface Props {
  modeLabels: {
    planning?: string;
    onsite?: string;
  };
  ticketsLabel?: string;
  lang: 'en' | 'de';
  ticketsHref?: string;
}

const { modeLabels, ticketsLabel = 'Buy Tickets', lang, ticketsHref = 'https://www.kunsthaus.ch/tickets' } = Astro.props;

// Build labels object for ModeToggle React island
const toggleLabels = {
  planning: { en: 'Plan a visit', de: 'Besuch planen', fr: 'Planifier' },
  onsite: { en: "I'm here", de: 'Ich bin da', fr: 'Je suis ici' },
};
---

{/* Desktop: floating buttons bottom-right */}
<div class="sticky-cta sticky-cta--desktop">
  <a
    href={ticketsHref}
    target="_blank"
    rel="noopener"
    class="sticky-cta__tickets hover-wipe-inverse touch-pulse touch-target"
  >
    <span>{ticketsLabel}</span>
    <span class="icon">chevron_right</span>
  </a>
  <div class="sticky-cta__toggle" role="radiogroup" aria-label="Site mode">
    <button
      class="sticky-cta__segment sticky-cta__segment--active"
      data-mode-segment="planning"
      role="radio"
      aria-checked="true"
    >
      {modeLabels.planning || 'Plan a visit'}
    </button>
    <button
      class="sticky-cta__segment"
      data-mode-segment="onsite"
      role="radio"
      aria-checked="false"
    >
      {modeLabels.onsite || "I'm here"}
    </button>
  </div>
</div>

{/* Mobile: sticky bottom bar */}
<div class="sticky-cta sticky-cta--mobile">
  <a
    href={ticketsHref}
    target="_blank"
    rel="noopener"
    class="sticky-cta__tickets hover-wipe-inverse touch-pulse touch-target"
  >
    <span>{ticketsLabel}</span>
    <span class="icon">chevron_right</span>
  </a>
  <div class="sticky-cta__toggle" role="radiogroup" aria-label="Site mode">
    <button
      class="sticky-cta__segment sticky-cta__segment--active"
      data-mode-segment="planning"
      role="radio"
      aria-checked="true"
    >
      {modeLabels.planning || 'Plan a visit'}
    </button>
    <button
      class="sticky-cta__segment"
      data-mode-segment="onsite"
      role="radio"
      aria-checked="false"
    >
      {modeLabels.onsite || "I'm here"}
    </button>
  </div>
</div>

{/* ModeToggle React island -- hidden, provides localStorage + data-mode sync */}
<div class="sticky-cta__react-toggle" style="display:none;">
  <ModeToggle client:load labels={toggleLabels} lang={lang} />
</div>

<script>
  function initStickyCTA() {
    // Segmented toggle click handler
    document.querySelectorAll('[data-mode-segment]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const mode = (btn as HTMLElement).dataset.modeSegment;
        if (!mode) return;

        // Update HTML mode attribute + localStorage
        document.documentElement.setAttribute('data-mode', mode);
        localStorage.setItem('kunsthaus-mode', mode);

        // Update all toggle segments across desktop + mobile
        document.querySelectorAll('[data-mode-segment]').forEach((seg) => {
          const el = seg as HTMLElement;
          const isActive = el.dataset.modeSegment === mode;
          el.classList.toggle('sticky-cta__segment--active', isActive);
          el.setAttribute('aria-checked', isActive ? 'true' : 'false');
        });
      });
    });

    // Initialize from localStorage
    const saved = localStorage.getItem('kunsthaus-mode');
    if (saved) {
      document.documentElement.setAttribute('data-mode', saved);
      document.querySelectorAll('[data-mode-segment]').forEach((seg) => {
        const el = seg as HTMLElement;
        const isActive = el.dataset.modeSegment === saved;
        el.classList.toggle('sticky-cta__segment--active', isActive);
        el.setAttribute('aria-checked', isActive ? 'true' : 'false');
      });
    }

    // Hide sticky CTA when footer is visible
    const footer = document.querySelector('.site-footer');
    if (footer) {
      const observer = new IntersectionObserver(
        ([entry]) => {
          document.querySelectorAll('.sticky-cta').forEach((el) => {
            (el as HTMLElement).style.opacity = entry.isIntersecting ? '0' : '1';
            (el as HTMLElement).style.pointerEvents = entry.isIntersecting ? 'none' : 'auto';
          });
        },
        { threshold: 0.1 }
      );
      observer.observe(footer);
    }
  }

  initStickyCTA();
  document.addEventListener('astro:after-swap', initStickyCTA);
</script>

<style>
  /* Segmented toggle */
  .sticky-cta__toggle {
    display: flex;
    border: 1px solid var(--color-text);
    border-radius: 2px;
    overflow: hidden;
  }

  .sticky-cta__segment {
    background: transparent;
    color: var(--color-text);
    border: none;
    padding: var(--space-3) var(--space-4);
    font-size: var(--type-sm);
    font-weight: var(--weight-regular);
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.2s ease, color 0.2s ease;
  }

  .sticky-cta__segment--active {
    background: var(--color-text);
    color: var(--color-surface);
    font-weight: var(--weight-medium);
  }

  .sticky-cta__segment:not(.sticky-cta__segment--active):hover {
    background: color-mix(in srgb, var(--color-text) 10%, transparent);
  }

  /* Desktop floating buttons */
  .sticky-cta--desktop {
    position: fixed;
    bottom: var(--space-8);
    right: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    z-index: 50;
    align-items: flex-end;
    transition: opacity 0.3s ease;
  }

  .sticky-cta--mobile {
    display: none;
  }

  .sticky-cta__tickets {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-3) var(--space-6);
    text-decoration: none;
    font-size: var(--type-md);
    font-weight: var(--weight-medium);
    white-space: nowrap;
  }

  /* Mobile: sticky bottom bar */
  @media (max-width: 1023px) {
    .sticky-cta--desktop {
      display: none;
    }

    .sticky-cta--mobile {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: var(--space-3) var(--space-4);
      background: var(--color-surface);
      border-top: 1px solid var(--color-decorative);
      z-index: 50;
      transition: opacity 0.3s ease;
    }
  }

  @media (min-width: 1024px) {
    .sticky-cta--mobile {
      display: none;
    }
  }
</style>
