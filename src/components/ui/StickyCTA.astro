---
// StickyCTA.astro -- D-18, D-19, D-21: Floating button (desktop) / sticky bottom bar (mobile)
// Tickets CTA only. The mode toggle lives in HamburgerOverlay + FooterColumns as
// route-aware <a href> navigation (Phase 03-01 URL-as-state refactor).

interface Props {
  modeLabels: {
    planning?: string;
    onsite?: string;
  };
  ticketsLabel?: string;
  lang: 'en' | 'de';
  ticketsHref?: string;
}

const { ticketsLabel = 'Buy Tickets', ticketsHref = 'https://www.kunsthaus.ch/tickets' } = Astro.props;
---

{/* Desktop: floating button bottom-right */}
<div class="sticky-cta sticky-cta--desktop">
  <a
    href={ticketsHref}
    target="_blank"
    rel="noopener"
    class="sticky-cta__tickets btn brushed-brass touch-pulse touch-target"
  >
    <span data-i18n-de="Tickets kaufen" data-i18n-en="Buy Tickets">{ticketsLabel}</span>
    <span class="icon">arrow_forward</span>
  </a>
</div>

{/* Mobile: sticky bottom bar */}
<div class="sticky-cta sticky-cta--mobile">
  <a
    href={ticketsHref}
    target="_blank"
    rel="noopener"
    class="sticky-cta__tickets btn brushed-brass touch-pulse touch-target"
  >
    <span data-i18n-de="Tickets kaufen" data-i18n-en="Buy Tickets">{ticketsLabel}</span>
    <span class="icon">arrow_forward</span>
  </a>
</div>

<script>
  function initStickyCTA() {
    // Hide sticky CTA when footer is visible
    const footer = document.querySelector('.site-footer');
    if (!footer) return;
    const observer = new IntersectionObserver(
      ([entry]) => {
        document.querySelectorAll('.sticky-cta').forEach((el) => {
          (el as HTMLElement).style.opacity = entry.isIntersecting ? '0' : '1';
          (el as HTMLElement).style.pointerEvents = entry.isIntersecting ? 'none' : 'auto';
        });
      },
      { threshold: 0.1 }
    );
    observer.observe(footer);
  }

  initStickyCTA();
  document.addEventListener('astro:page-load', initStickyCTA);
</script>

<style>
  /* Desktop floating buttons */
  .sticky-cta--desktop {
    position: fixed;
    bottom: var(--space-8);
    right: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    z-index: 50;
    align-items: stretch;
    transition: opacity 0.3s ease;
  }

  .sticky-cta--mobile {
    display: none;
  }

  .sticky-cta__tickets {
    justify-content: center;
  }

  /* Mobile: sticky bottom bar */
  @media (max-width: 1023px) {
    .sticky-cta--desktop {
      display: none;
    }

    .sticky-cta--mobile {
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      display: flex;
      justify-content: center;
      align-items: center;
      padding: var(--space-3) var(--space-4);
      background: transparent;
      border-top: none;
      z-index: 50;
      transition: opacity 0.3s ease;
    }

    /* Full-width button, centered by its flex parent */
    .sticky-cta--mobile .sticky-cta__tickets {
      width: 100%;
      justify-content: center;
    }
  }

  @media (min-width: 1024px) {
    .sticky-cta--mobile {
      display: none;
    }
  }
</style>
