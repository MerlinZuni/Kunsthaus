---
// ReduceMotionToggle.astro -- D-40: Manual reduce-motion toggle
// Respects OS prefers-reduced-motion as default, user can override via localStorage
// Stores preference in localStorage key 'kunsthaus-reduce-motion'

interface Props {
  lang?: 'en' | 'de';
}

const { lang = 'en' } = Astro.props;
const label = lang === 'de' ? 'Bewegung reduzieren' : 'Reduce motion';
---

<div class="reduce-motion-toggle">
  <label class="reduce-motion-toggle__label touch-target">
    <input
      type="checkbox"
      class="reduce-motion-toggle__input"
      id="reduce-motion-toggle"
      aria-label={label}
    />
    <span class="reduce-motion-toggle__switch" aria-hidden="true"></span>
    <span class="reduce-motion-toggle__text" data-i18n-de="Bewegung reduzieren" data-i18n-en="Reduce motion">{label}</span>
  </label>
</div>

<script>
  function initReduceMotion() {
    const toggle = document.getElementById('reduce-motion-toggle') as HTMLInputElement;
    if (!toggle) return;

    // Check localStorage first (kunsthaus-reduce-motion), then OS preference
    const stored = localStorage.getItem('kunsthaus-reduce-motion');
    const osPrefers = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const shouldReduce = stored !== null ? stored === 'true' : osPrefers;

    toggle.checked = shouldReduce;
    if (shouldReduce) {
      document.documentElement.classList.add('reduce-motion');
    }

    toggle.addEventListener('change', () => {
      const reduced = toggle.checked;
      localStorage.setItem('kunsthaus-reduce-motion', String(reduced));
      document.documentElement.classList.toggle('reduce-motion', reduced);
    });
  }

  initReduceMotion();
  document.addEventListener('astro:after-swap', initReduceMotion);
</script>

<style>
  .reduce-motion-toggle {
    padding: var(--space-4) 0;
  }

  .reduce-motion-toggle__label {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    cursor: pointer;
    font-size: var(--type-sm);
    color: var(--color-text);
  }

  .reduce-motion-toggle__input {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  .reduce-motion-toggle__switch {
    position: relative;
    width: 36px;
    height: 20px;
    background: rgba(255, 255, 255, 0.2);
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: 10px;
    transition: background 200ms ease, border-color 200ms ease;
    flex-shrink: 0;
  }

  .reduce-motion-toggle__switch::after {
    content: '';
    position: absolute;
    top: 2px;
    left: 2px;
    width: 14px;
    height: 14px;
    background: rgba(255, 255, 255, 0.9);
    border-radius: 50%;
    transition: transform 200ms ease, background 200ms ease;
  }

  .reduce-motion-toggle__input:checked + .reduce-motion-toggle__switch {
    background: #22c55e;
    border-color: #22c55e;
  }

  .reduce-motion-toggle__input:checked + .reduce-motion-toggle__switch::after {
    background: rgba(255, 255, 255, 0.9);
  }

  .reduce-motion-toggle__input:checked + .reduce-motion-toggle__switch::after {
    transform: translateX(16px);
  }

  .reduce-motion-toggle__input:focus-visible + .reduce-motion-toggle__switch {
    outline: 2px solid var(--color-text);
    outline-offset: 2px;
  }
</style>
