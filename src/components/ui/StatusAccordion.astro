---
// StatusAccordion.astro — Reusable open/closed status pill with accordion
// Dynamically computes open/closed from schedule data

interface ScheduleDay {
  day: number; // 0=Sun, 1=Mon, 2=Tue, etc.
  label: string;
  open?: string; // "8:00"
  close?: string; // "21:00"
  closed?: boolean;
}

interface Props {
  schedule: ScheduleDay[];
  closedLabel?: string;
  lang?: 'en' | 'de';
  variant?: 'pill' | 'inline';
}

const { schedule, closedLabel = 'Closed today', lang = 'en', variant = 'pill' } = Astro.props;
const openLabel = lang === 'de' ? 'Heute geöffnet bis' : 'Open today until';
---

<div
  class:list={['status-accordion', { 'status-accordion--inline': variant === 'inline' }]}
  data-status-accordion
  data-variant={variant}
  data-schedule={JSON.stringify(schedule)}
  data-open-label={openLabel}
  data-closed-label={closedLabel}
>
  {variant === 'inline' ? (
    <span class="status-accordion__trigger">
      <span class="status-accordion__dot"></span>
      <span class="status-accordion__text">...</span>
    </span>
  ) : (
    <>
      <button class="status-accordion__trigger" aria-expanded="false">
        <span class="status-accordion__dot"></span>
        <span class="status-accordion__text">...</span>
        <svg class="status-accordion__arrow-svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="6 9 12 15 18 9"/>
        </svg>
      </button>
      <div class="status-accordion__panel" aria-hidden="true">
        <dl class="status-accordion__list">
          {schedule.map(day => (
            <div class:list={['status-accordion__row', { 'status-accordion__row--closed': day.closed }]} data-schedule-day={day.day}>
              <dt class="status-accordion__label">{day.label}</dt>
              <dd class="status-accordion__value">{day.closed ? (lang === 'de' ? 'Geschlossen' : 'Closed') : `${day.open} – ${day.close}`}</dd>
            </div>
          ))}
        </dl>
      </div>
    </>
  )}
</div>

<style>
  .status-accordion {
    display: inline-flex;
    flex-direction: column;
    border: 1px solid color-mix(in srgb, var(--color-text) 20%, transparent);
    border-radius: var(--btn-radius);
    background: color-mix(in srgb, var(--color-surface) 60%, transparent);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.4), inset 0 -1px 0 rgba(0, 0, 0, 0.05), 0 1px 3px rgba(0, 0, 0, 0.06);
  }

  .status-accordion__trigger {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: var(--btn-padding-y) 16px;
    background: none;
    border: none;
    cursor: pointer;
    color: var(--color-text);
    font-family: inherit;
    font-size: var(--type-sm);
    font-weight: var(--weight-regular);
    white-space: nowrap;
    line-height: 1;
    width: 100%;
  }

  .status-accordion__text {
    flex: 1;
  }

  .status-accordion__dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .status-accordion__dot--open {
    background: #22c55e;
  }

  .status-accordion__dot--closed {
    background: #b91c1c;
  }

  .status-accordion__arrow-svg {
    margin-left: auto;
    flex-shrink: 0;
    transition: transform 0.25s ease;
  }

  .status-accordion__panel {
    height: 0;
    overflow: hidden;
    padding: 0 16px;
  }

  .status-accordion__list {
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .status-accordion__row {
    display: flex;
    justify-content: space-between;
    gap: var(--space-2);
  }

  .status-accordion__label {
    font-size: var(--type-sm);
    font-weight: var(--weight-regular);
    color: var(--color-text);
  }

  .status-accordion__value {
    font-size: var(--type-sm);
    font-weight: var(--weight-regular);
    color: var(--color-text);
    opacity: 0.7;
    margin: 0;
    text-align: right;
  }

  .status-accordion__row--today {
    background: color-mix(in srgb, var(--color-text) 8%, transparent);
    border-radius: 4px;
    margin: 0 -8px;
    padding: 4px 8px;
  }

  .status-accordion__row--today .status-accordion__label {
    font-weight: var(--weight-medium);
  }

  .status-accordion__row--today .status-accordion__value {
    opacity: 1;
  }

  .status-accordion__row--closed .status-accordion__value {
    color: #b91c1c;
    opacity: 1;
    font-weight: var(--weight-medium);
  }

  /* Inline variant — dot + text only, no pill chrome */
  .status-accordion--inline {
    border: none;
    background: none;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    box-shadow: none;
  }

  .status-accordion--inline .status-accordion__trigger {
    padding: 0;
    cursor: default;
  }

  /* Onsite / dark mode */
  html[data-mode="onsite"] .status-accordion__dot--open {
    background: #4ade80;
  }

  html[data-mode="onsite"] .status-accordion__dot--closed {
    background: #f87171;
  }

  html[data-mode="onsite"] .status-accordion__row--closed .status-accordion__value {
    color: #f87171;
  }

  html[data-mode="onsite"] .status-accordion__row--today {
    background: color-mix(in srgb, var(--color-surface) 15%, transparent);
  }
</style>

<script>
  import { gsap } from 'gsap';

  function initStatusAccordions() {
    document.querySelectorAll('[data-status-accordion]').forEach(accordion => {
      const el = accordion as HTMLElement;
      if (el.dataset.initialized === 'true') return;
      el.dataset.initialized = 'true';
      const trigger = el.querySelector('.status-accordion__trigger');
      const dot = el.querySelector('.status-accordion__dot') as HTMLElement;
      const text = el.querySelector('.status-accordion__text') as HTMLElement;
      const panel = el.querySelector('.status-accordion__panel') as HTMLElement;
      const arrow = el.querySelector('.status-accordion__arrow-svg') as HTMLElement;
      if (!trigger || !dot || !text) return;

      // Parse schedule and compute current status
      const schedule = JSON.parse(el.getAttribute('data-schedule') || '[]');
      const openLabel = el.getAttribute('data-open-label') || 'Open today until';
      const closedLabel = el.getAttribute('data-closed-label') || 'Closed today';

      const now = new Date();
      const today = now.getDay();
      const currentHour = now.getHours();
      const currentMinute = now.getMinutes();

      const todaySchedule = schedule.find((d: any) => d.day === today);
      let isOpen = false;
      let statusText = closedLabel;

      if (todaySchedule && !todaySchedule.closed && todaySchedule.open && todaySchedule.close) {
        const [openH, openM] = todaySchedule.open.split(':').map(Number);
        const [closeH, closeM] = todaySchedule.close.split(':').map(Number);
        const nowMinutes = currentHour * 60 + currentMinute;
        const openMinutes = openH * 60 + (openM || 0);
        const closeMinutes = closeH * 60 + (closeM || 0);

        if (nowMinutes >= openMinutes && nowMinutes < closeMinutes) {
          isOpen = true;
          statusText = `${openLabel} ${todaySchedule.close}`;
        }
      }

      dot.classList.add(isOpen ? 'status-accordion__dot--open' : 'status-accordion__dot--closed');
      text.textContent = statusText;

      // Inline variant — no accordion behavior
      if (el.dataset.variant === 'inline') return;

      // Highlight today's row
      const todayRow = el.querySelector(`[data-schedule-day="${today}"]`);
      if (todayRow) {
        todayRow.classList.add('status-accordion__row--today');
      }

      let expanded = false;

      trigger.addEventListener('click', () => {
        expanded = !expanded;
        trigger.setAttribute('aria-expanded', String(expanded));
        panel.setAttribute('aria-hidden', String(!expanded));

        if (expanded) {
          // Measure natural height
          panel.style.height = 'auto';
          const naturalHeight = panel.scrollHeight;
          panel.style.height = '0px';

          const tl = gsap.timeline();
          tl.to(arrow, {
            rotation: 180,
            duration: 0.25,
            ease: 'power2.out',
          });
          tl.to(panel, {
            height: naturalHeight + 8,
            paddingBottom: 24,
            duration: 0.4,
            ease: 'power2.out',
          }, 0);
        } else {
          const tl = gsap.timeline();
          tl.to(panel, {
            height: 0,
            paddingBottom: 0,
            duration: 0.3,
            ease: 'power2.inOut',
          });
          tl.to(arrow, {
            rotation: 0,
            duration: 0.25,
            ease: 'power2.inOut',
          }, 0);
        }
      });
    });
  }

  // Run on first paint and after every Astro View Transitions navigation.
  // Without astro:page-load the accordion stays at its server-rendered
  // placeholder ("...") on any page reached via ClientRouter.
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initStatusAccordions);
  } else {
    initStatusAccordions();
  }
  document.addEventListener('astro:page-load', initStatusAccordions);
</script>
