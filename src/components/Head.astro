---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
<meta name="generator" content={Astro.generator} />
<title>{title}</title>
<script is:inline>
  // Set reduce-motion class early, before any component scripts run
  (function() {
    var stored = localStorage.getItem('kunsthaus-reduce-motion');
    var osPrefers = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (stored === 'true' || (stored === null && osPrefers)) {
      document.documentElement.classList.add('reduce-motion');
    }
  })();
</script>
