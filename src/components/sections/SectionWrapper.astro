---
// SectionWrapper.astro -- D-25, D-26: Section with stacking scroll and background rotation
// Full implementation with GSAP ScrollTrigger will come in Phase 3

interface Props {
  index: number;
  bgStep: 1 | 2 | 3 | 4;
  sectionName: string;
  sectionId: string;
}

const { index, bgStep, sectionName, sectionId } = Astro.props;
const zIndex = 20 + index;
---

<section
  class="stacking-section section-spacing"
  data-bg-step={bgStep}
  data-section={sectionId}
  id={`section-${sectionId}`}
  style={`z-index: ${zIndex};`}
  aria-label={sectionName}
>
  <div class="section-inner">
    <h2 class="section-title">{sectionName}</h2>
    <slot />
  </div>
</section>

<style>
  .section-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 var(--space-8);
  }

  .section-title {
    font-size: var(--type-xl);
    font-weight: var(--weight-light);
    line-height: var(--leading-tight);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: var(--space-24);
  }

  @media (max-width: 767px) {
    .section-inner {
      padding: 0 var(--space-4);
    }

    .section-title {
      margin-bottom: var(--space-16);
    }
  }
</style>
