---
// SectionWrapper.astro -- D-25, D-26, D-27: Section with stacking scroll and background rotation
// GSAP ScrollTrigger stacking effect: pin, scale, rotate (desktop), scale+opacity (tablet), fade-up (mobile)

interface Props {
  index: number;
  bgStep: 1 | 2 | 3 | 4;
  sectionName: string;
  sectionId: string;
  /** Optional DE translation for client-side language switching */
  sectionNameDe?: string;
}

const { index, bgStep, sectionName, sectionId, sectionNameDe } = Astro.props;
const zIndex = 20 + index;
---

<section
  class="stacking-section section-spacing"
  data-bg-step={bgStep}
  data-section={sectionId}
  data-section-index={index}
  data-section-name={sectionName}
  id={`section-${sectionId}`}
  style={`z-index: ${zIndex};`}
  aria-label={sectionName}
>
  <div class="section-inner">
    <div class="section-layout">
      <div class="section-title-col">
        <h2 class="section-title" {...(sectionNameDe ? { 'data-i18n-de': sectionNameDe, 'data-i18n-en': sectionName } : {})}>{sectionName}</h2>
      </div>
      <div class="section-content-col">
        <slot />
      </div>
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initSectionStacking() {
    // Kill existing ScrollTriggers for stacking sections
    ScrollTrigger.getAll()
      .filter(st => (st.vars as any)._stackingSection)
      .forEach(st => st.kill());

    const sections = gsap.utils.toArray<HTMLElement>('.stacking-section');
    if (!sections.length) return;

    // Check reduced motion preference
    const reduceMotion =
      window.matchMedia('(prefers-reduced-motion: reduce)').matches ||
      document.documentElement.classList.contains('reduce-motion');

    const lastIndex = sections.length - 1;

    if (reduceMotion) {
      // Reduced motion: still pin sections so next slides over, but no transforms
      ScrollTrigger.matchMedia({
        '(min-width: 768px)': function () {
          sections.forEach((section, i) => {
            if (i === lastIndex) return;

            const nextSection = sections[i + 1];

            ScrollTrigger.create({
              trigger: section,
              start: 'bottom bottom',
              endTrigger: nextSection,
              end: 'top top',
              pin: true,
              pinSpacing: false,
              _stackingSection: true,
            } as ScrollTrigger.Vars & { _stackingSection: boolean });
          });

          ScrollTrigger.refresh();
        },
      });

      // Fade in hero backdrop
      const backdrop = document.querySelector('.hero-backdrop') as HTMLElement;
      if (backdrop && sections.length > 0) {
        ScrollTrigger.create({
          trigger: sections[0],
          start: 'top 20%',
          end: 'top top',
          onEnter: () => { backdrop.style.opacity = '1'; },
          onLeaveBack: () => { backdrop.style.opacity = '0'; },
        });
      }

      return;
    }

    const OVERLAP = 300; // px: how far next section overlaps before shrink starts

    ScrollTrigger.matchMedia({
      // Tablet+: scroll through content, then pin, next slides over, then scale down
      // (no rotation, subtle shadow — upright stacking)
      '(min-width: 768px)': function () {
        sections.forEach((section, i) => {
          if (i === lastIndex) return;

          const nextSection = sections[i + 1];

          // Pin once user has scrolled through all content
          // (bottom of section reaches bottom of viewport)
          ScrollTrigger.create({
            trigger: section,
            start: 'bottom bottom',
            endTrigger: nextSection,
            end: `top ${OVERLAP}px`,
            pin: true,
            pinSpacing: false,
            _stackingSection: true,
          } as ScrollTrigger.Vars & { _stackingSection: boolean });

          // Scale down only — no rotation, soft shadow
          ScrollTrigger.create({
            trigger: nextSection,
            start: `top ${OVERLAP}px`,
            end: 'top top',
            scrub: true,
            _stackingSection: true,
            onUpdate: (self) => {
              const progress = self.progress;
              const scale = 1 - progress * 0.08;

              const shadowBlur = progress * 16;
              const shadowOpacity = progress * 0.1;

              gsap.set(section, {
                scale,
                rotation: 0,
                transformOrigin: 'center center',
                boxShadow: `0 ${shadowBlur * 0.4}px ${shadowBlur}px rgba(0, 0, 0, ${shadowOpacity})`,
              });
            },
          } as ScrollTrigger.Vars & { _stackingSection: boolean });
        });

        ScrollTrigger.refresh();
      },

      // Mobile: simple fade-up entrance
      '(max-width: 767px)': function () {
        sections.forEach((section) => {
          gsap.from(section, {
            opacity: 0,
            y: 20,
            scrollTrigger: {
              trigger: section,
              scrub: true,
              start: 'top 60%',
              end: 'top 50%',
              _stackingSection: true,
            } as ScrollTrigger.Vars & { _stackingSection: boolean },
          });
        });

        ScrollTrigger.refresh();
      },
    });

    // Fade in hero backdrop once first section covers the hero
    const backdrop = document.querySelector('.hero-backdrop') as HTMLElement;
    if (backdrop && sections.length > 0) {
      ScrollTrigger.create({
        trigger: sections[0],
        start: 'top 20%',
        end: 'top top',
        scrub: true,
        onUpdate: (self) => {
          gsap.set(backdrop, { opacity: self.progress });
        },
        onLeaveBack: () => {
          gsap.set(backdrop, { opacity: 0 });
        },
      });
    }

    // Dispatch sectionchange events for SectionProgress
    sections.forEach((section, i) => {
      ScrollTrigger.create({
        trigger: section,
        start: 'top center',
        end: 'bottom center',
        onEnter: () => {
          window.dispatchEvent(
            new CustomEvent('sectionchange', { detail: { index: i, name: section.dataset.sectionName } })
          );
        },
        onEnterBack: () => {
          window.dispatchEvent(
            new CustomEvent('sectionchange', { detail: { index: i, name: section.dataset.sectionName } })
          );
        },
      });
    });
  }

  // Initialize on load and after Astro page transitions
  initSectionStacking();
  document.addEventListener('astro:after-swap', initSectionStacking);
</script>

<style>
  .section-inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 var(--space-8);
  }

  .section-layout {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: var(--space-12);
  }

  .section-title-col {
    position: sticky;
    top: var(--space-32);
    align-self: start;
  }

  .section-title {
    font-size: var(--type-xl);
    font-weight: var(--weight-light);
    line-height: var(--leading-tight);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    max-width: 200px;
    hyphens: auto;
    -webkit-hyphens: auto;
    overflow-wrap: break-word;
  }

  .section-content-col {
    min-width: 0;
  }

  @media (max-width: 1023px) {
    .section-layout {
      grid-template-columns: 160px 1fr;
      gap: var(--space-8);
    }

    .section-title {
      max-width: 160px;
    }
  }

  @media (max-width: 767px) {
    .section-inner {
      padding: 0 var(--space-4);
    }

    .section-layout {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    .section-title-col {
      position: relative;
      top: auto;
    }

    .section-title {
      max-width: none;
      margin-bottom: 0;
    }
  }
</style>
