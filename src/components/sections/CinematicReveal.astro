---
// CinematicReveal.astro — Scroll-driven expanding image with overlaid content
// Uses position:sticky + scroll height to create pinned effect without GSAP pin
// Starts small and centered, expands to full browser width, reveals content card

interface Props {
  contentType: string;
  data: {
    title?: { de: string; en: string };
    subtitle?: { de: string; en: string };
    image?: string;
    description?: { de: string; en: string };
    cta?: { label: { de: string; en: string }; href: string };
    tagline?: { de: string; en: string };
  };
  lang: 'en' | 'de';
  imagePosition?: 'left' | 'center' | 'right';
}

const { contentType, data, lang, imagePosition = 'center' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const imageSrc = data.image ? `${base}${data.image}` : '';
---

{/* Scroll container — tall enough to drive the animation */}
<div class="cinematic-reveal" data-cinematic-reveal data-content-type={contentType} data-image-position={imagePosition}>
  {/* Sticky viewport — stays fixed while user scrolls through the tall container */}
  <div class="cinematic-reveal__viewport">
    {/* Tagline — visible beneath small image, covered as it expands */}
    <p class="cinematic-reveal__tagline" set:html={data.tagline?.[lang] || (contentType === 'offerings'
      ? 'Where art meets appetite, culture meets comfort,<br/>and every visit tells a story.'
      : 'Every visit is a chance to see something new<br/>and to learn something unexpected.')} />

    {/* Image frame — GSAP animates width from small to 100vw */}
    <div class="cinematic-reveal__frame">
      <div class="cinematic-reveal__image-wrap">
        {imageSrc ? (
          <img
            src={imageSrc}
            alt={data.title?.[lang] || ''}
            class="cinematic-reveal__img"
            loading="lazy"
          />
        ) : (
          <div class="cinematic-reveal__placeholder" aria-label={data.title?.[lang] || ''}>
            <span class="icon" style="font-size: 48px; opacity: 0.3;">image</span>
          </div>
        )}
      </div>

      {/* Content card — inside frame, positioned relative to image */}
      <div class="cinematic-reveal__card">
        {data.title && (
          <h3 class="cinematic-reveal__title">{data.title[lang]}</h3>
        )}
        {data.description && (
          <p class="cinematic-reveal__description" set:html={data.description[lang]} />
        )}
        {data.cta && (
          <a href={data.cta.href} class="cinematic-reveal__cta btn hover-wipe-inverse touch-pulse touch-target">
            <span>{typeof data.cta.label === 'object' ? data.cta.label[lang] : data.cta.label}</span>
            <span class="icon">arrow_forward</span>
          </a>
        )}
      </div>
    </div>
  </div>
</div>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initCinematicReveal() {
    ScrollTrigger.getAll()
      .filter(st => (st.vars as any)._cinematic)
      .forEach(st => st.kill());

    const reveals = document.querySelectorAll<HTMLElement>('[data-cinematic-reveal]');
    if (!reveals.length) return;

    const reduceMotion =
      window.matchMedia('(prefers-reduced-motion: reduce)').matches ||
      document.documentElement.classList.contains('reduce-motion');

    reveals.forEach((reveal) => {
      const frame = reveal.querySelector('.cinematic-reveal__frame') as HTMLElement;
      const imageWrap = reveal.querySelector('.cinematic-reveal__image-wrap') as HTMLElement;
      const card = reveal.querySelector('.cinematic-reveal__card') as HTMLElement;

      if (!frame || !imageWrap) return;

      // Find the parent section's title to change its color
      const parentSection = reveal.closest('.stacking-section');
      const sectionTitle = parentSection?.querySelector('.section-title') as HTMLElement;

      if (reduceMotion) {
        gsap.set(frame, { maxWidth: 'none', width: '100vw', marginLeft: 'calc(-50vw + 50%)' });
        gsap.set(imageWrap, { clipPath: 'inset(0% 0% 0% 0%)', borderRadius: '0' });
        if (card) gsap.set(card, { opacity: 1, y: 0 });
        return;
      }

      // Initial state: small centered image with crop and uniform radius
      gsap.set(imageWrap, { clipPath: 'inset(10% 6% 10% 6%)', borderRadius: '10px 10px 10px 10px' });
      if (card) gsap.set(card, { opacity: 0, y: 40 });

      // Scrub timeline driven by scroll position through the tall container
      const isMobileView = window.innerWidth < 768;
      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: reveal,
          scrub: 0.3,
          start: isMobileView ? 'top 30%' : 'top 60%',
          end: 'bottom bottom',
          _cinematic: true,
        } as ScrollTrigger.Vars & { _cinematic: boolean },
      });

      // Single continuous clip + radius animation (no jump between phases)
      tl.to(imageWrap, {
        clipPath: 'inset(0% 0% 0% 0%)',
        borderRadius: '0px 0px 0px 0px',
        height: '100vh',
        duration: 0.6,
        ease: 'power1.inOut',
      }, 0);

      // Frame expands to full browser width (starts slightly later)
      tl.to(frame, {
        maxWidth: 'none',
        width: '100vw',
        marginLeft: 'calc(-50vw + 50%)',
        duration: 0.45,
        ease: 'power1.inOut',
      }, 0.15);

      // Section title turns white as image expands over it
      if (sectionTitle) {
        tl.to(sectionTitle, {
          color: '#ffffff',
          duration: 0.1,
          ease: 'none',
        }, 0.35);
      }

      // Phase 3 (0.65–0.8): Content card fades in
      if (card) {
        tl.to(card, {
          opacity: 1,
          y: 0,
          duration: 0.15,
          ease: 'power2.out',
        }, 0.65);
      }

      // Phase 4 (0.8–1.0): Hold — final state visible while user scrolls remainder
    });
  }

  initCinematicReveal();
  document.addEventListener('astro:after-swap', initCinematicReveal);
</script>

<style>
  /* Tall scroll container — height drives the animation duration */
  .cinematic-reveal {
    position: relative;
    height: 250vh;
  }

  /* Sticky viewport — stays in view while user scrolls through container */
  .cinematic-reveal__viewport {
    position: sticky;
    top: 0;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: visible;
  }

  /* Tagline — sits below the image, covered as image expands */
  .cinematic-reveal__tagline {
    position: absolute;
    bottom: 15%;
    left: 0;
    right: 0;
    text-align: center;
    font-size: var(--type-sm);
    font-weight: var(--weight-regular);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text);
    opacity: 0.7;
    z-index: 0;
    pointer-events: none;
  }

  /* Frame — starts at max-width, GSAP expands to 100vw */
  .cinematic-reveal__frame {
    width: 100%;
    max-width: 500px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
    overflow: visible;
  }

  .cinematic-reveal__image-wrap {
    position: relative;
    overflow: hidden;
    height: 30vh;
    will-change: clip-path;
    border-radius: var(--btn-radius);
  }

  .cinematic-reveal__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .cinematic-reveal__placeholder {
    width: 100%;
    height: 100%;
    background: var(--color-decorative);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Content card — vertically centered using inset trick (no transform needed) */
  .cinematic-reveal__card {
    position: absolute;
    right: var(--space-8);
    top: 0;
    bottom: 0;
    margin: auto 0;
    height: fit-content;
    background: white;
    padding: var(--space-8);
    max-width: 440px;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    opacity: 0;
    z-index: 2;
  }

  .cinematic-reveal__title {
    font-size: var(--type-3xl);
    font-weight: var(--weight-bold);
    line-height: 0.98;
    text-transform: uppercase;
    color: #272523;
  }

  .cinematic-reveal__description {
    font-size: var(--type-md);
    font-weight: var(--weight-light);
    line-height: var(--leading-normal);
    color: #272523;
    max-width: 45ch;
  }

  /* CTA — card is always white, so button must stay dark in both modes */
  .cinematic-reveal__cta {
    align-self: stretch;
    justify-content: center;
    margin-top: var(--space-2);
    background: color-mix(in srgb, #272523 75%, transparent);
    color: #fbf8f7;
  }

  .cinematic-reveal__cta:hover {
    background: color-mix(in srgb, #272523 90%, transparent);
  }

  /* Phase 03-03: desktop-only imagePosition variant. Shifts the small
     pre-expansion image frame to the left/right edge of the viewport.
     Once GSAP's timeline runs marginLeft:'calc(-50vw + 50%)' the inline
     style takes over and the image re-centers full-bleed — desired behaviour. */
  @media (min-width: 768px) {
    .cinematic-reveal[data-image-position="left"] .cinematic-reveal__frame {
      margin-left: 0;
      margin-right: auto;
    }
    .cinematic-reveal[data-image-position="right"] .cinematic-reveal__frame {
      margin-left: auto;
      margin-right: 0;
    }
  }

  @media (max-width: 767px) {
    .cinematic-reveal {
      height: 250vh;
    }

    .cinematic-reveal__viewport {
      align-items: flex-start;
      padding-top: 8vh;
    }

    .cinematic-reveal__tagline {
      bottom: auto;
      top: calc(8vh + 25vh + var(--space-6));
    }

    .cinematic-reveal__frame {
      max-width: 75%;
    }

    .cinematic-reveal__image-wrap {
      height: 25vh;
    }

    .cinematic-reveal__card {
      position: absolute;
      right: var(--space-4);
      left: var(--space-4);
      top: 0;
      bottom: 0;
      margin: auto 0;
      height: fit-content;
      max-width: none;
      padding: var(--space-6);
      background: rgba(255, 255, 255, 0.95);
    }
  }
</style>
