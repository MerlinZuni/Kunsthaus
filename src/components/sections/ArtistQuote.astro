---
// ArtistQuote.astro — Phase 03-03 typographic pull-quote block. No JS.

interface Props {
  quote: { de: string; en: string };
  attribution: string;
  lang: 'en' | 'de';
}

const { quote, attribution, lang } = Astro.props;
---

<figure class="artist-quote">
  <blockquote class="artist-quote__text" data-i18n-de={quote.de} data-i18n-en={quote.en}>{quote[lang]}</blockquote>
  <figcaption class="artist-quote__attribution">{attribution}</figcaption>
</figure>

<style>
  .artist-quote {
    max-width: 70ch;
    margin: 0 auto;
    padding-block: var(--space-16);
    text-align: center;
  }

  .artist-quote__text {
    font-size: var(--type-3xl);
    font-weight: var(--weight-light);
    line-height: 1.15;
    color: var(--color-text);
    margin: 0;
  }

  .artist-quote__attribution {
    display: block;
    font-size: var(--type-md);
    color: var(--color-text);
    opacity: 0.7;
    margin-top: var(--space-6);
    letter-spacing: 0.04em;
  }

  @media (max-width: 767px) {
    .artist-quote {
      padding-block: var(--space-10);
    }
    .artist-quote__text {
      font-size: var(--type-2xl);
    }
  }
</style>
