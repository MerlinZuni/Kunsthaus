---
// EventsList.astro — Events & programs list with same row styling as ExhibitionList

import exhibitionsJson from '../../content/planning/exhibitions.json';

interface Props {
  lang: 'en' | 'de';
}

const { lang } = Astro.props;
const data = exhibitionsJson[0];
---

<div class="events-list">
  <ul class="events-list__items">
    {data.events.map((event) => (
      <li class="events-list__row" data-image={event.image ? `${import.meta.env.BASE_URL.replace(/\/$/, '')}${event.image}` : ''}>
        <span class="events-list__row-title">{event.title[lang]}</span>
        <span class="events-list__row-meta">
          <span>{event.dateLabel[lang]}</span>
          <span class="events-list__row-time">{event.time}</span>
        </span>
        <span class="events-list__row-info">
          <span>{event.type[lang]}</span>
          {event.places !== null && (
            <span class="events-list__row-places">
              {lang === 'de' ? `${event.places} Plätze frei` : `${event.places} places left`}
            </span>
          )}
          {event.tags.includes('members-only') && (
            <span class="events-list__tag">
              <span class="icon" style="font-size: 16px;">lock</span>
              {lang === 'de' ? 'Nur Mitglieder' : 'Members Only'}
            </span>
          )}
        </span>
        {event.image && (
          <img class="events-list__row-thumb" src={`${import.meta.env.BASE_URL.replace(/\/$/, '')}${event.image}`} alt="" loading="lazy" />
        )}
      </li>
    ))}
  </ul>

  {/* Floating image preview for desktop */}
  <div class="events-list__preview" aria-hidden="true">
    <img class="events-list__preview-img" src="" alt="" />
  </div>
</div>

<script>
  const list = document.querySelector('.events-list');
  const preview = document.querySelector('.events-list__preview') as HTMLElement;
  const previewImg = document.querySelector('.events-list__preview-img') as HTMLImageElement;
  const rows = document.querySelectorAll('.events-list__row');
  const isMobile = window.matchMedia('(max-width: 767px)').matches;

  if (list && preview && previewImg) {
    if (!isMobile) {
      rows.forEach((row) => {
        row.addEventListener('mouseenter', () => {
          const src = (row as HTMLElement).dataset.image;
          if (src) {
            previewImg.src = src;
            preview.classList.add('events-list__preview--visible');
          }
          row.classList.add('events-list__row--active');
        });
        row.addEventListener('mouseleave', () => {
          preview.classList.remove('events-list__preview--visible');
          row.classList.remove('events-list__row--active');
        });
        row.addEventListener('mousemove', (e) => {
          const ev = e as MouseEvent;
          const rect = list.getBoundingClientRect();
          preview.style.left = `${ev.clientX - rect.left + 20}px`;
          preview.style.top = `${ev.clientY - rect.top - 80}px`;
        });
      });
    } else {
      let activeRow: HTMLElement | null = null;
      const updateActiveRow = () => {
        const viewportCenter = window.innerHeight / 2;
        let closest: HTMLElement | null = null;
        let closestDist = Infinity;
        rows.forEach((row) => {
          const rect = row.getBoundingClientRect();
          const rowCenter = rect.top + rect.height / 2;
          const dist = Math.abs(rowCenter - viewportCenter);
          if (dist < closestDist) { closestDist = dist; closest = row as HTMLElement; }
        });
        if (closest && closest !== activeRow) {
          if (activeRow) activeRow.classList.remove('events-list__row--active');
          closest.classList.add('events-list__row--active');
          activeRow = closest;
        }
      };
      window.addEventListener('scroll', updateActiveRow, { passive: true });
      updateActiveRow();
    }
  }
</script>

<style>
  .events-list {
    position: relative;
  }

  .events-list__items {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .events-list__row {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: var(--space-8);
    align-items: center;
    padding: var(--space-6) 0;
    border-bottom: 1px solid color-mix(in srgb, var(--color-text) 10%, transparent);
    cursor: pointer;
    transition: background 0.3s ease, color 0.3s ease;
  }

  .events-list__row:first-child {
    border-top: 1px solid color-mix(in srgb, var(--color-text) 10%, transparent);
  }

  .events-list__row--active {
    background: var(--color-offwhite);
    margin-left: calc(-1 * var(--space-8));
    margin-right: calc(-1 * var(--space-8));
    padding-left: var(--space-8);
    padding-right: var(--space-8);
  }

  /* Dark mode: reverse — hover becomes darker than the section bg */
  html[data-mode="onsite"] .events-list__row--active {
    background: #0e0d0c;
  }

  /* Floating preview — desktop only */
  .events-list__preview {
    position: absolute;
    pointer-events: none;
    z-index: 10;
    opacity: 0;
    transition: opacity 0.3s ease;
    width: 280px;
  }

  .events-list__preview--visible {
    opacity: 1;
  }

  .events-list__preview-img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: var(--btn-radius);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.15);
  }

  /* Row thumbnail — mobile only */
  .events-list__row-thumb {
    display: none;
  }

  .events-list__row-title {
    font-size: var(--type-md);
    font-weight: var(--weight-light);
    line-height: var(--leading-normal);
  }

  .events-list__row-meta {
    font-size: var(--type-md);
    font-weight: var(--weight-regular);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .events-list__row-time {
    opacity: 0.5;
  }

  .events-list__row-info {
    font-size: var(--type-md);
    font-weight: var(--weight-regular);
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    align-items: flex-end;
  }

  .events-list__row-places {
    opacity: 0.5;
  }

  .events-list__tag {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    font-size: var(--type-sm);
    font-weight: var(--weight-medium);
    padding: var(--space-1) var(--space-3);
    border: 1px solid currentColor;
    border-radius: 10px;
    white-space: nowrap;
    color: var(--color-accent);
  }

  @media (max-width: 767px) {
    .events-list__row {
      position: relative;
      grid-template-columns: 60% 1fr;
      gap: var(--space-2);
      overflow: visible;
    }

    .events-list__row-thumb {
      display: block;
      position: absolute;
      right: -80px;
      top: 50%;
      transform: translateY(-50%);
      width: 55%;
      height: 140%;
      object-fit: cover;
      border-radius: 4px 0 0 4px;
      opacity: 0;
      transition: opacity 0.4s ease;
    }

    .events-list__row--active .events-list__row-thumb {
      opacity: 1;
    }

    .events-list__row-title,
    .events-list__row-meta,
    .events-list__row-info {
      grid-column: 1;
      position: relative;
      z-index: 1;
    }

    .events-list__row-info {
      align-items: flex-start;
    }
  }
</style>
