---
// OnsiteExhibitionGrid.astro — Responsive 2/3/4-col grid for one building group.

import LayeredHoverCard from '../ui/LayeredHoverCard.astro';

interface Item {
  id: string;
  title: { de: string; en: string };
  image: string;
  location?: { building: string; floor: string };
  dateLabel?: { de: string; en: string };
}

interface Props {
  heading: { de: string; en: string };
  items: Item[];
  lang: 'en' | 'de';
}

const { heading, items, lang } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section class="onsite-grid">
  <header class="onsite-grid__header">
    <h2 class="onsite-grid__heading sub-heading" data-i18n-de={heading.de} data-i18n-en={heading.en}>{heading[lang]}</h2>
  </header>
  <ul class="onsite-grid__list">
    {items.map((item) => {
      const floor = item.location?.floor ?? '';
      const imgSrc = `${base}${item.image}`;
      const isClickable = item.id === 'kerry-james-marshall';
      const href = isClickable ? `${base}/onsite/${item.id}` : undefined;
      return (
        <li class="onsite-grid__item" data-id={item.id}>
          {isClickable ? (
            <div class="onsite-grid__card">
              <LayeredHoverCard
                image={item.image}
                alt={item.title[lang]}
                href={href!}
                ctaText={lang === 'de' ? 'Entdecken' : 'Explore'}
              />
              <div class="onsite-grid__meta">
                <h3 class="onsite-grid__title" data-i18n-de={item.title.de} data-i18n-en={item.title.en}>{item.title[lang]}</h3>
                {floor && <p class="onsite-grid__floor">{floor}</p>}
              </div>
            </div>
          ) : (
            <div class="onsite-grid__card">
              <div class="onsite-grid__media">
                <img src={imgSrc} alt={item.title[lang]} loading="lazy" />
              </div>
              <div class="onsite-grid__meta">
                <h3 class="onsite-grid__title" data-i18n-de={item.title.de} data-i18n-en={item.title.en}>{item.title[lang]}</h3>
                {floor && <p class="onsite-grid__floor">{floor}</p>}
              </div>
            </div>
          )}
        </li>
      );
    })}
  </ul>
</section>

<style>
  .onsite-grid {
    color: var(--color-text);
  }

  .onsite-grid__header {
    margin-bottom: var(--space-6);
  }

  /* Typography comes from the global .sub-heading utility (see base.css);
     only zero the h2's default browser margin here to avoid a conflict. */
  .onsite-grid__heading {
    margin: 0;
  }

  .onsite-grid__list {
    display: grid;
    gap: var(--space-4);
    grid-template-columns: repeat(2, 1fr);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  @media (min-width: 768px) {
    .onsite-grid__list {
      grid-template-columns: repeat(3, 1fr);
      gap: var(--space-6);
    }
  }

  @media (min-width: 1024px) {
    .onsite-grid__list {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .onsite-grid__item {
    margin: 0;
  }

  .onsite-grid__card {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .onsite-grid__media {
    aspect-ratio: 3 / 4;
    overflow: hidden;
    background: color-mix(in srgb, var(--color-text) 8%, transparent);
  }

  .onsite-grid__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .onsite-grid__meta {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .onsite-grid__title {
    font-size: var(--type-lg);
    color: var(--color-text);
    font-weight: var(--weight-regular);
    line-height: 1.2;
    margin: 0;
  }

  .onsite-grid__floor {
    font-size: var(--type-sm);
    color: var(--color-text);
    opacity: 0.7;
    margin: 0;
  }

  /* Hover: title shifts color when LayeredHoverCard is hovered */
  @media (hover: hover) {
    .onsite-grid__card:has(.layered-hover:hover) .onsite-grid__title {
      opacity: 0.6;
      transition: opacity 0.3s ease;
    }
  }

  .onsite-grid__card:has(.layered-hover) .onsite-grid__title {
    transition: opacity 0.3s ease;
  }
</style>
