---
// PinnedNarrative.astro -- D-28, D-33: Pinned narrative sequence with scrolling cards
// GSAP ScrollTrigger: desktop pins section, cards crossfade one at a time
// Mobile: cards stack vertically with normal scroll

import ExhibitionCard from './ExhibitionCard.astro';
import StatusAccordion from '../ui/StatusAccordion.astro';

interface Props {
  contentType: string;
  items: Array<{
    id: string;
    title: { de: string; en: string };
    description?: { de: string; en: string };
    image?: string;
    images?: string[];
    date?: string;
    link?: string;
    linkLabel?: { de: string; en: string };
    secondaryLink?: string;
    secondaryLinkLabel?: { de: string; en: string };
    schedule?: Array<{ day: number; label: { de: string; en: string }; open?: string; close?: string; closed?: boolean }>;
  }>;
  lang: 'en' | 'de';
}

const { contentType, items, lang } = Astro.props;
const isExhibition = contentType === 'exhibitions';
---

<div class="pinned-narrative" data-content-type={contentType} data-card-count={items.length}>
  <div class="pinned-narrative__cards">
    {items.map((item, i) => (
      <div
        class:list={[
          'pinned-narrative__card-wrap',
          { 'pinned-narrative__card-wrap--even': i % 2 === 0 },
          { 'pinned-narrative__card-wrap--odd': i % 2 === 1 },
        ]}
        data-card-index={i}
      >
        {isExhibition ? (
          <ExhibitionCard
            title={item.title}
            description={item.description}
            image={item.image}
            date={item.date}
            lang={lang}
          />
        ) : (
          <article class="pinned-narrative__card">
            {(item.images?.length ? item.images : item.image ? [item.image] : []).length > 0 && (
              <div class="pinned-narrative__card-stack" data-stack>
                {(item.images || (item.image ? [item.image] : [])).map((src, imgIdx) => (
                  <div
                    class="pinned-narrative__card-stack-img"
                    data-stack-img={imgIdx}
                    style={`--stack-offset: ${imgIdx}`}
                  >
                    <img src={`${import.meta.env.BASE_URL.replace(/\/$/, '')}${src}`} alt={`${item.title[lang]} ${imgIdx + 1}`} loading="lazy" />
                  </div>
                ))}
              </div>
            )}
            <div class="pinned-narrative__card-content">
              <h3 class="pinned-narrative__card-title sub-heading">{item.title[lang]}</h3>
              {item.date && (
                <span class="pinned-narrative__card-date">{item.date}</span>
              )}
              {item.description && (
                <p class="pinned-narrative__card-desc">{item.description[lang]}</p>
              )}
              {item.schedule && (
                <StatusAccordion
                  schedule={item.schedule.map(d => ({
                    ...d,
                    label: d.label[lang]
                  }))}
                  closedLabel={lang === 'de' ? 'Heute geschlossen' : 'Closed today'}
                  lang={lang}
                />
              )}
              {item.link && (
                <a href={item.link} class="pinned-narrative__card-link btn-link touch-pulse" target={item.link.startsWith('http') ? '_blank' : undefined} rel={item.link.startsWith('http') ? 'noopener' : undefined}>
                  <span>{item.linkLabel ? item.linkLabel[lang] : (lang === 'de' ? 'Mehr erfahren' : 'Learn more')}</span>
                  <span class="icon">arrow_forward</span>
                </a>
              )}
              {item.secondaryLink && (
                <a href={item.secondaryLink} class="pinned-narrative__card-link btn-link touch-pulse" target="_blank" rel="noopener">
                  <span>{item.secondaryLinkLabel ? item.secondaryLinkLabel[lang] : (lang === 'de' ? 'Mehr erfahren' : 'Learn more')}</span>
                  <span class="icon">arrow_forward</span>
                </a>
              )}
            </div>
          </article>
        )}
      </div>
    ))}
  </div>
</div>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  function initPinnedNarrative() {
    const narratives = document.querySelectorAll<HTMLElement>('.pinned-narrative');
    if (!narratives.length) return;

    const reduceMotion =
      window.matchMedia('(prefers-reduced-motion: reduce)').matches ||
      document.documentElement.classList.contains('reduce-motion');

    if (reduceMotion) return;

    narratives.forEach((narrative) => {
      const cards = narrative.querySelectorAll<HTMLElement>('.pinned-narrative__card-wrap');
      if (cards.length < 2) return;

      const cardCount = cards.length;

      // All cards visible, fade in on scroll
      narrative.style.height = 'auto';

      cards.forEach((card) => {
        gsap.set(card, { opacity: 1, y: 0, zIndex: 'auto' });

        // Fade in the card content
        const content = card.querySelector('.pinned-narrative__card-content');
        if (content) {
          gsap.from(content, {
            opacity: 0,
            y: 30,
            scrollTrigger: {
              trigger: card,
              start: 'top 85%',
              end: 'top 60%',
              scrub: true,
            },
          });
        }

        // Stagger in stacked images (drop-onto-table effect)
        const stackImgs = card.querySelectorAll('[data-stack-img]');
        if (stackImgs.length) {
          gsap.set(stackImgs, { opacity: 0, scale: 1.2 });

          ScrollTrigger.create({
            trigger: card,
            start: 'top 80%',
            onEnter: () => {
              gsap.to(stackImgs, {
                opacity: 1,
                scale: 1,
                duration: 1,
                ease: 'power3.out',
                stagger: 0.25,
              });
            },
            once: true,
          });
        }
      });
    });
  }

  initPinnedNarrative();
  document.addEventListener('astro:after-swap', initPinnedNarrative);
</script>

<style>
  .pinned-narrative {
    position: relative;
  }

  .pinned-narrative__cards {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
  }

  @media (min-width: 768px) {
    .pinned-narrative__cards {
      gap: var(--space-24);
    }
  }

  @media (max-width: 767px) {
    .pinned-narrative__card-wrap {
      position: relative;
    }

    .pinned-narrative__cards {
      gap: var(--space-16);
    }

    .pinned-narrative__card {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .pinned-narrative__card-stack {
      aspect-ratio: 3 / 2;
    }

    .pinned-narrative__card-wrap--odd .pinned-narrative__card {
      direction: ltr;
    }
  }

  /* Generic card styles (non-exhibition content) */
  .pinned-narrative__card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-12);
    align-items: start;
    min-height: 400px;
  }

  /* Stacked image cluster */
  .pinned-narrative__card-stack {
    position: relative;
    aspect-ratio: 4 / 3;
  }

  .pinned-narrative__card-stack-img {
    position: absolute;
    overflow: hidden;
    background: #d1d5db;
  }

  /* Variant A (cards 0, 4): large 3:2 top-left, smaller 2:3 offset down-right */
  [data-card-index="0"] .pinned-narrative__card-stack-img[data-stack-img="0"],
  [data-card-index="4"] .pinned-narrative__card-stack-img[data-stack-img="0"] {
    width: 80%;
    top: 0;
    left: 0;
    aspect-ratio: 3 / 2;
    z-index: 1;
  }
  [data-card-index="0"] .pinned-narrative__card-stack-img[data-stack-img="1"],
  [data-card-index="4"] .pinned-narrative__card-stack-img[data-stack-img="1"] {
    width: 45%;
    top: 35%;
    right: 0;
    aspect-ratio: 2 / 3;
    z-index: 2;
  }

  /* 3rd image for Variant A: small 3:2 tucked mid-right */
  [data-card-index="0"] .pinned-narrative__card-stack-img[data-stack-img="2"],
  [data-card-index="4"] .pinned-narrative__card-stack-img[data-stack-img="2"] {
    width: 35%;
    top: 10%;
    right: 5%;
    aspect-ratio: 3 / 2;
    z-index: 0;
  }

  /* Variant B (cards 1, 5): tall 2:3 offset down-left, 3:2 landscape top-right */
  [data-card-index="1"] .pinned-narrative__card-stack-img[data-stack-img="0"],
  [data-card-index="5"] .pinned-narrative__card-stack-img[data-stack-img="0"] {
    width: 50%;
    top: 20%;
    left: 0;
    aspect-ratio: 2 / 3;
    z-index: 2;
  }
  [data-card-index="1"] .pinned-narrative__card-stack-img[data-stack-img="1"],
  [data-card-index="5"] .pinned-narrative__card-stack-img[data-stack-img="1"] {
    width: 70%;
    top: 0;
    right: 0;
    aspect-ratio: 3 / 2;
    z-index: 1;
  }

  /* 3rd image for Variant B: small 2:3 bottom-left */
  [data-card-index="1"] .pinned-narrative__card-stack-img[data-stack-img="2"],
  [data-card-index="5"] .pinned-narrative__card-stack-img[data-stack-img="2"] {
    width: 30%;
    bottom: 0;
    left: 5%;
    aspect-ratio: 2 / 3;
    z-index: 3;
  }

  /* Variant C (cards 2, 6): 3:2 offset down-right, 2:3 top-left */
  [data-card-index="2"] .pinned-narrative__card-stack-img[data-stack-img="0"],
  [data-card-index="6"] .pinned-narrative__card-stack-img[data-stack-img="0"] {
    width: 65%;
    top: 25%;
    right: 0;
    aspect-ratio: 3 / 2;
    z-index: 2;
  }
  [data-card-index="2"] .pinned-narrative__card-stack-img[data-stack-img="1"],
  [data-card-index="6"] .pinned-narrative__card-stack-img[data-stack-img="1"] {
    width: 50%;
    top: 0;
    left: 0;
    aspect-ratio: 2 / 3;
    z-index: 1;
  }

  /* 3rd image for Variant C: small 3:2 bottom-right */
  [data-card-index="2"] .pinned-narrative__card-stack-img[data-stack-img="2"],
  [data-card-index="6"] .pinned-narrative__card-stack-img[data-stack-img="2"] {
    width: 38%;
    bottom: 5%;
    right: 5%;
    aspect-ratio: 3 / 2;
    z-index: 3;
  }

  /* Variant D (cards 3, 7): small 2:3 top-right, large 3:2 offset down-left */
  [data-card-index="3"] .pinned-narrative__card-stack-img[data-stack-img="0"],
  [data-card-index="7"] .pinned-narrative__card-stack-img[data-stack-img="0"] {
    width: 40%;
    top: 0;
    right: 10%;
    aspect-ratio: 2 / 3;
    z-index: 1;
  }
  [data-card-index="3"] .pinned-narrative__card-stack-img[data-stack-img="1"],
  [data-card-index="7"] .pinned-narrative__card-stack-img[data-stack-img="1"] {
    width: 75%;
    top: 30%;
    left: 0;
    aspect-ratio: 3 / 2;
    z-index: 2;
  }

  /* 3rd image for Variant D: small 2:3 mid-right */
  [data-card-index="3"] .pinned-narrative__card-stack-img[data-stack-img="2"],
  [data-card-index="7"] .pinned-narrative__card-stack-img[data-stack-img="2"] {
    width: 32%;
    top: 8%;
    right: 0;
    aspect-ratio: 2 / 3;
    z-index: 3;
  }

  .pinned-narrative__card-stack-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Alternate: text first on odd cards */
  .pinned-narrative__card-wrap--odd .pinned-narrative__card {
    direction: rtl;
  }
  .pinned-narrative__card-wrap--odd .pinned-narrative__card > * {
    direction: ltr;
  }

  .pinned-narrative__card-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding-top: var(--space-8);
  }

  .pinned-narrative__card-title {
    margin-bottom: var(--space-1);
  }

  .pinned-narrative__card-date {
    font-size: var(--type-sm);
    color: var(--color-decorative-shadow);
  }

  .pinned-narrative__card-desc {
    font-size: var(--type-md);
    line-height: var(--leading-normal);
    max-width: 45ch;
  }

  .pinned-narrative__card-link {
    display: inline-flex;
    align-self: flex-start;
    padding: var(--space-2) 0;
    font-size: var(--type-md);
    text-decoration: none;
    color: var(--color-text);
  }

  @media (max-width: 767px) {
    .pinned-narrative__card {
      grid-template-columns: 1fr;
    }
  }
</style>
