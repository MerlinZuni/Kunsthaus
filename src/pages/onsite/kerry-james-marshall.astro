---
// src/pages/onsite/kerry-james-marshall.astro — Phase 03-03 KJM exhibition
// detail page. Composition: KjmHero → CinematicReveal (imagePosition:left)
// → intro section → ArtworkSlider → ArtistQuote → Videos HSlider → Shop HSlider
// → Footer + StickyCTA. Task 2 ships the skeleton (hero + cinematic only);
// Task 6 fills in the remaining sections.
import BaseLayout from '../../layouts/BaseLayout.astro';
import KjmHero from '../../components/hero/KjmHero.astro';
import CinematicReveal from '../../components/sections/CinematicReveal.astro';
import SectionWrapper from '../../components/sections/SectionWrapper.astro';
import ArtworkSlider from '../../components/sections/ArtworkSlider.astro';
import ArtistQuote from '../../components/sections/ArtistQuote.astro';
import HorizontalSlider from '../../components/sections/HorizontalSlider.astro';
import Footer from '../../components/footer/Footer.astro';
import StickyCTA from '../../components/ui/StickyCTA.astro';
import kjmJson from '../../content/onsite/kerry-james-marshall.json';
import uiStringsJson from '../../content/shared/ui-strings.json';

const lang = 'en' as const;
const kjm = (kjmJson as any)['kerry-james-marshall'];

const uiStrings = uiStringsJson;
const getString = (key: string) => {
  const entry = uiStrings.find((s: any) => s.key === key);
  return entry?.value?.[lang] || key;
};

// CinematicReveal adapter — same 03-02 trap: component reads data.title,
// not data.cardTitle. Build the adapter at the page level.
const cinematicData = {
  tagline: kjm.cinematicReveal.tagline,
  title: kjm.cinematicReveal.cardTitle,
  description: kjm.cinematicReveal.description,
  image: kjm.cinematicReveal.image,
};

const backLabel = { de: '← Ihr Besuch', en: '← Your visit' };
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title="Kerry James Marshall — Kunsthaus Zurich" lang={lang} mode="onsite">
  <script define:vars={{ artworksJson: JSON.stringify(kjm.artworks) }}>
    window.__kjmArtworks = JSON.parse(artworksJson);
  </script>
  <KjmHero
    title={kjm.title}
    dateLabel={kjm.dateLabel}
    video={kjm.heroVideo}
    backLabel={backLabel}
    backHref={`${base}/onsite`}
    lang={lang}
  />

  <section
    class="stacking-section cinematic-reveal-section"
    data-section="kjm-reveal"
    style="z-index: 20; background: transparent;"
  >
    <CinematicReveal
      contentType="kjm-detail"
      data={cinematicData}
      lang={lang}
    />
  </section>

  <SectionWrapper
    index={1}
    bgStep={1}
    sectionName={kjm.intro.heading[lang]}
    sectionId="kjm-intro"
  >
    <p class="kjm-intro__body">{kjm.intro.body[lang]}</p>
    {kjm.intro.paragraphs && (
      <div class="kjm-intro__columns">
        {kjm.intro.paragraphs.map((p: any) => (
          <p class="kjm-intro__paragraph">{p[lang]}</p>
        ))}
      </div>
    )}

    <article class="kjm-intro__tickets-panel">
      <div class="kjm-intro__tickets-block">
        <h4 class="sub-heading">{lang === 'de' ? 'Tickets' : 'Tickets'}</h4>
        <p class="kjm-intro__tickets-info">
          {lang === 'de'
            ? 'Erwachsene CHF 31.– / Ermässigt CHF 22.–* inkl. Sammlung & kleine Ausstellungen.'
            : 'Adults CHF 31.– / Concessions CHF 22.–* incl. Collection & small exhibitions.'}
          <br />
          <span class="kjm-intro__tickets-note">{lang === 'de' ? '*Ermässigter Tarif' : '*Reduced rate'}</span>
        </p>
      </div>
      <div class="kjm-intro__tickets-block">
        <h4 class="sub-heading">{lang === 'de' ? 'Mitgliedschaft' : 'Membership'}</h4>
        <p class="kjm-intro__tickets-info">
          {lang === 'de'
            ? 'Freier Eintritt plus Einladungen zu allen Eröffnungen und viele weitere Vorteile!'
            : 'Free admission plus invitations to all openings and many other benefits!'}
        </p>
      </div>
      <a href="/membership" class="btn hover-wipe-inverse touch-pulse touch-target kjm-intro__tickets-cta">
        <span>{lang === 'de' ? 'Mitglied werden' : 'Become a member'}</span>
        <span class="icon" aria-hidden="true">arrow_forward</span>
      </a>
    </article>
  </SectionWrapper>

  <SectionWrapper
    index={2}
    bgStep={2}
    sectionName="Works"
    sectionId="kjm-artworks"
  >
    <ArtworkSlider artworks={kjm.artworks} lang={lang} />
  </SectionWrapper>

  <SectionWrapper
    index={3}
    bgStep={3}
    sectionName="In the artist's words"
    sectionId="kjm-quote"
  >
    <ArtistQuote
      quote={kjm.artistQuote.quote}
      attribution={kjm.artistQuote.attribution}
      lang={lang}
    />
  </SectionWrapper>

  <SectionWrapper
    index={4}
    bgStep={4}
    sectionName="Voices"
    sectionId="kjm-videos"
  >
    <HorizontalSlider
      heading={{ de: 'Ausstellungsvideos', en: 'Exhibition Videos' }}
      variant="videos"
      lang={lang}
    >
      {kjm.videos.map((v: any) => (
        <article class="video-card" data-role={v.role}>
          <div class="video-card__media">
            <img src={`${base}${v.thumbnail}`} alt={v.quote[lang]} loading="lazy" />
            <button type="button" class="video-card__play" aria-label="Play video">
              <svg width="14" height="14" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                <polygon points="5,3 17,10 5,17" />
              </svg>
            </button>
            <span class="video-card__duration">{v.duration}</span>
          </div>
          <blockquote class="video-card__quote">{v.quote[lang]}</blockquote>
          <p class="video-card__role">{v.role}</p>
        </article>
      ))}
    </HorizontalSlider>
  </SectionWrapper>

  <SectionWrapper
    index={5}
    bgStep={1}
    sectionName="Shop"
    sectionId="kjm-shop"
  >
    <HorizontalSlider
      heading={{ de: 'Aus der Ausstellung', en: 'From the Exhibit' }}
      variant="shop"
      lang={lang}
    >
      {kjm.shop.map((s: any) => (
        <article class="shop-card">
          <div class="shop-card__media">
            <img src={`${base}${s.image}`} alt={s.title[lang]} loading="lazy" />
          </div>
          <h4 class="shop-card__title">{s.title[lang]}</h4>
          <p class="shop-card__price">{s.price}</p>
          <button type="button" class="shop-card__cta btn hover-wipe-inverse touch-pulse touch-target">
            <span>{s.addToCartLabel[lang]}</span>
            <span class="icon" aria-hidden="true">shopping_bag</span>
          </button>
        </article>
      ))}
    </HorizontalSlider>
  </SectionWrapper>

  <SectionWrapper
    index={6}
    bgStep={2}
    sectionName={lang === 'de' ? 'Veranstaltungen' : 'Exhibit Events'}
    sectionId="kjm-events"
  >
    <div class="kjm-events" data-kjm-events>
      <h3 class="kjm-events__heading sub-heading">{lang === 'de' ? 'Programm' : 'Programme'}</h3>
      <ul class="kjm-events__list">
        {kjm.events.map((ev: any) => (
          <li class="kjm-events__row" data-image={`${base}${ev.image}`}>
            <span class="kjm-events__row-title">
              {ev.title[lang]}
              <span class="icon kjm-events__row-arrow">arrow_forward</span>
            </span>
            <span class="kjm-events__row-date">{ev.date[lang]}</span>
            <span class="kjm-events__row-tags">
              <span class="kjm-events__tag">{ev.category[lang]}</span>
            </span>
            <img class="kjm-events__row-thumb" src={`${base}${ev.image}`} alt="" loading="lazy" />
          </li>
        ))}
      </ul>

      <div class="kjm-events__preview" aria-hidden="true">
        <img class="kjm-events__preview-img" src="" alt="" />
      </div>
    </div>
  </SectionWrapper>

  <SectionWrapper
    index={7}
    bgStep={3}
    sectionName="Partners & Credits"
    sectionId="kjm-supported"
  >
    <div class="kjm-supported">
      <h3 class="kjm-supported__heading sub-heading">{lang === 'de' ? 'Unterstützt von' : 'Supported by'}</h3>
      <img
        src={`${base}/images/partners/Swiss-Re-logo.svg`}
        alt="Swiss Re"
        class="kjm-supported__logo"
        loading="lazy"
      />
      <p class="kjm-supported__credit">
        Ill: Kerry James Marshall, Untitled (Beauty Queen), 2014, Private collection, © Kerry James Marshall, Courtesy of the artist and David Zwirner, London.
      </p>
    </div>
  </SectionWrapper>

  <SectionWrapper
    index={8}
    bgStep={4}
    sectionName="Keep Exploring"
    sectionId="kjm-continue"
  >
    <div class="kjm-continue">
      <a href={`${base}/onsite`} class="btn hover-wipe-inverse touch-pulse touch-target">
        <span>{lang === 'de' ? 'Besuch fortsetzen' : 'Continue your visit'}</span>
        <span class="icon" aria-hidden="true">arrow_forward</span>
      </a>
    </div>
  </SectionWrapper>

  <Footer
    lang={lang}
    modeLabels={{ planning: getString('mode-planning'), onsite: getString('mode-onsite') }}
    ticketsLabel={getString('tickets')}
  />

  <StickyCTA
    modeLabels={{
      planning: getString('mode-planning'),
      onsite: getString('mode-onsite'),
    }}
    ticketsLabel={getString('tickets')}
    lang={lang}
  />
</BaseLayout>

<style>
  .kjm-intro__body {
    font-size: var(--type-lg);
    line-height: var(--leading-normal);
    max-width: 60ch;
    color: var(--color-text);
    margin: 0;
  }

  .kjm-supported {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-6);
    padding: var(--space-8) 0;
  }

  .kjm-supported__heading {
    margin: 0;
  }

  .kjm-supported__logo {
    height: 64px;
    width: auto;
    display: block;
    filter: brightness(0) invert(1);
  }

  .kjm-supported__credit {
    font-size: var(--type-sm);
    color: var(--color-text);
    opacity: 0.6;
    max-width: 60ch;
    line-height: var(--leading-normal);
    margin: 0;
  }

  /* Event list — mirrors ExhibitionList pattern */
  .kjm-events {
    position: relative;
  }

  .kjm-events__heading {
    margin-bottom: var(--space-6);
  }

  .kjm-events__list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .kjm-events__row {
    display: grid;
    grid-template-columns: 2fr 1fr auto;
    gap: var(--space-6);
    align-items: center;
    padding: var(--space-6) 0;
    border-bottom: 1px solid color-mix(in srgb, var(--color-text) 10%, transparent);
    cursor: default;
    transition: background 0.3s ease;
  }

  .kjm-events__row:first-child {
    border-top: 1px solid color-mix(in srgb, var(--color-text) 10%, transparent);
  }

  .kjm-events__row--active {
    background: #0e0d0c;
    margin-left: calc(-1 * var(--space-8));
    margin-right: calc(-1 * var(--space-8));
    padding-left: var(--space-8);
    padding-right: var(--space-8);
  }

  .kjm-events__row-title {
    font-size: var(--type-md);
    font-weight: var(--weight-regular);
    line-height: var(--leading-normal);
    color: var(--color-text);
  }

  .kjm-events__row-arrow {
    font-size: 18px;
    opacity: 0;
    display: inline-flex;
    vertical-align: middle;
    margin-left: var(--space-2);
    transition: opacity 0.3s ease, transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .kjm-events__row--active .kjm-events__row-arrow {
    opacity: 0.7;
    transform: translateX(4px);
  }

  .kjm-events__row-date {
    font-size: var(--type-md);
    font-weight: var(--weight-light);
    color: var(--color-text);
  }

  .kjm-events__tag {
    font-size: var(--type-xs);
    font-weight: var(--weight-medium);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 2px 8px;
    border: 1px solid color-mix(in srgb, var(--color-text) 25%, transparent);
    border-radius: 3px;
    color: var(--color-text);
    opacity: 0.7;
  }

  .kjm-events__row-thumb {
    display: none;
  }

  .kjm-events__preview {
    position: absolute;
    top: 0;
    left: 0;
    pointer-events: none;
    z-index: 10;
    opacity: 0;
    transition: opacity 0.3s ease;
    width: 280px;
    height: 210px;
    overflow: hidden;
    border-radius: 4px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.5);
  }

  .kjm-events__preview--visible {
    opacity: 1;
  }

  .kjm-events__preview-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  @media (max-width: 767px) {
    .kjm-events__row {
      position: relative;
      grid-template-columns: 60% 1fr;
      gap: var(--space-2);
      overflow: visible;
    }

    .kjm-events__row-thumb {
      display: block;
      position: absolute;
      right: -80px;
      top: 50%;
      transform: translateY(-50%);
      width: 55%;
      height: 140%;
      object-fit: cover;
      border-radius: 4px 0 0 4px;
      opacity: 0;
      transition: opacity 0.4s ease;
    }

    .kjm-events__row--active .kjm-events__row-thumb {
      opacity: 1;
    }

    .kjm-events__row-title,
    .kjm-events__row-date,
    .kjm-events__row-tags {
      grid-column: 1;
      position: relative;
      z-index: 1;
    }
  }

  .kjm-continue {
    display: flex;
    justify-content: center;
    padding: var(--space-6) 0;
  }

  .kjm-intro__columns {
    margin-top: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .kjm-intro__paragraph {
    font-size: var(--type-md);
    line-height: var(--leading-relaxed, 1.7);
    max-width: 65ch;
    color: var(--color-text);
    opacity: 0.85;
    margin: 0;
  }

  @media (min-width: 768px) {
    .kjm-intro__columns {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--space-12);
      max-width: 90ch;
    }
    .kjm-intro__paragraph {
      max-width: none;
    }
  }

  .kjm-intro__tickets-panel {
    margin-top: var(--space-8);
    background: color-mix(in srgb, var(--color-text) 5%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-text) 12%, transparent);
    border-radius: var(--btn-radius);
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    color: var(--color-text);
  }

  @media (min-width: 768px) {
    .kjm-intro__tickets-panel {
      max-width: 90ch;
    }
  }

  .kjm-intro__tickets-block {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .kjm-intro__tickets-block .sub-heading {
    margin: 0;
  }

  .kjm-intro__tickets-info {
    font-size: var(--type-md);
    line-height: var(--leading-normal);
    color: var(--color-text);
    opacity: 0.8;
    margin: 0;
  }

  .kjm-intro__tickets-note {
    font-size: var(--type-sm);
    opacity: 0.6;
  }

  .kjm-intro__tickets-cta {
    align-self: flex-start;
    justify-content: center;
  }

  /* Video testimonial cards (inline markup fills the HorizontalSlider slot) */
  .video-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    color: var(--color-text);
  }
  .video-card__media {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: color-mix(in srgb, var(--color-text) 10%, transparent);
  }
  .video-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .video-card__duration {
    position: absolute;
    bottom: var(--space-3);
    right: var(--space-3);
    background: rgba(0, 0, 0, 0.6);
    color: #fff;
    padding: var(--space-1) var(--space-2);
    font-size: var(--type-xs);
    letter-spacing: 0.04em;
  }
  .video-card__play {
    position: absolute;
    bottom: var(--space-3);
    left: var(--space-3);
    width: 48px;
    height: 48px;
    border-radius: 50%;
    border: none;
    background: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    color: #ffffff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: background 0.2s ease, transform 0.2s ease;
  }
  .video-card__play:hover,
  .video-card__play:focus-visible {
    background: rgba(0, 0, 0, 0.78);
    transform: scale(1.05);
    outline: none;
  }
  .video-card__play svg {
    margin-left: 2px;
  }
  .video-card__quote {
    font-size: var(--type-lg);
    font-weight: var(--weight-light);
    line-height: 1.2;
    margin: 0;
  }
  .video-card__role {
    font-size: var(--type-xs);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    opacity: 0.65;
    margin: 0;
  }

  /* Shop cards */
  .shop-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    color: var(--color-text);
  }
  .shop-card__media {
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: color-mix(in srgb, var(--color-text) 10%, transparent);
  }
  .shop-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .shop-card__title {
    font-size: var(--type-lg);
    font-weight: var(--weight-regular);
    margin: 0;
    line-height: 1.2;
  }
  .shop-card__price {
    font-size: var(--type-md);
    opacity: 0.8;
    margin: 0;
    font-variant-numeric: tabular-nums;
  }
  .shop-card__cta {
    align-self: flex-start;
    margin-top: var(--space-2);
  }
</style>

<script>
  function initKjmEvents() {
    const container = document.querySelector('[data-kjm-events]');
    if (!container) return;

    const preview = container.querySelector('.kjm-events__preview') as HTMLElement;
    const previewImg = container.querySelector('.kjm-events__preview-img') as HTMLImageElement;
    const rows = container.querySelectorAll('.kjm-events__row');
    if (!preview || !previewImg || !rows.length) return;

    const isTouch = 'ontouchstart' in window || navigator.maxTouchPoints > 0;

    if (!isTouch) {
      rows.forEach((row) => {
        row.addEventListener('mouseenter', () => {
          const src = (row as HTMLElement).dataset.image;
          if (src) {
            previewImg.src = src;
            preview.classList.add('kjm-events__preview--visible');
          }
          row.classList.add('kjm-events__row--active');
        });
        row.addEventListener('mouseleave', () => {
          preview.classList.remove('kjm-events__preview--visible');
          row.classList.remove('kjm-events__row--active');
        });
        row.addEventListener('mousemove', (e) => {
          const ev = e as MouseEvent;
          const rect = container.getBoundingClientRect();
          preview.style.left = `${ev.clientX - rect.left + 20}px`;
          preview.style.top = `${ev.clientY - rect.top - 80}px`;
        });
      });
    } else {
      let activeRow: HTMLElement | null = null;
      const updateActiveRow = () => {
        const viewportCenter = window.innerHeight / 2;
        let closest: HTMLElement | null = null;
        let closestDist = Infinity;
        rows.forEach((row) => {
          const rect = row.getBoundingClientRect();
          const rowCenter = rect.top + rect.height / 2;
          const dist = Math.abs(rowCenter - viewportCenter);
          if (dist < closestDist) { closestDist = dist; closest = row as HTMLElement; }
        });
        if (closest && closest !== activeRow) {
          if (activeRow) activeRow.classList.remove('kjm-events__row--active');
          closest.classList.add('kjm-events__row--active');
          activeRow = closest;
        }
      };
      window.addEventListener('scroll', updateActiveRow, { passive: true });
      updateActiveRow();
    }
  }

  initKjmEvents();
  document.addEventListener('astro:page-load', initKjmEvents);
</script>
