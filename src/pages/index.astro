---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Kunsthaus Zurich">
  <section style="padding: var(--space-16) var(--space-8);">
    <h1>Kunsthaus Zurich</h1>
    <p style="font-size: var(--type-lg); margin-top: var(--space-4);">
      Foundation phase -- CSS tokens, typography, and smooth scroll active.
    </p>
    <p style="margin-top: var(--space-8); color: var(--color-accent);">
      This text uses the accent color token.
    </p>
  </section>
  <section style="height: 200vh; padding: var(--space-16) var(--space-8);">
    <h2>Scroll Test</h2>
    <p>Scroll down to verify Lenis smooth scrolling is active.</p>
  </section>
</BaseLayout>
