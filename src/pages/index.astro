---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const planningContent = await getCollection('planning');
const sorted = planningContent.sort((a, b) => a.data.priority - b.data.priority);

const lang = 'de'; // Default language, Phase 2 will add switching
---
<BaseLayout title="Kunsthaus Zurich">
  <div class="grid-page">
    {sorted.map((section) => (
      <section class="col-full" style={`padding: var(--space-12) var(--space-8);`}>
        <h2 style="font-size: var(--type-2xl); margin-bottom: var(--space-4);">
          {section.data.title[lang]}
        </h2>
        {section.data.subtitle && (
          <p style="font-size: var(--type-lg); color: var(--color-accent); margin-bottom: var(--space-4);">
            {section.data.subtitle[lang]}
          </p>
        )}
        {section.data.body && (
          <p style="font-size: var(--type-md); max-width: 60ch; line-height: var(--leading-relaxed);">
            {section.data.body[lang]}
          </p>
        )}
        {section.data.items && (
          <ul style="list-style: none; margin-top: var(--space-6); display: flex; flex-direction: column; gap: var(--space-4);">
            {section.data.items.map((item) => (
              <li style="padding: var(--space-4); background: var(--color-decorative); border-radius: 2px;">
                <strong>{item.title[lang]}</strong>
                {item.description && <p style="margin-top: var(--space-2);">{item.description[lang]}</p>}
                {item.date && <span style="font-size: var(--type-sm); color: var(--color-decorative-shadow);">{item.date}</span>}
              </li>
            ))}
          </ul>
        )}
      </section>
    ))}
    <!-- Content source indicator -->
    <footer class="col-full" style="padding: var(--space-8); font-size: var(--type-sm); color: var(--color-decorative-shadow);">
      Content loaded from JSON content collections. {planningContent.length} sections rendered.
    </footer>
  </div>
</BaseLayout>
