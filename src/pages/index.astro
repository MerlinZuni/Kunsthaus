---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroCarousel from '../components/hero/HeroCarousel.astro';
import SectionWrapper from '../components/sections/SectionWrapper.astro';
import CinematicReveal from '../components/sections/CinematicReveal.astro';
import PinnedNarrative from '../components/sections/PinnedNarrative.astro';
import StandardGrid from '../components/sections/StandardGrid.astro';
import ExhibitionList from '../components/sections/ExhibitionList.astro';
import EventsList from '../components/sections/EventsList.astro';
import StickyCTA from '../components/ui/StickyCTA.astro';
import SectionProgress from '../components/ui/SectionProgress.tsx';
import Footer from '../components/footer/Footer.astro';
import { getCollection } from 'astro:content';
import uiStringsJson from '../content/shared/ui-strings.json';
import homepageJson from '../content/planning/homepage.json';

const lang = 'en';
const planningContent = homepageJson;
const uiStrings = uiStringsJson;

// Extract hero and content sections
const hero = planningContent.find(s => s.section === 'hero');
const sections = planningContent
  .filter(s => s.section !== 'hero')
  .sort((a, b) => a.priority - b.priority);

// Helper: get ui string value by key
const getString = (key: string) => {
  const entry = uiStrings.find(s => s.key === key);
  return entry?.value?.[lang] || key;
};

// D-29: Section to component type mapping
const sectionComponent: Record<string, string> = {
  'exhibitions': 'mixed',
  'offerings': 'pinned-narrative',
  'education': 'pinned-narrative',
  'key-info': 'standard-grid',
  'events': 'events-list',
  'planning-details': 'standard-grid',
};

// D-26: Background rotation - 4 step cycle
const bgSteps = [2, 3, 4, 1] as const;

// Section names for progress indicator
const sectionNames = sections.map(s => s.title[lang]);

// Slide titles for mobile progress display
const slideNames = (hero?.slides || []).map(s => s.title[lang]);
---

<BaseLayout title="Kunsthaus Zurich" lang={lang}>
  {/* Hero (fixed, z-index: 10) */}
  <HeroCarousel slides={hero?.slides || []} lang={lang} uiStrings={uiStrings} />

  {/* Spacer: pushes stacking sections below fixed hero */}
  <div class="hero-spacer"></div>

  {/* Content sections with stacking scroll effect */}
  {sections.map((section, i) => {
    const bgStep = bgSteps[i % 4];
    const componentType = sectionComponent[section.section] || 'standard-grid';

    return (
      <SectionWrapper
        index={i}
        bgStep={bgStep}
        sectionName={section.title[lang]}
        sectionId={section.section}
      >
        {componentType === 'mixed' && (
          <ExhibitionList lang={lang} />
        )}
        {componentType === 'pinned-narrative' && (
          <PinnedNarrative
            contentType={section.section}
            items={section.items || []}
            lang={lang}
          />
        )}
        {componentType === 'events-list' && (
          <EventsList lang={lang} />
        )}
        {componentType === 'standard-grid' && (
          <StandardGrid
            title={section.title}
            body={section.body}
            items={section.items || []}
            lang={lang}
            columns={3}
          />
        )}
      </SectionWrapper>
    );
  })}

  {/* Footer */}
  <Footer
    lang={lang}
    modeLabels={{ planning: getString('mode-planning'), onsite: getString('mode-onsite') }}
    ticketsLabel={getString('tickets')}
  />

  {/* Fixed UI elements (outside main content flow) */}
  <StickyCTA
    modeLabels={{
      planning: getString('mode-planning'),
      onsite: getString('mode-onsite'),
    }}
    ticketsLabel={getString('tickets')}
    lang={lang}
  />
  <SectionProgress
    client:visible
    totalSections={slideNames.length}
    sectionNames={sectionNames}
    slideNames={slideNames}
  />
</BaseLayout>
