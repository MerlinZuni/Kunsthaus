---
import '../styles/layers.css';
import '../styles/reset.css';
import '../styles/tokens/primitives.css';
import '../styles/tokens/semantic.css';
import '../styles/tokens/components.css';
import '../styles/typography.css';
import '../styles/grid.css';
import '../styles/base.css';
import '../styles/components/interactions.css';
import '../styles/components/sections.css';

import SkipNav from '../components/SkipNav.astro';
import Head from '../components/Head.astro';
import GridOverlay from '../components/GridOverlay.tsx';
import HeroTextControls from '../components/hero/HeroTextControls.tsx';
import NavBar from '../components/nav/NavBar.astro';
import LogoIsland from '../components/nav/LogoIsland.astro';
import SearchOverlay from '../components/nav/SearchOverlay.astro';
import HamburgerOverlay from '../components/nav/HamburgerOverlay.astro';
import navItemsJson from '../content/shared/navigation.json';
import uiStringsJson from '../content/shared/ui-strings.json';

interface Props {
  title: string;
  lang?: 'en' | 'de';
}

const { title, lang = 'en' } = Astro.props;
const isDev = import.meta.env.DEV;

// Navigation data from JSON
const navItems = navItemsJson;
const uiStrings = uiStringsJson;
const getString = (key: string) => {
  const entry = uiStrings.find((s: any) => s.key === key);
  return entry?.value?.[lang] || key;
};
const searchLabel = getString('search-label');
const menuLabel = getString('menu-label');
---

<html lang={lang} data-mode="planning">
  <head>
    <Head title={title} />
    <noscript>
      <style>
        /* Ensure all content is visible without JS */
        [data-js-only] { display: none !important; }
        /* Remove smooth scroll dependency */
        html { scroll-behavior: auto; }
      </style>
    </noscript>
  </head>
  <body>
    <SkipNav />

    <GridOverlay client:only="react" />

    {/* Navigation (z-index: 60) */}
    <NavBar navItems={navItems} lang={lang} searchLabel={searchLabel} menuLabel={menuLabel} />
    <LogoIsland />
    <SearchOverlay searchLabel={searchLabel} />
    <HamburgerOverlay navItems={navItems} lang={lang} searchLabel={searchLabel} />

    <main id="main" role="main">
      <slot />
    </main>

    <script>
      import Lenis from 'lenis';
      import 'lenis/dist/lenis.css';
      import { gsap } from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';

      gsap.registerPlugin(ScrollTrigger);

      const lenis = new Lenis({
        duration: 1.2,
        smoothWheel: true,
      });

      // Sync Lenis with GSAP ScrollTrigger
      lenis.on('scroll', ScrollTrigger.update);

      gsap.ticker.add((time) => {
        lenis.raf(time * 1000);
      });

      gsap.ticker.lagSmoothing(0);

      // Expose lenis instance for overlays to pause/resume
      (window as any).__lenis = lenis;

      // Respect reduced motion -- per D-10
      const motionQuery = window.matchMedia('(prefers-reduced-motion: reduce)');
      if (motionQuery.matches) {
        lenis.destroy();
      }
      motionQuery.addEventListener('change', (e) => {
        if (e.matches) lenis.destroy();
      });
    </script>
  </body>
</html>
