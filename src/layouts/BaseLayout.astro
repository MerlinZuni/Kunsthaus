---
import '../styles/layers.css';
import '../styles/reset.css';
import '../styles/tokens/primitives.css';
import '../styles/tokens/semantic.css';
import '../styles/tokens/components.css';
import '../styles/typography.css';
import '../styles/grid.css';
import '../styles/base.css';
import '../styles/components/interactions.css';
import '../styles/components/sections.css';

import { ClientRouter } from 'astro:transitions';

import SkipNav from '../components/SkipNav.astro';
import Head from '../components/Head.astro';
import GridOverlay from '../components/GridOverlay.tsx';
import HeroTextControls from '../components/hero/HeroTextControls.tsx';
import NavBar from '../components/nav/NavBar.astro';
import LogoIsland from '../components/nav/LogoIsland.astro';
import SearchOverlay from '../components/nav/SearchOverlay.astro';
import HamburgerOverlay from '../components/nav/HamburgerOverlay.astro';
import HoursOverlay from '../components/nav/HoursOverlay.astro';
import PaywallOverlay from '../components/nav/PaywallOverlay.astro';
import AudioGuideOverlay from '../components/nav/AudioGuideOverlay.astro';
import ProfileOverlay from '../components/nav/ProfileOverlay.astro';
import navItemsJson from '../content/shared/navigation.json';
import uiStringsJson from '../content/shared/ui-strings.json';
import footerJson from '../content/shared/footer.json';

interface Props {
  title: string;
  lang?: 'en' | 'de';
  /** Which dual-mode theme this page renders in. Drives `html[data-mode]`
   *  which cascades through semantic tokens. Phase 03 URL-as-state pattern:
   *  each page sets this explicitly, JS does NOT mutate data-mode anywhere. */
  mode?: 'planning' | 'onsite';
}

const { title, lang = 'en', mode = 'planning' } = Astro.props;
const isDev = import.meta.env.DEV;

// Navigation data from JSON
const navItems = navItemsJson;
const uiStrings = uiStringsJson;
const getString = (key: string) => {
  const entry = uiStrings.find((s: any) => s.key === key);
  return entry?.value?.[lang] || key;
};
const searchLabel = getString('search-label');
const menuLabel = getString('menu-label');
const footerData = footerJson[0];
---

<html lang={lang} data-mode={mode}>
  <head>
    <Head title={title} />
    <ClientRouter />
    <noscript>
      <style>
        /* Ensure all content is visible without JS */
        [data-js-only] { display: none !important; }
        /* Remove smooth scroll dependency */
        html { scroll-behavior: auto; }
      </style>
    </noscript>
  </head>
  <body>
    <SkipNav />

    {/* Navigation (z-index: 60) */}
    <NavBar navItems={navItems} lang={lang} searchLabel={searchLabel} menuLabel={menuLabel} />
    <LogoIsland />
    <SearchOverlay searchLabel={searchLabel} />
    <HamburgerOverlay navItems={navItems} lang={lang} searchLabel={searchLabel} />
    <HoursOverlay
      schedule={footerData.schedule}
      holidaySchedule={footerData.holidaySchedule}
      phone={footerData.address.phone}
      lang={lang}
    />
    <PaywallOverlay lang={lang} />
    <AudioGuideOverlay lang={lang} />
    <ProfileOverlay lang={lang} />

    <script is:inline>
      window.__demoUser = localStorage.getItem('kunsthaus-demo-user') || null;
      document.addEventListener('astro:page-load', function() {
        window.__demoUser = localStorage.getItem('kunsthaus-demo-user') || null;
      });
    </script>

    <main id="main" role="main">
      <slot />
    </main>

    <script>
      // Global i18n swap: swap textContent/innerHTML based on data-i18n-{lang} attributes
      function applyLanguage(lang: string) {
        if (lang !== 'en' && lang !== 'de') return;
        document.querySelectorAll('[data-i18n-de]').forEach(el => {
          const value = el.getAttribute(`data-i18n-${lang}`);
          if (value !== null) {
            if (el.hasAttribute('data-i18n-html')) {
              el.innerHTML = value;
            } else {
              // Preserve child elements (like icons) by only replacing text nodes
              const childElements = Array.from(el.children);
              if (childElements.length > 0) {
                // Find the first text node and update it
                for (const node of Array.from(el.childNodes)) {
                  if (node.nodeType === Node.TEXT_NODE && node.textContent?.trim()) {
                    node.textContent = value;
                    break;
                  }
                }
                // If no text node found, set textContent on first text-bearing child or prepend
                if (!Array.from(el.childNodes).some(n => n.nodeType === Node.TEXT_NODE && n.textContent?.trim())) {
                  el.insertBefore(document.createTextNode(value), el.firstChild);
                }
              } else {
                el.textContent = value;
              }
            }
          }
        });
      }

      // Observe lang attribute changes on <html>
      const i18nObserver = new MutationObserver((mutations) => {
        for (const m of mutations) {
          if (m.attributeName === 'lang') {
            const lang = document.documentElement.lang || 'en';
            applyLanguage(lang);
          }
        }
      });
      i18nObserver.observe(document.documentElement, { attributeFilter: ['lang'] });

      // On page load (including View Transitions), restore saved language
      function restoreLanguage() {
        const saved = localStorage.getItem('kunsthaus-lang');
        if (saved && saved !== 'en') {
          document.documentElement.setAttribute('lang', saved);
          applyLanguage(saved);
        }
      }

      document.addEventListener('astro:page-load', restoreLanguage);
      if (document.readyState !== 'loading') restoreLanguage();
    </script>

    <script>
      import Lenis from 'lenis';
      import 'lenis/dist/lenis.css';
      import { gsap } from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';

      gsap.registerPlugin(ScrollTrigger);

      const lenis = new Lenis({
        duration: 1.2,
        smoothWheel: true,
      });

      // Sync Lenis with GSAP ScrollTrigger
      lenis.on('scroll', ScrollTrigger.update);

      gsap.ticker.add((time) => {
        lenis.raf(time * 1000);
      });

      gsap.ticker.lagSmoothing(0);

      // Expose lenis instance for overlays to pause/resume
      (window as any).__lenis = lenis;

      // Respect reduced motion -- per D-10
      const motionQuery = window.matchMedia('(prefers-reduced-motion: reduce)');
      if (motionQuery.matches) {
        lenis.destroy();
      }
      motionQuery.addEventListener('change', (e) => {
        if (e.matches) lenis.destroy();
      });
    </script>
    <script>
      function syncOverlayProfileButtons() {
        const isLoggedIn = !!localStorage.getItem('kunsthaus-demo-user');
        const btns = document.querySelectorAll(
          '.hamburger-overlay__profile-btn, .search-overlay__profile-btn, .hours-overlay__profile-btn'
        );
        btns.forEach(btn => {
          (btn as HTMLElement).style.display = isLoggedIn ? 'flex' : 'none';
          btn.addEventListener('click', () => {
            document.querySelectorAll('.hamburger-overlay, .search-overlay, .hours-overlay').forEach(o => {
              if (o.classList.contains('is-open')) {
                o.classList.remove('is-open');
                o.setAttribute('aria-hidden', 'true');
              }
            });
            document.body.style.overflow = '';
            (window as any).__lenis?.start?.();
            setTimeout(() => (window as any).__profileOverlay?.open(), 100);
          });
        });
      }
      function initOverlayProfileSync() {
        syncOverlayProfileButtons();
        window.addEventListener('kunsthaus:login', syncOverlayProfileButtons);
        window.addEventListener('kunsthaus:logout', syncOverlayProfileButtons);
      }
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initOverlayProfileSync);
      } else {
        initOverlayProfileSync();
      }
      document.addEventListener('astro:page-load', initOverlayProfileSync);
    </script>
  </body>
</html>
